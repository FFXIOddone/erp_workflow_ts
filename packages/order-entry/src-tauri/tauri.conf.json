{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/tooling/cli/schema.json",
  "productName": "Wilde Signs - Order Entry",
  "identifier": "com.wildesigns.orderentry",
  "version": "1.0.0",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5184",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Order Entry",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["msi", "dmg"],
    "icon": [],
    "windows": {
      "wix": {
        "upgradeCode": "a1b2c3d4-e5f6-7890-abcd-ef1234567890"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
