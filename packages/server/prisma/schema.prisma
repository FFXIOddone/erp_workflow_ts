// Audit log for settings changes
model SettingsAudit {
  id          String   @id @default(uuid())
  field       String
  oldValue    String?
  newValue    String?
  changedById String
  changedAt   DateTime @default(now())
}

// ============ OAuth Tokens (Microsoft 365, etc.) ============

model OAuthToken {
  id           String   @id @default("microsoft-email") // singleton key per provider
  provider     String   @default("microsoft")           // "microsoft", etc.
  accessToken  String   @db.Text                        // current access token
  refreshToken String   @db.Text                        // long-lived refresh token
  expiresAt    DateTime                                 // when accessToken expires
  scope        String?                                  // granted scopes
  accountEmail String?                                  // the email account that authorized
  connectedBy  String?                                  // userId of admin who connected
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============ Activity Log ============

model ActivityLog {
  id          String   @id @default(uuid())
  action      String // e.g., "CREATE", "UPDATE", "DELETE", "LOGIN", "STATUS_CHANGE"
  entityType  String // e.g., "WorkOrder", "Customer", "Quote", "User"
  entityId    String? // ID of the affected entity
  entityName  String? // Human-readable name (e.g., order number, customer name)
  description String // Human-readable description of what happened
  details     Json? // Additional structured data (old/new values, etc.)
  ipAddress   String? // IP address of the request
  userAgent   String? // Browser/client info
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  // ============ Performance Indexes ============
  @@index([userId])
  @@index([entityType])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])                      // Entity history lookup
  @@index([entityType, createdAt])                     // Activity by type over time
  @@index([userId, createdAt])                         // User activity history
  @@index([action, createdAt])                         // Action audit trail
}

// ============ Import History ============

model ImportHistory {
  id            String   @id @default(uuid())
  fileName      String                    // Original filename
  filePath      String?                   // Server path (if from-path import)
  totalRows     Int
  imported      Int
  updated       Int      @default(0)
  skipped       Int
  errors        Int
  details       Json                       // Full ImportRowResult[] array
  userId        String?
  user          User?    @relation("UserImports", fields: [userId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

// ============ FedEx Ship Manager Logs ============

