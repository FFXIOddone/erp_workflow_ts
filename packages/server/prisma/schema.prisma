// ============ SSS-001: ML Prediction & Routing Intelligence ============

// Routing prediction model - Stores ML predictions for optimal routing
model RoutingPrediction {
  id                String              @id @default(uuid())
  
  // What we're predicting for
  workOrderId       String?
  workOrder         WorkOrder?          @relation("WorkOrderRoutingPredictions", fields: [workOrderId], references: [id], onDelete: Cascade)
  
  // Prediction context
  jobType           String?             // Sign type, material, complexity
  customerSegment   String?             // Customer tier/segment
  priorityLevel     Int                 // 1-5 priority
  estimatedArea     Float?              // Square footage/meters
  
  // Predicted optimal route
  predictedRoute    String[]            // Ordered array of PrintingMethod values
  confidence        Float               // 0.0 to 1.0 prediction confidence
  
  // Alternative routes with scores
  alternativeRoutes Json?               // Array of {route: [], score: number, reason: string}
  
  // Prediction factors
  factorWeights     Json?               // {queueDepth: 0.3, operatorSkill: 0.2, ...}
  
  // Timing predictions
  estimatedDuration Int?                // Minutes for full route
  estimatedPerStation Json?             // {ROLL_TO_ROLL: 45, LAMINATING: 15, ...}
  
  // Actual vs predicted (for learning)
  actualRoute       String[]            // What route was actually used
  actualDuration    Int?                // Actual total minutes
  wasAccepted       Boolean?            // Did user accept prediction
  feedbackScore     Int?                // 1-5 user rating of prediction
  feedbackNotes     String?
  
  // Model versioning
  modelVersion      String              // e.g., "v1.2.3"
  modelType         PredictionModelType @default(GRADIENT_BOOST)
  
  // Relation to decisions that used this prediction
  routingDecisions  RoutingDecision[]   @relation("RoutingDecisionPrediction")
  
  // Metadata
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([workOrderId])
  @@index([jobType])
  @@index([createdAt])
  @@index([modelVersion])
}

// Types of ML models used for predictions
enum PredictionModelType {
  GRADIENT_BOOST    // XGBoost/LightGBM style
  NEURAL_NET        // Deep learning
  RANDOM_FOREST     // Ensemble decision trees
  LINEAR_REGRESSION // Simple linear
  RULE_BASED        // Business rules only
  HYBRID            // Combination approach
}

// Optimization rule - Configurable business rules that influence routing
model OptimizationRule {
  id                String              @id @default(uuid())
  
  // Rule identification
  name              String              // Human readable name
  description       String?
  code              String              @unique // Machine identifier (e.g., "BATCH_SIMILAR_MATERIALS")
  
  // Rule type and category
  ruleType          OptimizationRuleType
  category          OptimizationCategory
  
  // Rule configuration
  conditions        Json                // Conditions that trigger this rule
  actions           Json                // What the rule does when triggered
  weight            Float               @default(1.0) // Influence weight (0.0 - 2.0)
  
  // Scope
  appliesTo         String[]            // PrintingMethods this applies to, empty = all
  
  // Learning from outcomes
  successCount      Int                 @default(0)
  failureCount      Int                 @default(0)
  averageImprovement Float?             // Avg time/cost improvement when applied
  
  // Status
  isActive          Boolean             @default(true)
  priority          Int                 @default(50) // 1-100, higher = checked first
  
  // Metadata
  createdBy         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([ruleType])
  @@index([isActive])
  @@index([priority])
}

// Types of optimization rules
enum OptimizationRuleType {
  ROUTING           // Affects route selection
  SCHEDULING        // Affects timing/scheduling
  BATCHING          // Groups jobs together
  RESOURCE          // Manages equipment/operators
  QUALITY           // Quality-based routing
  COST              // Cost optimization
  DEADLINE          // Due date driven
}

// Categories for organizing rules
enum OptimizationCategory {
  EFFICIENCY        // Speed/throughput
  COST_REDUCTION    // Lower costs
  QUALITY           // Quality outcomes
  CUSTOMER_SERVICE  // Customer satisfaction
  RESOURCE_BALANCE  // Even load distribution
  SUSTAINABILITY    // Waste reduction
}

// Station intelligence - Real-time and historical data per station
model StationIntelligence {
  id                String              @id @default(uuid())
  
  // Station reference
  station           PrintingMethod
  
  // Current state (updated frequently)
  currentQueueDepth Int                 @default(0)
  currentWaitTime   Int                 @default(0) // Minutes
  activeJobs        Int                 @default(0)
  activeOperators   Int                 @default(0)
  equipmentStatus   EquipmentStatus     @default(OPERATIONAL)
  
  // Capacity metrics
  dailyCapacityHours Float              @default(8.0)
  scheduledHours    Float               @default(0.0)
  availableHours    Float               @default(8.0)
  utilizationPct    Float               @default(0.0)
  
  // Historical performance
  avgJobDuration    Int?                // Minutes
  avgSetupTime      Int?                // Minutes between jobs
  avgQualityScore   Float?              // 0-100
  throughputPerHour Float?              // Jobs per hour
  
  // Skill matrix (JSON of operator skills)
  operatorSkills    Json?               // {userId: {skillLevel: 5, certifications: []}}
  
  // Bottleneck detection
  isBottleneck      Boolean             @default(false)
  bottleneckReason  String?
  bottleneckSince   DateTime?
  
  // Last updated
  lastCalculated    DateTime            @default(now())
  
  @@unique([station])
  @@index([isBottleneck])
  @@index([utilizationPct])
}

// NOTE: Using existing EquipmentStatus enum from equipment management section

// Routing decision log - Records every routing decision for learning
model RoutingDecision {
  id                String              @id @default(uuid())
  
  // Work order reference
  workOrderId       String
  workOrder         WorkOrder           @relation("WorkOrderRoutingDecisions", fields: [workOrderId], references: [id], onDelete: Cascade)
  
  // Decision details
  decisionType      RoutingDecisionType
  previousRoute     String[]            // Route before decision
  newRoute          String[]            // Route after decision
  
  // What triggered the decision
  trigger           RoutingTrigger
  triggerReason     String?
  
  // Factors considered
  factorsConsidered Json?               // {queueDepth: {ROLL_TO_ROLL: 5, ...}, ...}
  rulesApplied      String[]            // OptimizationRule codes that applied
  
  // Prediction used (if any)
  predictionId      String?
  prediction        RoutingPrediction?  @relation("RoutingDecisionPrediction", fields: [predictionId], references: [id])
  predictionScore   Float?
  
  // Who/what made the decision
  decisionMaker     DecisionMaker       @default(SYSTEM)
  userId            String?
  user              User?               @relation("UserRoutingDecisions", fields: [userId], references: [id])
  
  // Outcome tracking
  outcomeStatus     DecisionOutcome?
  outcomeNotes      String?
  actualDuration    Int?                // If different from predicted
  
  // Metadata
  createdAt         DateTime            @default(now())
  
  @@index([workOrderId])
  @@index([decisionType])
  @@index([createdAt])
}

// Add relation to RoutingPrediction
// (already defined inline above)

// Types of routing decisions
enum RoutingDecisionType {
  INITIAL           // First route assignment
  OPTIMIZATION      // System optimized route
  MANUAL_OVERRIDE   // User changed route
  REROUTE           // Changed due to issue
  SKIP_STATION      // Skipped a station
  ADD_STATION       // Added a station
  REORDER           // Changed station order
}

// What triggered a routing decision
enum RoutingTrigger {
  NEW_ORDER         // New order created
  QUEUE_IMBALANCE   // Queue depths unbalanced
  EQUIPMENT_CHANGE  // Equipment status changed
  OPERATOR_CHANGE   // Operator availability changed
  DEADLINE_RISK     // At risk of missing deadline
  USER_REQUEST      // User requested change
  QUALITY_ISSUE     // Quality problem at station
  BATCH_OPPORTUNITY // Can batch with similar jobs
  SCHEDULE_CHANGE   // Schedule optimization
}

// Who/what made the decision
enum DecisionMaker {
  SYSTEM            // Automated decision
  USER              // Manual user decision
  RULE              // Business rule triggered
  ML_MODEL          // ML prediction accepted
}

// Outcome of a routing decision
enum DecisionOutcome {
  PENDING           // Not yet completed
  SUCCESS           // Route worked well
  PARTIAL           // Partially successful
  FAILED            // Route caused issues
  REVERTED          // Had to change back
}

// Scheduling constraint - Defines constraints for the auto-scheduler
model SchedulingConstraint {
  id                String              @id @default(uuid())
  
  // Constraint identification
  name              String
  description       String?
  code              String              @unique
  
  // Constraint type
  constraintType    ConstraintType
  
  // What it constrains
  targetType        ConstraintTarget
  targetId          String?             // Specific station, user, etc.
  
  // Constraint definition
  definition        Json                // The actual constraint logic
  
  // Violation handling
  isHard            Boolean             @default(true) // Hard = must satisfy, Soft = prefer
  violationCost     Float?              // For soft constraints, cost of violation
  
  // Status
  isActive          Boolean             @default(true)
  priority          Int                 @default(50)
  
  // Metadata
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([constraintType])
  @@index([isActive])
}

// Types of scheduling constraints
enum ConstraintType {
  CAPACITY          // Maximum capacity limits
  AVAILABILITY      // Time-based availability
  DEPENDENCY        // Job dependencies
  SKILL             // Operator skill requirements
  EQUIPMENT         // Equipment requirements
  MATERIAL          // Material availability
  DEADLINE          // Due date constraints
  PREFERENCE        // Soft preferences
}

// What the constraint targets
enum ConstraintTarget {
  STATION           // Specific station
  OPERATOR          // Specific operator
  EQUIPMENT         // Specific equipment
  MATERIAL          // Specific material
  JOB_TYPE          // Type of job
  CUSTOMER          // Customer-specific
  GLOBAL            // System-wide
}

