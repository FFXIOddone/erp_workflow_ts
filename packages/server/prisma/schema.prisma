  createdBy         User                @relation("DeliveryRoutesCreated", fields: [createdById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([routeDate, routeName])
  @@index([routeDate])
  @@index([driverId])
  @@index([status])
}

// Route status
enum DeliveryRouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// Individual stops on a delivery route
model DeliveryStop {
  id                String              @id @default(uuid())
  routeId           String
  route             DeliveryRoute       @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  // Order
  stopOrder         Int                 // Sequence in route
  
  // Linked entities
  shipmentId        String?
  workOrderId       String?
  customerId        String?
  
  // Stop details
  stopType          DeliveryStopType
  companyName       String
  contactName       String?
  address           String
  city              String
  state             String
  zip               String
  phone             String?
  
  // Special instructions
  deliveryInstructions String?
  requiresSignature Boolean             @default(false)
  requiresPhoto     Boolean             @default(false)
  
  // Timing
  scheduledArrival  DateTime?
  actualArrival     DateTime?
  actualDeparture   DateTime?
  
  // Status
  status            DeliveryStopStatus  @default(PENDING)
  
  // Completion
  signedBy          String?
  signatureUrl      String?
  photoUrls         Json?               // Array of photo URLs
  deliveryNotes     String?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([routeId])
  @@index([shipmentId])
  @@index([status])
}

// Stop types
enum DeliveryStopType {
  DELIVERY           // Deliver goods
  PICKUP             // Pick up goods
  SIGNATURE_ONLY     // Collect signature/documents only
  SERVICE_CALL       // Service/installation
}

// Stop status
enum DeliveryStopStatus {
  PENDING
  EN_ROUTE           // Driver heading to stop
  ARRIVED            // Driver at location
  COMPLETED          // Delivery complete
  FAILED             // Delivery failed
  SKIPPED            // Stop skipped
}

// Tracking events from carriers
model TrackingEvent {
  id                String              @id @default(uuid())
  shipmentId        String
  shipment          Shipment            @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  carrierAccountId  String?
  carrierAccount    CarrierAccount?     @relation(fields: [carrierAccountId], references: [id])
  
  // Event details
  eventType         TrackingEventType
  eventDate         DateTime
  eventTime         DateTime?
  
  // Location
  city              String?
  state             String?
  zip               String?
  country           String?
  
  // Details
