// ============ Companies ============

model Company {
  id               String    @id @default(uuid())
  name             String
  legalName        String?   // Full legal name if different from display name
  dba              String?   // "Doing Business As" name
  
  // Primary Address
  address          String?
  city             String?
  state            String?
  zipCode          String?
  country          String    @default("USA")
  
  // Communication
  phone            String?
  fax              String?
  email            String?   // General company email
  website          String?
  
  // Billing Address (5 lines from QB)
  billToLine1      String?
  billToLine2      String?
  billToLine3      String?
  billToLine4      String?
  billToLine5      String?
  
  // Shipping Address (5 lines from QB)
  shipToLine1      String?
  shipToLine2      String?
  shipToLine3      String?
  shipToLine4      String?
  shipToLine5      String?
  
  // Financial
  taxExempt        Boolean   @default(false)
  resaleNumber     String?   // Tax exemption number
  creditLimit      Decimal?  @db.Decimal(10, 2)
  currentBalance   Decimal?  @db.Decimal(10, 2)
  paymentTerms     String?   // Net 30, Net 60, COD, etc.
  isOnCreditHold   Boolean   @default(false)
  creditHoldReason String?
  creditHoldDate   DateTime?
  accountNumber    String?   // QB Account number
  
  // Classification
  companyType      String?   // WALK IN, Corporate, Referral, Franchise, etc.
  industry         String?   // Gas Station, Coffee Shop, etc.
  salesRep         String?   // Sales rep initials
  salesTaxCode     String?   // Tax, Non
  taxItem          String?   // Sales Tax, Out of State, etc.
  tags             String[]
  
  notes            String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  // Relations
  contacts         Contact[]
  quotes           Quote[]            @relation("CompanyQuotes")
  workOrders       WorkOrder[]        @relation("CompanyWorkOrders")
  portalUsers      PortalUser[]       @relation("CompanyPortalUsers")
  documents        Document[]         @relation("CompanyDocuments")
  recurringOrders  RecurringOrder[]   @relation("CompanyRecurringOrders")
  installationJobs InstallationJob[]  @relation("CompanyInstallationJobs")
  projects         Project[]          @relation("CompanyProjects")
  
  // Hierarchy (parent/child company relationships)
  parentRelationships CompanyHierarchy[] @relation("ParentCompany")
  childRelationships  CompanyHierarchy[] @relation("ChildCompany")

  @@index([name])
  @@index([isActive, name])
  @@index([companyType])
  @@index([salesRep])
  @@index([isOnCreditHold, isActive])
}

// Individual contacts at companies
model Contact {
  id           String       @id @default(uuid())
  
  // Name
  salutation   String?      // Mr./Ms./etc.
  firstName    String
  lastName     String
  middleInitial String?
  
  // Role at company
  title        String?      // Job title
  role         ContactRole  @default(PRIMARY)
  isPrimary    Boolean      @default(false)
  
  // Contact info
  email        String?
  phone        String?
  mobile       String?
  
  notes        String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  // Relations
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Work orders where this contact is the PoC
  workOrders   WorkOrder[]  @relation("ContactWorkOrders")
  
  // Portal access
  portalUser   PortalUser?  @relation("ContactPortalUser")
  
  @@index([companyId])
  @@index([email])
  @@index([lastName, firstName])
}

// Company hierarchy for parent/child relationships (franchises, subsidiaries, etc.)
model CompanyHierarchy {
  id              String              @id @default(uuid())
  
  parentCompanyId String
  childCompanyId  String
  relationType    CustomerRelationType  // Reusing existing enum
  
  effectiveFrom   DateTime            @default(now())
  effectiveUntil  DateTime?
  isPrimary       Boolean             @default(true)
  
  inheritBilling  Boolean             @default(false)
  inheritPricing  Boolean             @default(false)
  inheritTerms    Boolean             @default(false)
  
  notes           String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  parentCompany   Company             @relation("ParentCompany", fields: [parentCompanyId], references: [id], onDelete: Cascade)
  childCompany    Company             @relation("ChildCompany", fields: [childCompanyId], references: [id], onDelete: Cascade)
  
  @@unique([parentCompanyId, childCompanyId])
  @@index([parentCompanyId])
  @@index([childCompanyId])
}

