  RETURNED           // Returned to sender
  HELD               // Held at facility
  CUSTOMS            // In customs
}

// ============================================================================
// NEW-CRITICAL-08: VERSION CONTROL & REVISION MANAGEMENT
// ============================================================================

// Entity revisions for tracking changes
model EntityRevision {
  id                String              @id @default(uuid())
  
  // Entity identification
  entityType        RevisionEntityType
  entityId          String
  
  // Revision details
  revisionNumber    Int
  revisionType      RevisionType
  
  // Change summary
  title             String?
  description       String?             @db.Text
  changeReason      ChangeReason?
  changeNotes       String?             @db.Text
  
  // Before/after data
  previousData      Json?               // Snapshot of previous state
  currentData       Json?               // Snapshot of current state
  changedFields     Json?               // Array of changed field names
  
  // Approval workflow
  status            RevisionStatus      @default(DRAFT)
  requiresApproval  Boolean             @default(false)
  approvalWorkflow  ApprovalWorkflow?
  
  // Request/Approval tracking
  requestedById     String
  requestedBy       User                @relation("RevisionsRequested", fields: [requestedById], references: [id])
  requestedAt       DateTime            @default(now())
  
  approvedById      String?
  approvedBy        User?               @relation("RevisionsApproved", fields: [approvedById], references: [id])
  approvedAt        DateTime?
  approvalNotes     String?
  
  rejectedById      String?
  rejectedBy        User?               @relation("RevisionsRejected", fields: [rejectedById], references: [id])
  rejectedAt        DateTime?
  rejectionReason   String?
  
  // Implementation
  implementedById   String?
  implementedBy     User?               @relation("RevisionsImplemented", fields: [implementedById], references: [id])
  implementedAt     DateTime?
  
  // Linked revisions
  parentRevisionId  String?
  parentRevision    EntityRevision?     @relation("RevisionHistory", fields: [parentRevisionId], references: [id])
  childRevisions    EntityRevision[]    @relation("RevisionHistory")
  
  // Impact tracking
  impactedEntities  Json?               // Array of { type, id, description }
  
  // Attachments
  attachmentUrls    Json?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([entityType, entityId, revisionNumber])
  @@index([entityType, entityId])
  @@index([status])
  @@index([requestedById])
  @@index([requestedAt])
}

// Entity types that support versioning
enum RevisionEntityType {
  WORK_ORDER
  QUOTE
  LINE_ITEM
  DESIGN_FILE
  BOM
  TEMPLATE
  PRICING
  CUSTOMER
  PRODUCT
  PROOF
}

// Revision types
enum RevisionType {
  INITIAL_VERSION    // First version
  MINOR_CHANGE       // Small change (typo, minor adjustment)
  MAJOR_CHANGE       // Significant change (scope, pricing)
  CORRECTION         // Error correction
  CUSTOMER_REQUEST   // Customer-requested change
  INTERNAL_UPDATE    // Internal process update
  ROLLBACK           // Reverting to previous version
  MERGE              // Merging changes
}

// Reasons for change
enum ChangeReason {
  CUSTOMER_REQUEST
  DESIGN_ERROR
  SPECIFICATION_CHANGE
  PRICING_ADJUSTMENT
  QUANTITY_CHANGE
  MATERIAL_CHANGE
  SCHEDULE_CHANGE
  QUALITY_ISSUE
  VENDOR_ISSUE
  PROCESS_IMPROVEMENT
  REGULATORY_REQUIREMENT
  OTHER
}

// Revision status
enum RevisionStatus {
  DRAFT              // Being prepared
  PENDING_REVIEW     // Awaiting review
  PENDING_APPROVAL   // Awaiting approval
  APPROVED           // Approved, ready to implement
  IMPLEMENTING       // Being implemented
  IMPLEMENTED        // Successfully implemented
  REJECTED           // Rejected
  CANCELLED          // Cancelled
  ON_HOLD            // On hold
}

// Approval workflow types
enum ApprovalWorkflow {
  NONE               // No approval needed
  MANAGER_ONLY       // Single manager approval
  CUSTOMER_ONLY      // Customer approval only
  MANAGER_THEN_CUSTOMER // Manager, then customer
  PARALLEL           // Multiple approvers simultaneously
  SEQUENTIAL         // Multiple approvers in sequence
}

// Design file versions with visual diff support
model DesignVersion {
  id                String              @id @default(uuid())
  
  // Parent design file
  designFileId      String?
  
  // Version info
  versionNumber     Int
  versionLabel      String?             // "v1.0", "Final", "Rev A", etc.
  
  // File info
  fileName          String
  fileUrl           String
  fileSize          Int?                // In bytes
  fileType          String              // MIME type
  thumbnailUrl      String?
  
  // Metadata
  width             Int?                // For images
  height            Int?
  colorProfile      String?
  dpi               Int?
  
  // Annotations (JSON array of annotations with coordinates)
  annotations       Json?
  
  // Changes from previous version
  changeDescription String?             @db.Text
  changedAreas      Json?               // Highlighted areas of change
  
  // Status
  status            DesignVersionStatus @default(DRAFT)
  isCurrentVersion  Boolean             @default(false)
  
  // Creator
  createdById       String
  createdBy         User                @relation("DesignVersionsCreated", fields: [createdById], references: [id])
  
  // Approval
  approvedById      String?
  approvedBy        User?               @relation("DesignVersionsApproved", fields: [approvedById], references: [id])
  approvedAt        DateTime?
  
  // Customer proof link
  proofId           String?
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([designFileId, versionNumber])
  @@index([designFileId])
  @@index([status])
  @@index([isCurrentVersion])
}

// Design version status
enum DesignVersionStatus {
  DRAFT
  REVIEW
  APPROVED
  REJECTED
  SUPERSEDED
  ARCHIVED
}

// Change orders for formal scope changes
model ChangeOrder {
  id                String              @id @default(uuid())
  changeOrderNumber String              @unique
  
  // Linked entity
  workOrderId       String?
  workOrder         WorkOrder?          @relation(fields: [workOrderId], references: [id])
  quoteId           String?
  quote             Quote?              @relation(fields: [quoteId], references: [id])
  projectId         String?
  
  // Change details
  title             String
  description       String              @db.Text
  changeType        ChangeOrderType
  priority          ChangeOrderPriority @default(NORMAL)
  status            ChangeOrderStatus   @default(DRAFT)
  
  // Scope
  scopeChanges      Json?               // Array of scope change items
  
  // Impact analysis
  scheduleImpact    String?             // Description of schedule impact
  daysAdded         Int?
  costImpact        String?             // Description of cost impact
  costChange        Decimal?            @db.Decimal(10, 2) // +/- amount
  materialImpact    String?
  laborImpact       String?
  
  // Original vs new values
  originalValues    Json?               // { dueDate, total, items, etc. }
  newValues         Json?
  
  // Requester (can be internal or customer)
  requestSource     ChangeRequestSource
  requestedById     String?
  requestedBy       User?               @relation("ChangeOrdersRequested", fields: [requestedById], references: [id])
  customerRequestDate DateTime?
  customerContact   String?
  
  // Approval chain
  internalApprovalStatus ChangeApprovalStatus @default(PENDING)
  internalApprovedById String?
  internalApprovedBy User?              @relation("ChangeOrdersInternalApproved", fields: [internalApprovedById], references: [id])
  internalApprovedAt DateTime?
  internalNotes     String?
  
  customerApprovalStatus ChangeApprovalStatus @default(NOT_REQUIRED)
  customerApprovedAt DateTime?
  customerSignature String?
  customerNotes     String?
  
  // Implementation
  implementedById   String?
  implementedBy     User?               @relation("ChangeOrdersImplemented", fields: [implementedById], references: [id])
  implementedAt     DateTime?
  
  // Documents
  attachmentUrls    Json?
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([workOrderId])
  @@index([quoteId])
  @@index([status])
  @@index([changeOrderNumber])
}

// Change order types
enum ChangeOrderType {
  SCOPE_ADDITION     // Adding work
  SCOPE_REDUCTION    // Removing work
  SPECIFICATION_CHANGE
  MATERIAL_CHANGE
  SCHEDULE_CHANGE
  PRICING_ADJUSTMENT
  DESIGN_REVISION
  CORRECTION
  OTHER
}

// Change order priority
enum ChangeOrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL
}

// Change order status
enum ChangeOrderStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  PENDING_CUSTOMER
  APPROVED
  REJECTED
  IMPLEMENTING
  COMPLETED
  CANCELLED
}

// Change request source
enum ChangeRequestSource {
  INTERNAL           // Internal team request
  CUSTOMER           // Customer request
  VENDOR             // Vendor/supplier request
  QUALITY            // Quality control finding
  REGULATORY         // Regulatory requirement
}

// Change approval status (for change orders)
enum ChangeApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
  SKIPPED
}

// Comparison/diff records for visual comparisons
model VersionComparison {
  id                String              @id @default(uuid())
  
  // Versions being compared
  entityType        RevisionEntityType
  entityId          String
  oldRevisionNumber Int
  newRevisionNumber Int
  
  // Comparison results
  diffSummary       Json?               // { added: [], removed: [], modified: [] }
  fieldComparisons  Json?               // Detailed field-by-field comparison
  visualDiffUrl     String?             // URL to visual diff image
  
  // Metrics
  percentChanged    Float?              // Percentage of content changed
  addedLines        Int?
  removedLines      Int?
  modifiedLines     Int?
  
  // Generator
  generatedById     String
  generatedBy       User                @relation("ComparisonsGenerated", fields: [generatedById], references: [id])
  generatedAt       DateTime            @default(now())
  
  notes             String?
  
  @@unique([entityType, entityId, oldRevisionNumber, newRevisionNumber])
  @@index([entityType, entityId])
}

