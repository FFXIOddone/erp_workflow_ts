// ============ Print Station Management Models ============

model PrintQueue {
  id              String          @id @default(uuid())
  name            String          @unique
  description     String?
  
  // Station assignment
  station         PrintingMethod
  
  // Queue settings
  priority        Int             @default(1)   // Higher = processed first
  isActive        Boolean         @default(true)
  maxConcurrent   Int             @default(1)   // Max jobs running at once
  
  // Status
  currentJobs     Int             @default(0)
  pendingJobs     Int             @default(0)
  
  // Scheduling
  autoSchedule    Boolean         @default(false)
  scheduledHours  Json?           // { start: "08:00", end: "17:00" }
  
  // Metadata
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  jobs            PrintJob[]
  
  @@index([station])
  @@index([isActive])
}

model PrintJob {
  id              String          @id @default(uuid())
  
  // Queue assignment
  queueId         String
  queue           PrintQueue      @relation(fields: [queueId], references: [id], onDelete: Cascade)
  
  // Work order reference
  workOrderId     String
  workOrder       WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  lineItemId      String?         // Optional specific line item
  
  // Job details
  jobNumber       String          @unique
  name            String
  description     String?
  
  // Files and materials
  fileUrl         String?         // Source file to print
  fileName        String?
  fileSize        Int?
  materialType    String?         // e.g., "3M 8518", "ORAFOL 451"
  mediaWidth      Decimal?        @db.Decimal(10, 2)
  mediaLength     Decimal?        @db.Decimal(10, 2)
  copies          Int             @default(1)
  
  // Status
  status          PrintJobStatus  @default(PENDING)
  priority        Int             @default(3)   // 1=urgent, 5=low
  
  // Progress
  estimatedMinutes Int?
  actualMinutes   Int?
  startedAt       DateTime?
  completedAt     DateTime?
  
  // Operator notes
  operatorNotes   String?
  qualityNotes    String?
  
  // Error handling
  errorMessage    String?
  retryCount      Int             @default(0)
  maxRetries      Int             @default(3)
  
  // Metadata
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Equipment assignment (direct FK instead of embedding in notes)
  equipmentId     String?
  equipment       Equipment?      @relation("PrintJobEquipment", fields: [equipmentId], references: [id])
  
  // RIP job link
  ripJobId        String?         @unique
  ripJob          RipJob?         @relation("RipJobPrintJob", fields: [ripJobId], references: [id])
  
  // Print settings (can be set before RIP)
  colorProfile    String?         // e.g., "sRGB", "AdobeRGB", "CMYK_Uncoated"
  printResolution String?         // e.g., "720x720", "1440x720"
  printMode       String?         // e.g., "Production", "Quality", "Billboard"
  mediaProfile    String?         // RIP media profile name
  whiteInk        String?         // "None", "Underflood", "Overflood", "Spot"
  mirror          Boolean         @default(false)
  
  // Relations
  assignedToId    String?
  assignedTo      User?           @relation("PrintJobAssignedTo", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User            @relation("PrintJobCreatedBy", fields: [createdById], references: [id])
  
  @@index([queueId])
  @@index([workOrderId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([equipmentId])
}

enum PrintJobStatus {
  PENDING         // Waiting in queue
  PREPARING       // Pre-print preparation (RIP, layout)
  READY           // Ready to print
  PRINTING        // Currently printing
  DRYING          // Print complete, drying
  FINISHING       // Post-print processing (laminate, cut)
  QUALITY_CHECK   // Quality inspection
  COMPLETED       // Successfully completed
  ON_HOLD         // Paused by operator
  FAILED          // Failed, needs intervention
  CANCELLED       // Cancelled
  REPRINTING      // Reprinting due to quality issue
}

// ============ RIP Queue Integration ============

// Tracks a file's journey from the ERP through the RIP to the printer.
// The ERP copies print files into Thrive/Fiery hotfolders and monitors
// the queue XML to detect status changes.
model RipJob {
  id               String          @id @default(uuid())
  
  // Work order reference
  workOrderId      String
  workOrder        WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  // Source file info (from the WO folder on the file server)
  sourceFilePath   String          // Full UNC path to original file
  sourceFileName   String          // Original file name
  sourceFileSize   Int?            // File size in bytes
  
  // RIP destination
  hotfolderPath    String          // UNC path to the Thrive/Fiery hotfolder
  hotfolderName    String          // Friendly name (e.g., "HP Latex 800 W")
  ripType          String          @default("Onyx") // Onyx, Flexi, Caldera, VersaWorks, Fiery, Other
  
  // Status lifecycle
  status           RipJobStatus    @default(QUEUED)
  
  // Print settings (configured in ERP before sending to RIP)
  colorProfile     String?         // e.g., "sRGB", "AdobeRGB", "CMYK_Uncoated"
  printResolution  String?         // e.g., "720x720", "1440x720"
  printMode        String?         // e.g., "Production", "Quality", "Billboard"
  mediaProfile     String?         // RIP media profile name
  mediaType        String?         // e.g., "3M 8518", "ORAFOL 451"
  mediaWidth       Decimal?        @db.Decimal(10, 2) // inches
  mediaLength      Decimal?        @db.Decimal(10, 2) // inches
  copies           Int             @default(1)
  whiteInk         String?         // "None", "Underflood", "Overflood", "Spot"
  mirror           Boolean         @default(false)
  nestingEnabled   Boolean         @default(false)
  printSettingsJson Json?          // Additional RIP-specific settings as JSON
  
  // Timing data (KPI gold)
  queuedAt         DateTime        @default(now()) // When ERP sent file to hotfolder
  rippedAt         DateTime?       // When RIP finished processing (detected via queue XML)
  sentToPrinterAt  DateTime?       // When RIP sent to printer (status=Printing in XML)
  printStartedAt   DateTime?       // When printing physically started
  printCompletedAt DateTime?       // When printing completed (status=Printed in XML)
  cancelledAt      DateTime?       // When cancelled (if applicable)
  
  // Thrive/RIP tracking
  ripJobGuid       String?         // Job GUID from Thrive QueueXML.Info
  ripStatusCode    Int?            // Thrive status code (0=Pending,4=Processing,8=Ready,16=Printing,32=Printed,64=Error)
  ripInkUsage      String?         // Total ink usage reported by RIP
  ripInkCoverage   String?         // Ink coverage %
  
  // Error handling
  errorMessage     String?
  retryCount       Int             @default(0)
  
  // Operator
  notes            String?
  priority         Int             @default(3) // 1=urgent, 5=low
  
  // Relations
  equipmentId      String?         // Target printer equipment
  equipment        Equipment?      @relation("RipJobEquipment", fields: [equipmentId], references: [id])
  createdById      String
  createdBy        User            @relation("RipJobCreatedBy", fields: [createdById], references: [id])
  operatorId       String?
  operator         User?           @relation("RipJobOperator", fields: [operatorId], references: [id])
  printJob         PrintJob?       @relation("RipJobPrintJob") // Link to the ERP PrintJob record
  printCutLinks    PrintCutLink[]  @relation("PrintCutLinkRipJob") // Links to cut file chain
  
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  
  @@index([workOrderId])
  @@index([status])
  @@index([queuedAt])
  @@index([ripJobGuid])
  @@index([equipmentId])
  @@index([createdById])
}

enum RipJobStatus {
  QUEUED           // File copied to hotfolder, waiting for RIP
  PROCESSING       // RIP is processing (rasterizing)
  READY            // RIP done, ready to send to printer
  SENDING          // Sending to printer
  PRINTING         // Currently printing
  PRINTED          // Print complete
  COMPLETED        // Fully done (verified/cleared)
  FAILED           // Error occurred
  CANCELLED        // Cancelled by user
}

// ============ Print-Cut File Chain ============

// Links a print file to its corresponding Zund cut file.
// Tracks the full lifecycle: design → RIP → print → cut → finished.
// Auto-linked by the file-chain daemon or manually by operators.
model PrintCutLink {
  id               String              @id @default(uuid())
  
  // Work order reference
  workOrderId      String
  workOrder        WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  // Print side
  printFileName    String              // Original print file name
  printFilePath    String              // Full UNC path to print file
  printFileSize    Int?                // File size in bytes
  ripJobId         String?             // Link to RipJob if sent through ERP
  ripJob           RipJob?             @relation("PrintCutLinkRipJob", fields: [ripJobId], references: [id])
  
  // Cut side (null until cut file is linked)
  cutFileName      String?             // Cut file name (.zcc, .xml, etc.)
  cutFilePath      String?             // Full UNC path to cut file
  cutFileSize      Int?                // Cut file size in bytes
  cutFileSource    CutFileSource?      // THRIVE, FIERY, MANUAL, ZUND_CENTER
  cutFileFormat    String?             // File extension (.zcc, .xml, .dxf)
  
  // Status & linking
  status           FileChainStatus     @default(DESIGN)
  linkConfidence   LinkConfidence      @default(NONE)
  linkedAt         DateTime?           // When cut file was linked
  linkedById       String?             // null = auto-linked by daemon
  linkedBy         User?               @relation("PrintCutLinkLinkedBy", fields: [linkedById], references: [id])
  
  // Confirmation tracking
  confirmed        Boolean             @default(false)
  confirmedAt      DateTime?
  confirmedById    String?
  confirmedBy      User?               @relation("PrintCutLinkConfirmedBy", fields: [confirmedById], references: [id])
  
  // Print tracking
  printStartedAt   DateTime?
  printCompletedAt DateTime?
  printerName      String?             // e.g., "HP Latex 800 W"
  ripMachine       String?             // e.g., "WS-RIP2"
  
  // Cut tracking
  cutStartedAt     DateTime?
  cutCompletedAt   DateTime?
  cutterName       String?             // "Zund 1" or "Zund 2"
  cutJobName       String?             // Job name from Zund stats DB
  cutCopiesDone    Int?
  cutCopiesTotal   Int?
  
  // Zund statistics (from Statistic.db3)
  zundJobId        String?             // Zund ProductionTimeJob.JobID
  zundMaterialGuid String?             // Material GUID from Zund
  cuttingTimeMs    Int?                // Total cutting time in ms
  setupTimeMs      Int?                // Setup time in ms
  cutLengthMm      Float?              // Total cut length in mm
  
  // CutID cross-linking (e.g., P1_T1_162_57_33277349)
  cutId            String?
  
  // Error tracking
  errorMessage     String?
  
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  
  @@index([workOrderId])
  @@index([status])
  @@index([ripJobId])
  @@index([printFileName])
  @@index([cutFileName])
  @@index([linkConfidence])
  @@index([cutId])
  @@index([createdAt])
}

enum FileChainStatus {
  DESIGN             // File exists in design, not yet sent
  SENT_TO_RIP        // Sent to RIP hotfolder
  RIPPING            // RIP is processing
  READY_TO_PRINT     // RIP done, queued for printer
  PRINTING           // Currently printing
  PRINTED            // Print complete
  CUT_PENDING        // Has a cut file queued/waiting
  CUTTING            // Zund is actively cutting
  CUT_COMPLETE       // Cut complete
  FINISHED           // Print+cut both done
  FAILED             // Error at any stage
}

enum LinkConfidence {
  EXACT              // WO# + filename exact match
  HIGH               // WO# match + customer match
  MEDIUM             // WO# match only
  PARTIAL            // Substring/normalized match
  NESTING            // Nesting pattern detected
  MANUAL             // Manually linked by operator
  NONE               // Auto-detected, low confidence
}

enum CutFileSource {
  THRIVE             // Thrive Onyx Cut Center XML
  FIERY              // EFI Fiery .zcc contour file
  MANUAL             // Manually imported cut file
  ZUND_CENTER        // Created in Zund Cut Center directly
}

// ============ Manual Job Links ============

// Allows operators to manually associate external Thrive/Zund jobs with work orders
// when automatic name-based matching fails.
model ManualJobLink {
  id              String          @id @default(uuid())
  
  workOrderId     String
  workOrder       WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  jobType         ManualJobType   // PRINT_JOB, CUT_JOB, ZUND_QUEUE, ZUND_COMPLETED
  jobIdentifier   String          // jobGuid for print/cut, fileName for zund queue, jobId for completed
  jobName         String          // Display name
  
  linkedAt        DateTime        @default(now())
  linkedById      String
  linkedBy        User            @relation("ManualJobLinkLinkedBy", fields: [linkedById], references: [id])
  
  @@unique([workOrderId, jobType, jobIdentifier])
  @@index([workOrderId])
  @@index([jobIdentifier])
}

// Tracks auto-linked jobs that a user has dismissed/rejected.
// Prevents the auto-linker daemon from re-creating removed links.
model DismissedJobLink {
  id              String          @id @default(uuid())
  
  workOrderId     String
  workOrder       WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  jobType         ManualJobType   // reuse existing enum
  jobIdentifier   String          // cutID, jobGuid, fileName, jobId
  reason          String?         // optional user note
  
  dismissedAt     DateTime        @default(now())
  dismissedById   String
  dismissedBy     User            @relation("DismissedJobLinkDismissedBy", fields: [dismissedById], references: [id])
  
  @@unique([workOrderId, jobType, jobIdentifier])
  @@index([workOrderId])
  @@index([jobIdentifier])
}

enum ManualJobType {
  PRINT_JOB        // Thrive print queue job
  CUT_JOB          // Thrive cut center job
  ZUND_QUEUE       // Zund .zcc queue file
  ZUND_COMPLETED   // Zund statistics completed job
  FIERY_JOB        // Fiery RIP print job
}

// ============ Installation Tracking ============

// Tracks installation sessions with timer and photo uploads.
// Supports offline operation — photos queue locally until wifi reconnects.
model InstallSession {
  id               String              @id @default(uuid())
  
  workOrderId      String
  workOrder        WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  // Installer
  installerId      String
  installer        User                @relation("InstallSessionInstaller", fields: [installerId], references: [id])
  
  // Timing
  startedAt        DateTime            @default(now())
  pausedAt         DateTime?
  completedAt      DateTime?
  totalPausedMs    Int                 @default(0)  // Accumulated pause time
  durationMinutes  Float?              // Calculated on completion
  
  // Location (from mobile GPS)
  latitude         Float?
  longitude        Float?
  address          String?             // Reverse geocoded
  
  // Status
  status           InstallSessionStatus @default(IN_PROGRESS)
  notes            String?
  
  // Photos
  photos           SessionPhoto[]
  
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  
  @@index([workOrderId])
  @@index([installerId])
  @@index([status])
  @@index([startedAt])
}

enum InstallSessionStatus {
  IN_PROGRESS
  PAUSED
  COMPLETED
}

model SessionPhoto {
  id               String              @id @default(uuid())
  
  installSessionId String
  installSession   InstallSession      @relation(fields: [installSessionId], references: [id], onDelete: Cascade)
  
  fileName         String
  filePath         String              // Relative to uploads dir
  thumbnailPath    String?
  fileSize         Int?
  mimeType         String              @default("image/jpeg")
  
  // Capture metadata
  capturedAt       DateTime            @default(now())
  uploadedAt       DateTime?           // null until synced
  synced           Boolean             @default(false)
  
  // GPS from phone
  latitude         Float?
  longitude        Float?
  
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  
  @@index([installSessionId])
  @@index([synced])
}

// ============ Shipping Label Scanning ============

model ShippingLabelScan {
