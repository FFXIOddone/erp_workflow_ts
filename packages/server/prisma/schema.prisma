  networkDriveBasePath     String? // e.g., "\\\\SERVER\\Share\\Orders" or "S:\\"
  networkDriveSafariPath   String? // Base path for Safari/Port City Signs 4-digit WOs, e.g. "S:\\Safari"
  networkDriveFolderPattern String  @default("{orderNumber}") // Pattern for folder names. Supports: {orderNumber}, {customerName}, {year}, {month}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
