// ============ QuickBooks Data Cache ============
// Local cache of QB invoices, sales orders, and estimates.
// Populated by the QB Agent USB tool or ODBC snapshot.
// Allows line-item lookup without a live QB connection.

model QBCachedOrder {
  id           String   @id @default(uuid())
  refNumber    String   // Invoice/SO/Estimate number (QB RefNumber)
  txnId        String?  // QB TxnID (null for manual/CSV imports)
  type         String   // 'invoice' | 'salesOrder' | 'estimate'
  customerName String
  totalAmount  Float    @default(0)
  poNumber     String?
  txnDate      DateTime?
  memo         String?
  snapshotDate DateTime @default(now()) // When this was cached
  source       String   @default("odbc") // 'odbc' | 'csv' | 'agent' | 'manual'
  lineItems    QBCachedLineItem[]

  @@unique([refNumber, type])
  @@index([customerName])
  @@index([txnDate])
  @@index([snapshotDate])
}

model QBCachedLineItem {
  id          String        @id @default(uuid())
  orderId     String
  order       QBCachedOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lineNumber  Int
  itemName    String?
  description String?
  quantity    Float?
  rate        Float?
  amount      Float         @default(0)
  unit        String?

  @@index([orderId])
}

// ============ File Chain Logging ============

// Structured log for the print-to-cut linking pipeline.
// Tracks every step of Zund watcher → CutID match → WO link flow.
model FileChainLog {
  id               String   @id @default(uuid())
  timestamp        DateTime @default(now())
  level            String   // INFO, WARN, ERROR, DEBUG
  source           String   // ZUND_WATCHER, AUTO_LINKER, MANUAL
  event            String   // NEW_ZCC_DETECTED, CUTID_EXTRACTED, PRINT_LOG_MATCH, WO_FOUND, LINK_CREATED, etc.
  message          String
  details          Json?    // Structured data for debugging
  cutId            String?
  zccFileName      String?
  printFileName    String?
  workOrderId      String?
  workOrderNumber  String?
  printCutLinkId   String?
  success          Boolean  @default(true)

  @@index([timestamp])
  @@index([source])
  @@index([event])
  @@index([cutId])
  @@index([workOrderId])
}
model BarcodeScan {
  id           String      @id @default(cuid())
  rawBarcode   String
  parsedCutId  String?
  orientation  String?
  station      String?
  matched      Boolean     @default(false)
  workOrderId  String?
  workOrder    WorkOrder?  @relation(fields: [workOrderId], references: [id])
  scannedAt    DateTime    @default(now())

  @@index([parsedCutId])
  @@index([workOrderId])
  @@index([scannedAt])
}
