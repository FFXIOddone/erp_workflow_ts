// Forecast method enum
enum ForecastMethod {
  MOVING_AVERAGE
  EXPONENTIAL_SMOOTHING
  LINEAR_REGRESSION
  SEASONAL
  ARIMA
  MACHINE_LEARNING
  MANUAL
}

// Forecast status
enum ForecastStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

// Demand forecast model for predictive inventory
model DemandForecast {
  id              String              @id @default(uuid())
  organizationId  String?
  
  // Item identification
  itemMasterId    String?
  materialCategory String?            // Category-level forecast
  
  // Forecast period
  periodStart     DateTime
  periodEnd       DateTime
  granularity     ForecastGranularity
  
  // Forecast values
  forecastQuantity Float
  minQuantity     Float?              // Optimistic
  maxQuantity     Float?              // Pessimistic
  confidenceLevel Float?              // 0-100%
  
  // Historical basis
  historicalPeriods Int?              // Number of periods analyzed
  historicalAverage Float?
  trendFactor     Float?              // > 1 = growing, < 1 = declining
  seasonalFactor  Float?              // Seasonal adjustment
  
  // Method
  forecastMethod  ForecastMethod
  modelParameters Json?               // ML model params, coefficients, etc.
  
  // Accuracy tracking
  actualQuantity  Float?              // Filled in after period ends
  forecastError   Float?              // Actual - Forecast
  errorPercentage Float?              // MAPE
  
  // Status
  status          ForecastStatus      @default(DRAFT)
  approvedById    String?
  approvedAt      DateTime?
  
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([itemMasterId])
  @@index([periodStart, periodEnd])
  @@index([status])
  @@index([organizationId])
}

// Forecast granularity
enum ForecastGranularity {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
}

// Reorder point with dynamic calculation
model ReorderPoint {
  id              String              @id @default(uuid())
  organizationId  String?
  itemMasterId    String              @unique
  
  // Static thresholds (can be overridden by dynamic)
  minQuantity     Float               // Minimum stock level
  reorderQuantity Float               // Quantity to reorder
  maxQuantity     Float?              // Maximum stock level
  
  // Dynamic calculation
  isDynamic       Boolean             @default(false)
  leadTimeDays    Int                 @default(7)
  safetyStockDays Int                 @default(3)
  demandPerDay    Float?              // Average daily usage
  
  // Calculated values (updated by system)
  calculatedReorderPoint Float?
  calculatedSafetyStock Float?
  nextReorderDate DateTime?
  
  // Supplier info
  preferredSupplierId String?
  alternateSupplierIds String[]
  
  // Status
  lastCalculatedAt DateTime?
  lastOrderedAt   DateTime?
  lastOrderQuantity Float?
  
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([itemMasterId])
  @@index([isDynamic])
  @@index([nextReorderDate])
}

// Supplier performance rating category
enum PerformanceCategory {
  DELIVERY
  QUALITY
  PRICE
  RESPONSIVENESS
  DOCUMENTATION
  OVERALL
}

// Supplier performance metrics tracking
model SupplierPerformance {
  id              String              @id @default(uuid())
  vendorId        String
  organizationId  String?
  
  // Period
  periodStart     DateTime
  periodEnd       DateTime
  
  // Delivery metrics
  ordersPlaced    Int                 @default(0)
  ordersReceived  Int                 @default(0)
  ordersOnTime    Int                 @default(0)
  ordersComplete  Int                 @default(0)
  ordersCancelled Int                 @default(0)
  averageLeadDays Float?
  
  // Quality metrics
  itemsReceived   Int                 @default(0)
  itemsDefective  Int                 @default(0)
  itemsReturned   Int                 @default(0)
  qualityScore    Float?              // 0-100
  
  // Cost metrics
  totalSpend      Decimal?            @db.Decimal(12, 2)
  priceVariance   Float?              // % variance from quoted
  savingsAchieved Decimal?            @db.Decimal(10, 2)
  
  // Responsiveness
  avgResponseTime Float?              // Hours to respond to inquiries
  quotesRequested Int                 @default(0)
  quotesReceived  Int                 @default(0)
  
  // Calculated scores (0-100)
  deliveryScore   Float?
  qualityMetricScore Float?           // Renamed from qualityScore to avoid conflict
  priceScore      Float?
  responsivenessScore Float?
  overallScore    Float?
  
  // Tier/Rating
  performanceTier SupplierTier?
  
  // Notes
  issues          Json?               // List of issues during period
  notes           String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@unique([vendorId, periodStart, periodEnd])
  @@index([vendorId])
  @@index([periodStart, periodEnd])
  @@index([overallScore])
}

// Supplier tier
enum SupplierTier {
  PREFERRED
  APPROVED
  CONDITIONAL
  PROBATION
  DISQUALIFIED
}

// Substitution type
enum SubstitutionType {
  EQUIVALENT           // Functionally equivalent
  ALTERNATIVE          // Different but acceptable
  UPGRADE              // Better than original
  DOWNGRADE            // Lesser but acceptable in emergency
  TEMPORARY            // Short-term only
}

// Material substitution for alternative materials
model MaterialSubstitution {
  id              String              @id @default(uuid())
  organizationId  String?
  
  // Primary and substitute items
  primaryItemId   String
  substituteItemId String
  
  // Substitution details
  substitutionType SubstitutionType
  conversionFactor Float              @default(1.0) // e.g., 1.2 means use 20% more
  
  // Constraints
  maxSubstituteQty Float?             // Maximum quantity to substitute
  requiresApproval Boolean            @default(false)
  approvalThreshold Float?            // Quantity above which approval needed
  
  // Cost impact
  costDifference  Decimal?            @db.Decimal(10, 2) // Positive = more expensive
  qualityImpact   String?             // Description of quality difference
  
  // Usage
  isActive        Boolean             @default(true)
  usageCount      Int                 @default(0)
  lastUsedAt      DateTime?
  
  notes           String?
  
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@unique([primaryItemId, substituteItemId])
  @@index([primaryItemId])
  @@index([substituteItemId])
  @@index([isActive])
}

// Transaction type for inventory movements
enum InventoryTransactionType {
  RECEIPT              // Goods received
  ISSUE                // Issued to production
  ADJUSTMENT_IN        // Positive adjustment
  ADJUSTMENT_OUT       // Negative adjustment
  TRANSFER             // Location transfer
  RETURN_TO_VENDOR     // Returned to supplier
  RETURN_FROM_CUSTOMER // Customer return
  SCRAP                // Written off as scrap
  CYCLE_COUNT          // Cycle count adjustment
  PHYSICAL_COUNT       // Physical inventory adjustment
  CONSUMPTION          // Used in production
  RESERVE              // Reserved for order
  UNRESERVE            // Released reservation
}

// Inventory transaction for full movement history
model InventoryTransaction {
  id              String              @id @default(uuid())
  organizationId  String?
  locationId      String?
  
  // Item
  itemMasterId    String
  
  // Transaction details
  transactionType InventoryTransactionType
  transactionDate DateTime            @default(now())
  
  // Quantities
  quantity        Float               // Positive or negative based on type
  quantityBefore  Float?              // Stock level before
  quantityAfter   Float?              // Stock level after
  unitCost        Decimal?            @db.Decimal(10, 4)
  totalValue      Decimal?            @db.Decimal(12, 2)
  
  // Reference
  referenceType   String?             // 'PO', 'WorkOrder', 'Adjustment', etc.
  referenceId     String?
  referenceNumber String?             // Display number
  
  // For transfers
  fromLocationId  String?
  toLocationId    String?
  
  // Lot/Batch tracking
  lotNumber       String?
  batchNumber     String?
  expirationDate  DateTime?
  serialNumbers   String[]
  
  // Quality
  inspectionRequired Boolean          @default(false)
  inspectionStatus String?            // 'PENDING', 'PASSED', 'FAILED'
  inspectedById   String?
  inspectedAt     DateTime?
  
  // Reason/Notes
  reasonCode      String?
  notes           String?
  
  // Attribution
  createdById     String?
  createdAt       DateTime            @default(now())
  
  @@index([itemMasterId])
  @@index([transactionType])
  @@index([transactionDate])
  @@index([referenceType, referenceId])
  @@index([lotNumber])
  @@index([organizationId])
  @@index([locationId])
}

// Inventory reservation for order allocation
model InventoryReservation {
  id              String              @id @default(uuid())
  organizationId  String?
  locationId      String?
  
  // Item
  itemMasterId    String
  
  // Reservation details
  workOrderId     String?
  quoteId         String?
  lineItemId      String?
  
  quantity        Float
  reservedAt      DateTime            @default(now())
  expiresAt       DateTime?
  
  // Status
  status          ReservationStatus   @default(ACTIVE)
  consumedQuantity Float              @default(0)
  releasedAt      DateTime?
  releasedById    String?
  releaseReason   String?
  
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([itemMasterId])
  @@index([workOrderId])
  @@index([status])
  @@index([expiresAt])
}

// Reservation status
enum ReservationStatus {
  ACTIVE
  PARTIALLY_CONSUMED
  FULLY_CONSUMED
  RELEASED
  EXPIRED
}

// ============================================================================
// CRITICAL-08: QUALITY MANAGEMENT SYSTEM
// ============================================================================

// C08-A: Quality Standard - acceptance criteria for products/materials
model QualityStandard {
  id              String              @id @default(uuid())
  
  // Identification
  code            String              @unique
  name            String
  description     String?
  version         String              @default("1.0")
  
  // Scope
  standardType    QualityStandardType
  category        String?             // e.g., "Dimensional", "Visual", "Functional"
  applicableTo    String?             // Product type, material, or process
  
  // Criteria
  criteria        Json                // Array of acceptance criteria with tolerances
  // Example: [{ name: "Width Tolerance", min: -0.5, max: 0.5, unit: "mm" }]
  
  // Sampling
  samplingMethod  SamplingMethod      @default(RANDOM)
  sampleSize      Int?                // Required sample size
  aqlLevel        Float?              // Acceptable Quality Level (%)
  
  // Status
  status          StandardStatus      @default(DRAFT)
  effectiveDate   DateTime?
  expiryDate      DateTime?
  
  // Traceability
  referenceStandards String[]         // ISO, ASTM, etc.
  
  createdById     String?
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  inspectionCheckpoints InspectionCheckpoint[]
  qualityMetrics        QualityMetric[]

  @@index([standardType])
  @@index([status])
  @@index([category])
}

enum QualityStandardType {
  INCOMING_MATERIAL
  IN_PROCESS
  FINAL_PRODUCT
  PACKAGING
  SHIPPING
}

enum SamplingMethod {
  RANDOM
  SYSTEMATIC
  STRATIFIED
  ONE_HUNDRED_PERCENT
  SKIP_LOT
}

enum StandardStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  SUPERSEDED
  RETIRED
}

// C08-B: Inspection Checkpoint - in-process QC points
model InspectionCheckpoint {
  id              String              @id @default(uuid())
  
  // Links
  workOrderId     String?
  workOrder       WorkOrder?          @relation("WorkOrderInspections", fields: [workOrderId], references: [id], onDelete: Cascade)
  standardId      String?
  standard        QualityStandard?    @relation(fields: [standardId], references: [id])
  stationId       String?
  
  // Identification
  checkpointType  CheckpointType
  sequenceNumber  Int                 // Order in inspection workflow
  name            String
  
  // Timing
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  
  // Inspector
  inspectorId     String?
  inspector       User?               @relation("InspectionsByUser", fields: [inspectorId], references: [id])
  
  // Results
  result          InspectionResult    @default(PENDING)
  measurements    Json?               // Actual measured values
  // Example: [{ criterion: "Width", value: 24.3, unit: "inches", passed: true }]
  passedCount     Int                 @default(0)
  failedCount     Int                 @default(0)
  totalChecked    Int                 @default(0)
  
  // Evidence
  notes           String?
  photoUrls       String[]
  
  // Decisions
  disposition     InspectionDisposition?
  dispositionNote String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  nonConformances NonConformanceReport[]

  @@index([workOrderId])
  @@index([standardId])
  @@index([result])
  @@index([scheduledAt])
}

enum CheckpointType {
  RECEIVING
  FIRST_ARTICLE
  IN_PROCESS
  FINAL
  SHIPPING
  CUSTOMER_RETURN
}

enum InspectionResult {
  PENDING
  PASSED
  FAILED
  CONDITIONAL_PASS
  NOT_APPLICABLE
}

enum InspectionDisposition {
  ACCEPT
  REJECT
  REWORK
  USE_AS_IS
  SCRAP
  RETURN_TO_VENDOR
}

// C08-C: Non-Conformance Report (NCR) - defect tracking
model NonConformanceReport {
  id              String              @id @default(uuid())
  
  // Identification
  ncrNumber       String              @unique
  title           String
  description     String
  
  // Links
  workOrderId     String?
  workOrder       WorkOrder?          @relation("WorkOrderNCRs", fields: [workOrderId], references: [id])
  inspectionId    String?
  inspection      InspectionCheckpoint? @relation(fields: [inspectionId], references: [id])
  customerId      String?
  
  // Classification
  category        NCRCategory
  severity        NCRSeverity         @default(MINOR)
  source          NCRSource
  
  // Defect details
  defectType      String?             // e.g., "Color mismatch", "Dimension out of spec"
  defectLocation  String?             // Where on the product
  quantityAffected Int                @default(1)
  lotNumber       String?
  
  // Cost impact
  estimatedCost   Decimal?            @db.Decimal(12, 2)
  actualCost      Decimal?            @db.Decimal(12, 2)
  costCategory    String?             // Scrap, Rework, Return, etc.
  
  // Status workflow
  status          NCRStatus           @default(OPEN)
  disposition     NCRDisposition?
  dispositionNote String?
  
  // Personnel
  reportedById    String
  reportedBy      User                @relation("NCRReportedBy", fields: [reportedById], references: [id])
  assignedToId    String?
  assignedTo      User?               @relation("NCRAssignedTo", fields: [assignedToId], references: [id])
  approvedById    String?
  approvedAt      DateTime?
  closedById      String?
  closedAt        DateTime?
  
  // Root cause
  rootCauseCategory String?           // e.g., "Operator Error", "Machine", "Material"
  rootCauseDetail   String?
  
  // Evidence
  photoUrls       String[]
  documentUrls    String[]
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  correctiveActions CorrectiveAction[]

  @@index([workOrderId])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([reportedById])
  @@index([assignedToId])
}

enum NCRCategory {
  MATERIAL
  PROCESS
  EQUIPMENT
  DESIGN
  VENDOR
  CUSTOMER_COMPLAINT
  SHIPPING
  OTHER
}

enum NCRSeverity {
  CRITICAL      // Safety hazard or complete failure
  MAJOR         // Significant impact on function
  MINOR         // Cosmetic or minor deviation
  OBSERVATION   // Noted for improvement
}

enum NCRSource {
  INCOMING_INSPECTION
  IN_PROCESS
  FINAL_INSPECTION
  CUSTOMER_RETURN
  CUSTOMER_COMPLAINT
  INTERNAL_AUDIT
  EXTERNAL_AUDIT
}

enum NCRStatus {
  OPEN
  UNDER_INVESTIGATION
  PENDING_DISPOSITION
  IN_CORRECTIVE_ACTION
  PENDING_VERIFICATION
  CLOSED
  VOID
}

enum NCRDisposition {
  USE_AS_IS
  REWORK
  REPAIR
  SCRAP
  RETURN_TO_VENDOR
  REJECT
  CONCESSION
}

// C08-D: Corrective Action - issue resolution workflow
model CorrectiveAction {
  id              String              @id @default(uuid())
  
  // Identification
  carNumber       String              @unique  // Corrective Action Report number
  title           String
  
  // Link to NCR
  ncrId           String?
  ncr             NonConformanceReport? @relation(fields: [ncrId], references: [id])
  
  // Type
  actionType      CorrectiveActionType
  priority        CorrectiveActionPriority @default(MEDIUM)
  
  // Problem statement
  problemStatement    String
  immediateAction     String?              // Containment
  immediateActionDate DateTime?
  
  // Root cause analysis
  rootCauseMethod     RootCauseMethod?     // 5-Why, Fishbone, etc.
  rootCauseAnalysis   String?
  rootCauseCategory   String?
  
  // Corrective action
  correctiveAction    String?
  plannedCompletionDate DateTime?
  actualCompletionDate  DateTime?
  
  // Preventive action
  preventiveAction    String?
  preventiveActionDate DateTime?
  
  // Verification
  verificationMethod  String?
  verificationResult  String?
  verifiedAt          DateTime?
  verifiedById        String?
  verifiedBy          User?               @relation("CAVerifiedBy", fields: [verifiedById], references: [id])
  
  // Effectiveness
  effectivenessReviewDate DateTime?
  effectivenessResult     EffectivenessResult?
  effectivenessNotes      String?
  
  // Status
  status          CAStatus            @default(OPEN)
  
  // Personnel
  assignedToId    String?
  assignedTo      User?               @relation("CAAssignedTo", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User                @relation("CACreatedBy", fields: [createdById], references: [id])
  approvedById    String?
  approvedAt      DateTime?
  closedById      String?
  closedAt        DateTime?
  
  // Cost tracking
  implementationCost Decimal?         @db.Decimal(12, 2)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([ncrId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([plannedCompletionDate])
}

enum CorrectiveActionType {
  CORRECTION        // Fix the immediate issue
  CORRECTIVE        // Eliminate root cause
  PREVENTIVE        // Prevent recurrence
  IMPROVEMENT       // Continuous improvement
}

enum CorrectiveActionPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum RootCauseMethod {
  FIVE_WHY
  FISHBONE
  FMEA
  FAULT_TREE
  PARETO
  OTHER
}

enum CAStatus {
  OPEN
  ROOT_CAUSE_ANALYSIS
  PLANNING
  IMPLEMENTATION
  VERIFICATION
  EFFECTIVENESS_REVIEW
  CLOSED
  CANCELLED
}

enum EffectivenessResult {
  EFFECTIVE
  PARTIALLY_EFFECTIVE
  NOT_EFFECTIVE
  PENDING
}

// C08-E: Quality Metric - trend analysis and SPC
model QualityMetric {
  id              String              @id @default(uuid())
  
  // Identification
  metricCode      String              @unique
  name            String
  description     String?
  
  // Scope
  standardId      String?
  standard        QualityStandard?    @relation(fields: [standardId], references: [id])
  stationId       String?             // If station-specific
  category        String?             // Grouping category
  
  // Measurement definition
  measurementType QualityMeasurementType
  unit            String?
  targetValue     Float?
  lowerLimit      Float?              // Lower control limit
  upperLimit      Float?              // Upper control limit
  lowerSpec       Float?              // Lower spec limit
  upperSpec       Float?              // Upper spec limit
  
  // Calculation settings
  sampleSize      Int                 @default(1)
  calculationMethod String?           // Average, median, etc.
  
  // SPC settings
  enableSPC       Boolean             @default(false)
  chartType       SPCChartType?
  
  // Status
  isActive        Boolean             @default(true)
  
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  observations    QualityObservation[]

  @@index([standardId])
  @@index([stationId])
  @@index([isActive])
}

// Individual quality observations/measurements
model QualityObservation {
  id              String              @id @default(uuid())
  
  metricId        String
  metric          QualityMetric       @relation(fields: [metricId], references: [id], onDelete: Cascade)
  
  // Context
  workOrderId     String?
  lotNumber       String?
  sampleNumber    Int?
  
  // Measurement
  value           Float
  timestamp       DateTime            @default(now())
  
  // Analysis
  inControl       Boolean             @default(true)   // Within control limits
  inSpec          Boolean             @default(true)   // Within spec limits
  alertTriggered  Boolean             @default(false)
  alertType       String?             // Type of alert if triggered
  
  // Inspector
  recordedById    String?
  notes           String?
  
  createdAt       DateTime            @default(now())

  @@index([metricId])
  @@index([workOrderId])
  @@index([timestamp])
  @@index([inControl])
}

enum QualityMeasurementType {
  CONTINUOUS      // Measurements (length, weight)
  ATTRIBUTE       // Pass/fail counts
  DEFECTS         // Number of defects per unit
  PERCENTAGE      // Percentage values
}

enum SPCChartType {
  X_BAR_R         // Average and Range
  X_BAR_S         // Average and Std Dev
  I_MR            // Individual and Moving Range
  P_CHART         // Proportion defective
  NP_CHART        // Number defective
  C_CHART         // Defects per unit
  U_CHART         // Defects per unit (variable sample)
}

// ============================================================================
// CRITICAL-09: DOCUMENT MANAGEMENT SYSTEM
// ============================================================================

// C09-A: Document Version - version control for documents
model DocumentVersion {
  id              String              @id @default(uuid())
  
  // Link to parent document
  documentId      String
  document        Document            @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  
  // Version info
  versionNumber   Int
  majorVersion    Int                 @default(1)
  minorVersion    Int                 @default(0)
  versionLabel    String?             // e.g., "Draft", "Final", "Rev A"
  
  // File info
  fileName        String
  fileUrl         String
  fileSize        Int                 // Bytes
  mimeType        String
  checksum        String?             // MD5/SHA for integrity
  
  // Changes
  changeNotes     String?
  changedFields   String[]            // List of changed sections/fields
  
  // Status
  status          DocumentVersionStatus @default(DRAFT)
  isCurrentVersion Boolean            @default(false)
  
  // Created by
  createdById     String
  createdBy       User                @relation("DocumentVersionCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime            @default(now())
  
  // Approval tracking
  approvals       DocumentApproval[]

  @@unique([documentId, versionNumber])
  @@index([documentId])
  @@index([status])
  @@index([isCurrentVersion])
}

enum DocumentVersionStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUPERSEDED
  ARCHIVED
}

// C09-B: Document Template - reusable document templates
model DocumentTemplate {
  id              String              @id @default(uuid())
  
  // Identification
  code            String              @unique
  name            String
  description     String?
  
  // Classification
  category        DocumentCategory
  subcategory     String?
  
  // Template content
  templateType    TemplateType
  templateUrl     String?             // URL to template file
  templateContent String?             // JSON/HTML template content
  placeholders    Json?               // List of placeholder variables
  // Example: [{ name: "customerName", type: "text", required: true }]
  
  // Output settings
  outputFormat    String              @default("pdf")  // pdf, docx, etc.
  paperSize       String              @default("letter")
  orientation     String              @default("portrait")
  
  // Usage
  usageCount      Int                 @default(0)
  lastUsedAt      DateTime?
  
  // Status
  isActive        Boolean             @default(true)
  isDefault       Boolean             @default(false)  // Default for category
  
  createdById     String?
  createdBy       User?               @relation("TemplateCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([category])
  @@index([isActive])
}

enum TemplateType {
  FORM              // Fillable form
  REPORT            // Report template
  LETTER            // Letter/correspondence
  CERTIFICATE       // Certificate of conformance, etc.
  LABEL             // Labels/tags
  CHECKLIST         // Inspection checklist
  CONTRACT          // Contract template
  INVOICE           // Invoice template
  QUOTE             // Quote template
  WORK_INSTRUCTION  // SOPs, work instructions
  OTHER
}

// C09-C: Document Approval - review workflow
model DocumentApproval {
  id              String              @id @default(uuid())
  
  // Links
  documentVersionId String
  documentVersion   DocumentVersion   @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  
  // Workflow
  approvalLevel   Int                 @default(1)  // 1, 2, 3... for multi-level
  approvalType    ApprovalType        @default(REVIEW)
  
  // Approver
  approverId      String
  approver        User                @relation("DocumentApprover", fields: [approverId], references: [id])
  
  // Status
  status          ApprovalStatus      @default(PENDING)
  
  // Decision
  decision        ApprovalDecision?
  comments        String?
  decidedAt       DateTime?
  
  // Deadlines
  dueDate         DateTime?
  reminderSentAt  DateTime?
  
  // Delegation
  delegatedToId   String?
  delegatedTo     User?               @relation("ApprovalDelegatedTo", fields: [delegatedToId], references: [id])
  delegatedAt     DateTime?
  delegationReason String?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([documentVersionId, approverId, approvalLevel])
  @@index([documentVersionId])
  @@index([approverId])
  @@index([status])
  @@index([dueDate])
}

enum ApprovalType {
  REVIEW            // General review
  TECHNICAL         // Technical review
  QUALITY           // Quality approval
  MANAGEMENT        // Management approval
  CUSTOMER          // Customer approval
  LEGAL             // Legal review
  FINAL             // Final sign-off
}

enum ApprovalStatus {
  PENDING
  IN_REVIEW
  COMPLETED
  SKIPPED
  DELEGATED
  EXPIRED
}

enum ApprovalDecision {
  APPROVED
  APPROVED_WITH_COMMENTS
  REJECTED
  NEEDS_REVISION
  DEFERRED
}

// C09-D: Document Tag - tagging system for documents
model DocumentTag {
  id              String              @id @default(uuid())
  
  // Tag info
  name            String              @unique
  slug            String              @unique
  description     String?
  color           String?             // Hex color for UI
  
  // Hierarchy
  parentId        String?
  parent          DocumentTag?        @relation("TagHierarchy", fields: [parentId], references: [id])
  children        DocumentTag[]       @relation("TagHierarchy")
  
  // Usage
  usageCount      Int                 @default(0)
  
  createdById     String?
  createdAt       DateTime            @default(now())

  // Relations
  documents       DocumentTagAssignment[]

  @@index([parentId])
}

// Junction table for Document-Tag many-to-many
model DocumentTagAssignment {
  id              String              @id @default(uuid())
  
  documentId      String
  document        Document            @relation("DocumentTags", fields: [documentId], references: [id], onDelete: Cascade)
  
  tagId           String
  tag             DocumentTag         @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  assignedById    String?
  assignedAt      DateTime            @default(now())

  @@unique([documentId, tagId])
  @@index([documentId])
  @@index([tagId])
}

// C09-E: Document Access - permission management
model DocumentAccess {
  id              String              @id @default(uuid())
  
  // Target document (or folder in future)
  documentId      String
  document        Document            @relation("DocumentAccessRules", fields: [documentId], references: [id], onDelete: Cascade)
  
  // Grantee (user or role)
  accessType      DocumentAccessType
  userId          String?
  user            User?               @relation("DocumentAccessUser", fields: [userId], references: [id], onDelete: Cascade)
  role            UserRole?           // Grant to role
  
  // Permissions
  canView         Boolean             @default(true)
  canDownload     Boolean             @default(true)
  canEdit         Boolean             @default(false)
  canDelete       Boolean             @default(false)
  canShare        Boolean             @default(false)
  canApprove      Boolean             @default(false)
  
  // Validity
  validFrom       DateTime            @default(now())
  validUntil      DateTime?
  
  // Audit
  grantedById     String?
  grantedBy       User?               @relation("DocumentAccessGrantedBy", fields: [grantedById], references: [id])
  grantedAt       DateTime            @default(now())
  revokedAt       DateTime?
  revokedById     String?

  @@unique([documentId, userId])
  @@index([documentId])
  @@index([userId])
  @@index([role])
}

enum DocumentAccessType {
  USER              // Specific user
  ROLE              // Role-based
  DEPARTMENT        // Department-based (future)
  PUBLIC            // Public access
  CUSTOMER          // Customer portal access
}

// Document download/access log
model DocumentAccessLog {
  id              String              @id @default(uuid())
  
  documentId      String
  document        Document            @relation("DocumentAccessLogs", fields: [documentId], references: [id], onDelete: Cascade)
  versionId       String?
  
  // Access info
  accessType      DocumentAccessAction
  userId          String?
  user            User?               @relation("DocumentAccessLogUser", fields: [userId], references: [id])
  
  // Context
  ipAddress       String?
  userAgent       String?
  
  // Result
  success         Boolean             @default(true)
  failureReason   String?
  
  accessedAt      DateTime            @default(now())

  @@index([documentId])
  @@index([userId])
  @@index([accessedAt])
}

enum DocumentAccessAction {
  VIEW
  DOWNLOAD
  PRINT
  SHARE
  EDIT
  DELETE
  VERSION_UPLOAD
}

// ============================================================================
// CRITICAL-10: PERFORMANCE & ANALYTICS FOUNDATION
// ============================================================================

// C10-A: Daily Metric Snapshot - pre-calculated KPIs
model DailyMetricSnapshot {
  id              String              @id @default(uuid())
  
  // Date of metrics
  date            DateTime            @db.Date
  
  // Scope
  metricType      MetricSnapshotType
  scopeType       MetricScopeType
  scopeId         String?             // Station ID, User ID, etc.
  
  // Order metrics
  ordersReceived      Int             @default(0)
  ordersCompleted     Int             @default(0)
  ordersShipped       Int             @default(0)
  ordersCancelled     Int             @default(0)
  ordersOnHold        Int             @default(0)
  ordersInProgress    Int             @default(0)
  orderBacklog        Int             @default(0)
  
  // Financial metrics
  revenueTotal        Decimal         @default(0) @db.Decimal(14, 2)
  revenueCompleted    Decimal         @default(0) @db.Decimal(14, 2)
  costTotal           Decimal         @default(0) @db.Decimal(14, 2)
  profitMargin        Float?
  
  // Production metrics
  unitsProduced       Int             @default(0)
  sqftProduced        Float           @default(0)
  hoursWorked         Float           @default(0)
  productiveHours     Float           @default(0)
  
  // Efficiency metrics
  utilization         Float?          // Percentage
  efficiency          Float?          // Actual vs standard
  firstPassYield      Float?          // Quality metric
  
  // Lead time metrics (in hours)
  avgLeadTime         Float?
  minLeadTime         Float?
  maxLeadTime         Float?
  p50LeadTime         Float?          // Median
  p90LeadTime         Float?          // 90th percentile
  
  // Customer metrics
  newCustomers        Int             @default(0)
  repeatOrders        Int             @default(0)
  customerComplaints  Int             @default(0)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([date, metricType, scopeType, scopeId])
  @@index([date])
  @@index([metricType])
  @@index([scopeType, scopeId])
}

enum MetricSnapshotType {
  OVERALL           // Company-wide
  STATION           // Per station
  USER              // Per operator
  CUSTOMER          // Per customer
  PRODUCT_LINE      // Per product category
}

enum MetricScopeType {
  GLOBAL            // No specific scope
  STATION           // Station-level
  USER              // User-level
  CUSTOMER          // Customer-level
  DEPARTMENT        // Department-level
}

// C10-B: Station Throughput - production rate tracking
model StationThroughput {
  id              String              @id @default(uuid())
  
  // Station identification
  stationId       String              // PrintingMethod enum value
  date            DateTime            @db.Date
  periodType      ThroughputPeriod    @default(HOURLY)
  periodStart     DateTime
  periodEnd       DateTime
  
  // Volume metrics
  ordersCompleted     Int             @default(0)
  itemsCompleted      Int             @default(0)
  unitsCompleted      Int             @default(0)
  sqftCompleted       Float           @default(0)
  
  // Time metrics
  availableMinutes    Int             @default(0)
  productiveMinutes   Int             @default(0)
  downtimeMinutes     Int             @default(0)
  setupMinutes        Int             @default(0)
  
  // Rate metrics
  throughputRate      Float?          // Units per hour
  cycleTime           Float?          // Avg minutes per unit
  
  // Quality
  defectCount         Int             @default(0)
  reworkCount         Int             @default(0)
  scrapCount          Int             @default(0)
  
  // Queue
  queueSizeStart      Int             @default(0)
  queueSizeEnd        Int             @default(0)
  avgQueueSize        Float?
  
  createdAt       DateTime            @default(now())

  @@unique([stationId, periodStart, periodType])
  @@index([stationId])
  @@index([date])
  @@index([periodType])
}

enum ThroughputPeriod {
  HOURLY
  SHIFT
  DAILY
  WEEKLY
}

// C10-C: Lead Time History - trend analysis
model LeadTimeHistory {
  id              String              @id @default(uuid())
  
  // Work order reference
  workOrderId     String              @unique
  workOrder       WorkOrder           @relation("WorkOrderLeadTime", fields: [workOrderId], references: [id], onDelete: Cascade)
  
  // Timestamps
  orderReceivedAt     DateTime
  orderCompletedAt    DateTime?
  orderShippedAt      DateTime?
  
  // Lead times (in hours)
  totalLeadTime       Float?          // Received to shipped
  productionLeadTime  Float?          // First station to last station
  shippingLeadTime    Float?          // Completed to shipped
  
  // Station breakdowns
  stationTimes        Json?           // { stationId: { start, end, duration } }
  
  // Queue times (waiting)
  totalQueueTime      Float?
  stationQueueTimes   Json?           // { stationId: queueMinutes }
  
  // Classification
  orderType           String?         // Rush, standard, etc.
  complexity          String?         // Simple, medium, complex
  
  // Comparison to estimates
  estimatedLeadTime   Float?
  variance            Float?          // Actual - estimated
  variancePercent     Float?
  
  createdAt       DateTime            @default(now())

  @@index([workOrderId])
  @@index([orderReceivedAt])
  @@index([orderCompletedAt])
}

// C10-D: Bottleneck Event - capacity constraint logging
model BottleneckEvent {
  id              String              @id @default(uuid())
  
  // When
  detectedAt      DateTime            @default(now())
  resolvedAt      DateTime?
  
  // Where
  stationId       String              // PrintingMethod
  resourceType    BottleneckResource
  resourceId      String?             // Equipment ID, user ID, etc.
  
  // What
  bottleneckType  BottleneckType
  severity        BottleneckSeverity
  
  // Metrics
  queueDepth          Int             @default(0)  // Jobs waiting
  waitTimeMinutes     Float           @default(0)
  affectedOrderCount  Int             @default(0)
  
  // Thresholds
  thresholdExceeded   Float?          // What threshold triggered
  currentValue        Float?          // Current metric value
  
  // Impact
  estimatedDelay      Float?          // Additional hours
  revenueAtRisk       Decimal?        @db.Decimal(12, 2)
  
  // Resolution
  resolutionType      BottleneckResolution?
  resolutionNotes     String?
  
  // Detection
  detectionMethod     String?         // Auto, manual, scheduled
  autoDetected        Boolean         @default(true)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([stationId])
  @@index([detectedAt])
  @@index([severity])
  @@index([resolvedAt])
}

enum BottleneckResource {
  EQUIPMENT         // Printer, cutter, etc.
  LABOR             // Operator availability
  MATERIAL          // Material shortage
  SPACE             // Physical space constraint
  TOOLING           // Tools, dies, etc.
}

enum BottleneckType {
  CAPACITY          // Max capacity reached
  EQUIPMENT_DOWN    // Equipment not working
  STAFF_SHORTAGE    // Not enough operators
  MATERIAL_OUT      // Material stockout
  QUALITY_HOLD      // QC holding up work
  DEPENDENCY        // Waiting on upstream
  EXTERNAL          // Customer delay, vendor, etc.
}

enum BottleneckSeverity {
  CRITICAL          // Production stopped
  HIGH              // Significant delay
  MEDIUM            // Moderate impact
  LOW               // Minor inconvenience
}

enum BottleneckResolution {
  CLEARED           // Natural resolution
  OVERTIME          // Added overtime
  RESEQUENCED       // Changed priorities
  OUTSOURCED        // Sent to subcontractor
  ESCALATED         // Escalated to management
  EQUIPMENT_FIXED   // Repaired equipment
  MATERIAL_RECEIVED // Received materials
  OTHER
}

// C10-E: User Productivity - operator performance metrics
model UserProductivity {
  id              String              @id @default(uuid())
  
  // User and period
  userId          String
  user            User                @relation("UserProductivityMetrics", fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime            @db.Date
  periodType      ProductivityPeriod  @default(DAILY)
  
  // Time metrics
  scheduledHours      Float           @default(0)
  clockedHours        Float           @default(0)
  productiveHours     Float           @default(0)
  indirectHours       Float           @default(0)  // Meetings, training, etc.
  breakHours          Float           @default(0)
  
  // Output metrics
  ordersWorked        Int             @default(0)
  ordersCompleted     Int             @default(0)
  itemsCompleted      Int             @default(0)
  unitsCompleted      Int             @default(0)
  sqftCompleted       Float           @default(0)
  
  // Efficiency metrics
  productivity        Float?          // Output / hours
  efficiency          Float?          // Actual vs standard time
  utilization         Float?          // Productive / clocked
  
  // Quality metrics
  defectsCreated      Int             @default(0)
  reworkRequired      Int             @default(0)
  firstPassYield      Float?
  
  // Comparison
  peerAvgProductivity Float?
  rankInTeam          Int?
  rankPercentile      Float?
  
  // Station breakdown
  stationBreakdown    Json?           // { stationId: { hours, units } }
  
  createdAt       DateTime            @default(now())

  @@unique([userId, date, periodType])
  @@index([userId])
  @@index([date])
  @@index([periodType])
}

enum ProductivityPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

// Analytics goal tracking
model PerformanceGoal {
  id              String              @id @default(uuid())
  
  // Goal identification
  name            String
  description     String?
  
  // Scope
  goalType        GoalType
  scopeType       MetricScopeType
  scopeId         String?
  
  // Metric
  metricName      String              // e.g., "throughputRate", "firstPassYield"
  metricUnit      String?             // e.g., "units/hour", "%"
  
  // Target
  targetValue     Float
  targetDirection GoalDirection       // Higher is better or lower is better
  
  // Timeframe
  periodType      GoalPeriod
  startDate       DateTime
  endDate         DateTime
  
  // Progress
  currentValue    Float?
  lastUpdatedAt   DateTime?
  progressPercent Float?
  status          GoalStatus          @default(ON_TRACK)
  
  // Thresholds
  warningThreshold Float?             // Yellow zone
  criticalThreshold Float?            // Red zone
  
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([goalType])
  @@index([scopeType, scopeId])
  @@index([status])
}

enum GoalType {
  PRODUCTIVITY
  QUALITY
  EFFICIENCY
  REVENUE
  CUSTOMER_SATISFACTION
  SAFETY
  DELIVERY
}

enum GoalDirection {
  HIGHER          // Higher is better
  LOWER           // Lower is better
  TARGET          // Closest to target
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum GoalStatus {
  NOT_STARTED
  ON_TRACK
  AT_RISK
  BEHIND
  ACHIEVED
  MISSED
}

// ============================================================================
// SSS-019: ADVANCED QUALITY ASSURANCE SYSTEM
// Comprehensive QC with evidence capture, defect categorization, root cause
// analysis, supplier quality scoring, and customer feedback loop
// ============================================================================

// ============ Defect Categorization ============

enum DefectSeverity {
  COSMETIC         // Visual only, no functionality impact
  MINOR            // Minor impact, can be used with notes
  MAJOR            // Significant impact, may need rework
  CRITICAL         // Cannot be used/shipped, must be fixed
  SAFETY           // Safety hazard, immediate action required
}

enum DefectDisposition {
  PENDING          // Awaiting decision
  USE_AS_IS        // Accept with deviation
  REWORK           // Repair/fix the defect
  SCRAP            // Cannot be salvaged
  RETURN_TO_VENDOR // Supplier issue
  DOWNGRADE        // Use for lesser purpose
}

enum DefectSource {
  INCOMING         // Incoming inspection (materials)
  IN_PROCESS       // Found during production
  FINAL_QC         // Final inspection before shipping
  CUSTOMER         // Customer complaint/return
  INTERNAL_AUDIT   // Internal quality audit
  EQUIPMENT        // Equipment-caused defect
}

enum EvidenceType {
  PHOTO            // Image evidence
  VIDEO            // Video evidence
  DOCUMENT         // Document/PDF
  MEASUREMENT      // Measurement data
  TEST_RESULT      // Test results
  CUSTOMER_REPORT  // Customer complaint
  AUDIO            // Audio recording
}

enum RootCauseCategory {
  OPERATOR_ERROR   // Human error
  EQUIPMENT        // Machine/equipment failure
  MATERIAL         // Material defect
  PROCESS          // Process issue
  DESIGN           // Design flaw
  ENVIRONMENTAL    // Temperature, humidity, etc.
  MAINTENANCE      // Maintenance-related
  TRAINING         // Training deficiency
  VENDOR           // Supplier issue
  UNKNOWN          // Under investigation
}

enum SupplierQualityTier {
  PREFERRED        // Excellent quality history
  APPROVED         // Meets quality standards
  CONDITIONAL      // On probation/watch
  RESTRICTED       // Limited use only
  BLOCKED          // Quality issues, cannot use
}

enum FeedbackType {
  COMPLIMENT       // Positive feedback
  COMPLAINT        // Quality issue
  SUGGESTION       // Improvement idea
  WARRANTY_CLAIM   // Warranty-related
  RETURN           // Return request
  QUESTION         // Quality question
}

enum FeedbackStatus {
  RECEIVED         // Just received
  ACKNOWLEDGED     // Customer contacted
  INVESTIGATING    // Under investigation
  RESOLVED         // Issue resolved
  CLOSED           // Feedback closed
  ESCALATED        // Escalated to management
}

enum QualityTrendType {
  FIRST_PASS_YIELD // Percentage passing on first try
  DEFECT_RATE      // Defects per 100 units
  CUSTOMER_RETURNS // Return rate
  REWORK_RATE      // Rework percentage
  SCRAP_RATE       // Scrap percentage
  INSPECTION_TIME  // Average inspection time
  ESCAPE_RATE      // Defects that reach customer
}

model DefectCategory {
  id             String           @id @default(uuid())
  name           String           @unique
  description    String?
  parentId       String?          // For hierarchical categories
  parent         DefectCategory?  @relation("DefectHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       DefectCategory[] @relation("DefectHierarchy")
  
  // Classification
  isActive       Boolean          @default(true)
  sortOrder      Int              @default(0)
  
  // Default severity for this category
  defaultSeverity DefectSeverity?
  
  // Applicable stations/methods
  applicableStations PrintingMethod[]  @default([])
  
  // Standard rework time for this defect type
  standardReworkMinutes Int?
  
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  defects        Defect[]

  @@index([parentId])
  @@index([isActive])
}

model Defect {
  id             String            @id @default(uuid())
  
  // What was defective
  workOrderId    String
  workOrder      WorkOrder         @relation("WorkOrderDefects", fields: [workOrderId], references: [id], onDelete: Cascade)
  inspectionId   String?
  inspection     QCInspection?     @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  
  // Categorization
  categoryId     String
  category       DefectCategory    @relation(fields: [categoryId], references: [id])
  severity       DefectSeverity    @default(MINOR)
  source         DefectSource      @default(IN_PROCESS)
  
  // Details
  description    String
  location       String?           // Where on the product
  quantity       Int               @default(1)
  
  // Disposition
  disposition    DefectDisposition @default(PENDING)
  dispositionById String?
  dispositionBy  User?             @relation("DefectDisposedBy", fields: [dispositionById], references: [id])
  dispositionAt  DateTime?
  dispositionNotes String?
  
  // Costs
  laborCostImpact   Decimal?       @db.Decimal(10, 2)
  materialCostImpact Decimal?      @db.Decimal(10, 2)
  
  // Discovery
  discoveredById String
  discoveredBy   User              @relation("DefectDiscoveredBy", fields: [discoveredById], references: [id])
  discoveredAt   DateTime          @default(now())
  station        PrintingMethod?
  
  // Root cause (if analyzed)
  rootCauseId    String?
  rootCause      RootCauseAnalysis? @relation(fields: [rootCauseId], references: [id], onDelete: SetNull)
  
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  evidence       QCEvidence[]

  @@index([workOrderId])
  @@index([categoryId])
  @@index([severity])
  @@index([disposition])
  @@index([discoveredAt])
}

model QCEvidence {
  id             String        @id @default(uuid())
  
  // Link to defect or inspection
  defectId       String?
  defect         Defect?       @relation(fields: [defectId], references: [id], onDelete: Cascade)
  inspectionResultId String?
  inspectionResult QCInspectionResult? @relation(fields: [inspectionResultId], references: [id], onDelete: Cascade)
  
  // Evidence details
  type           EvidenceType  @default(PHOTO)
  fileUrl        String        // URL to file storage
  fileName       String
  fileSize       Int?          // Bytes
  mimeType       String?
  
  // Metadata
  caption        String?
  takenAt        DateTime?     // When evidence was captured
  takenById      String?
  takenBy        User?         @relation("EvidenceTakenBy", fields: [takenById], references: [id])
  
  // Location data (for photos)
  gpsLatitude    Float?
  gpsLongitude   Float?
  
  // Equipment used for capture
  deviceInfo     String?       // Camera/device model
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([defectId])
  @@index([inspectionResultId])
  @@index([type])
}

model RootCauseAnalysis {
  id             String             @id @default(uuid())
  
  // What triggered the analysis
  title          String
  description    String?
  
  // Classification
  category       RootCauseCategory  @default(UNKNOWN)
  
  // 5 Whys methodology
  why1           String?
  why2           String?
  why3           String?
  why4           String?
  why5           String?
  
  // Fishbone/Ishikawa categories
  manContributor    String?        // Man/People factors
  machineContributor String?       // Machine factors
  materialContributor String?      // Material factors
  methodContributor   String?      // Method/Process factors
  measurementContributor String?   // Measurement factors
  environmentContributor String?   // Environment factors
  
  // Root cause determination
  rootCauseStatement String?
  
  // Analysis metadata
  analyzedById   String?
  analyzedBy     User?             @relation("RootCauseAnalyst", fields: [analyzedById], references: [id])
  analyzedAt     DateTime?
  
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  defects        Defect[]

  @@index([category])
  @@index([analyzedAt])
}

model SupplierQualityScore {
  id             String              @id @default(uuid())
  
  // Supplier reference (assumes Vendor model exists)
  vendorId       String?             // Link to vendor if available
  supplierName   String              // Fallback if no vendor link
  
  // Current quality tier
  tier           SupplierQualityTier @default(APPROVED)
  
  // Metrics (0-100 scale)
  qualityScore   Float               @default(100) // Overall quality
  deliveryScore  Float               @default(100) // On-time delivery
  responseScore  Float               @default(100) // Communication/response
  
  // Defect history
  totalLots      Int                 @default(0)   // Total lots received
  rejectedLots   Int                 @default(0)   // Lots rejected
  defectCount    Int                 @default(0)   // Total defects found
  
  // PPM (Parts Per Million defective)
  currentPPM     Float?
  
  // Audit info
  lastAuditDate  DateTime?
  lastAuditScore Float?
  nextAuditDue   DateTime?
  
  // Notes
  notes          String?
  
  updatedAt      DateTime            @updatedAt
  createdAt      DateTime            @default(now())

  qualityEvents  SupplierQualityEvent[]

  @@unique([vendorId])
  @@index([tier])
  @@index([qualityScore])
}

model SupplierQualityEvent {
  id             String              @id @default(uuid())
  scoreId        String
  score          SupplierQualityScore @relation(fields: [scoreId], references: [id], onDelete: Cascade)
  
  // Event details
  eventDate      DateTime            @default(now())
  eventType      String              // INCOMING_DEFECT, LATE_DELIVERY, AUDIT, etc.
  description    String?
  
  // Impact on scores
  qualityImpact  Float?              // Points deducted/added
  deliveryImpact Float?
  responseImpact Float?
  
  // Reference
  defectId       String?             // If related to a defect
  purchaseOrderNumber String?        // Related PO if any
  
  recordedById   String?
  createdAt      DateTime            @default(now())

  @@index([scoreId])
  @@index([eventDate])
}

model CustomerFeedback {
  id             String          @id @default(uuid())
  
  // Customer reference
  customerId     String?
  customer       Customer?       @relation("CustomerQualityFeedback", fields: [customerId], references: [id], onDelete: SetNull)
  
  // Related order
  workOrderId    String?
  workOrder      WorkOrder?      @relation("WorkOrderFeedback", fields: [workOrderId], references: [id], onDelete: SetNull)
  
  // Feedback details
  type           FeedbackType    @default(COMPLAINT)
  subject        String
  description    String?
  status         FeedbackStatus  @default(RECEIVED)
  
  // Source
  sourceChannel  String?         // Email, Phone, Portal, In-Person
  receivedAt     DateTime        @default(now())
  receivedById   String?
  receivedBy     User?           @relation("FeedbackReceivedBy", fields: [receivedById], references: [id])
  
  // Rating (1-5 scale)
  overallRating  Int?            // @db.SmallInt range 1-5
  qualityRating  Int?
  serviceRating  Int?
  
  // Resolution
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?           @relation("FeedbackResolvedBy", fields: [resolvedById], references: [id])
  resolution     String?
  
  // Cost of quality
  creditIssued   Decimal?        @db.Decimal(10, 2)
  refundIssued   Decimal?        @db.Decimal(10, 2)
  
  // Defect linkage (if quality complaint)
  linkedDefectId String?
  
  // Tags
  tags           String[]        @default([])
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([customerId])
  @@index([workOrderId])
  @@index([type])
  @@index([status])
  @@index([receivedAt])
}

model QualityTrend {
  id             String           @id @default(uuid())
  
  // Trend identification
  trendType      QualityTrendType
  periodStart    DateTime
  periodEnd      DateTime
  
  // Scope
  station        PrintingMethod?  // null = all stations
  productType    String?          // Product category
  customerId     String?          // Specific customer
  
  // Metric values
  metricValue    Float            // The actual metric
  targetValue    Float?           // Target for this metric
  previousValue  Float?           // Previous period value
  
  // Trend direction
  changePercent  Float?           // % change from previous
  isImproving    Boolean?         // True if trending positive
  
  // Sample size
  sampleSize     Int              // Number of items in calculation
  
  // Statistical data
  standardDeviation Float?
  upperControlLimit Float?
  lowerControlLimit Float?
  
  // Alerts
  isOutOfControl Boolean          @default(false) // Outside control limits
  requiresAction Boolean          @default(false) // Needs attention
  
  notes          String?
  calculatedAt   DateTime         @default(now())

  @@index([trendType])
  @@index([periodStart, periodEnd])
  @@index([station])
  @@index([isOutOfControl])
}

model QualityObjective {
  id             String           @id @default(uuid())
  
  // Objective details
  name           String
  description    String?
  
  // Metric
  metricType     QualityTrendType
  targetValue    Float
  currentValue   Float?
  
  // Timeframe
  startDate      DateTime
  endDate        DateTime
  
  // Scope
  station        PrintingMethod?  // null = all stations
  
  // Status
  progressPercent Float?          @default(0)
  status         GoalStatus       @default(NOT_STARTED)
  
  // Owner
  ownerId        String?
  
  // Review
  lastReviewDate DateTime?
  nextReviewDate DateTime?
  
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([metricType])
  @@index([status])
  @@index([isActive])
}

// ============================================================================
// NEW-CRITICAL-01: PROJECT MANAGEMENT & JOB COSTING TEMPLATES
// Enables bundling related work orders, project tracking, milestones,
// job templates for repeatable configurations, and budget management
// ============================================================================

enum ProjectStatus {
  PLANNING        // Initial planning phase
  APPROVED        // Budget approved, ready to start
  IN_PROGRESS     // Active work in progress
  ON_HOLD         // Temporarily paused
  COMPLETED       // All work finished
  CANCELLED       // Project cancelled
  ARCHIVED        // Archived for records
}

enum ProjectPriority {
  CRITICAL        // Highest priority, immediate attention
  HIGH            // High priority
  MEDIUM          // Normal priority
  LOW             // Low priority, as time permits
}

enum MilestoneStatus {
  NOT_STARTED     // Milestone not yet begun
  IN_PROGRESS     // Milestone work underway
  COMPLETED       // Milestone achieved
  OVERDUE         // Past due date
  SKIPPED         // Milestone skipped/not applicable
}

enum BudgetLineType {
  MATERIAL        // Material costs
  LABOR           // Labor costs
  EQUIPMENT       // Equipment/machine time
  SUBCONTRACT     // Subcontractor costs
  SHIPPING        // Shipping/freight costs
  OVERHEAD        // Overhead allocation
  OTHER           // Miscellaneous costs
}

enum BudgetStatus {
  DRAFT           // Budget not finalized
  APPROVED        // Budget approved
  OVER_BUDGET     // Exceeded approved amount
  UNDER_BUDGET    // Under approved amount
  CLOSED          // Budget closed out
}

enum TemplateCategory {
  SIGNAGE         // Standard signage templates
  VEHICLE_WRAP    // Vehicle wrap templates
  BANNER          // Banner templates
  DISPLAY         // Display/trade show templates
  WAYFINDING      // Wayfinding system templates
  CHANNEL_LETTER  // Channel letter templates
  MONUMENT        // Monument sign templates
  CUSTOM          // Custom/other templates
}

// ============ Project Model ============

model Project {
  id              String          @id @default(uuid())
  projectNumber   String          @unique
  name            String
  description     String?
  
  // Company (new) - will replace customerId
  companyId       String?
  company         Company?        @relation("CompanyProjects", fields: [companyId], references: [id])
  
  // Customer (legacy - being deprecated)
  customerId      String?
  customer        Customer?       @relation(fields: [customerId], references: [id])
  
  // Status & Priority
  status          ProjectStatus   @default(PLANNING)
  priority        ProjectPriority @default(MEDIUM)
  
  // Timeline
  startDate       DateTime?
  targetEndDate   DateTime?
  actualEndDate   DateTime?
  
  // Budget summary (calculated from budget lines)
  estimatedBudget Decimal?        @db.Decimal(12, 2)
  approvedBudget  Decimal?        @db.Decimal(12, 2)
  actualCost      Decimal?        @db.Decimal(12, 2)
  
  // Project manager
  managerId       String?
  manager         User?           @relation("ProjectManager", fields: [managerId], references: [id])
  
  // Tags for categorization
  tags            String[]        @default([])
  
  // Metadata
  createdById     String
  createdBy       User            @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  workOrders      ProjectWorkOrder[]
  milestones      ProjectMilestone[]
  budgetLines     BudgetLine[]
  notes           ProjectNote[]
  attachments     ProjectAttachment[]

  // ============ Performance Indexes ============
  @@index([customerId])
  @@index([status])
  @@index([priority])
  @@index([managerId])
  @@index([startDate])
  @@index([status, priority])                          // Project dashboard
  @@index([status, targetEndDate])                     // Deadline tracking
  @@index([managerId, status])                         // PM dashboard
  @@index([customerId, status])                        // Customer project view
}

// ============ Project-WorkOrder Junction ============

model ProjectWorkOrder {
  id            String     @id @default(uuid())
  projectId     String
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workOrderId   String
  workOrder     WorkOrder  @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  // Ordering within project
  sortOrder     Int        @default(0)
  
  // Phase/group within project
  phase         String?
  
  createdAt     DateTime   @default(now())

  @@unique([projectId, workOrderId])
  @@index([projectId])
  @@index([workOrderId])
}

// ============ Project Milestones ============

model ProjectMilestone {
  id              String          @id @default(uuid())
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  name            String
  description     String?
  
  // Status & dates
  status          MilestoneStatus @default(NOT_STARTED)
  dueDate         DateTime?
  completedDate   DateTime?
  
  // Completion criteria
  completionCriteria String?
  
  // Dependencies (milestone IDs that must complete first)
  dependsOn       String[]        @default([])
  
  // Ordering
  sortOrder       Int             @default(0)
  
  // Assignment
  assignedToId    String?
  assignedTo      User?           @relation("MilestoneAssignee", fields: [assignedToId], references: [id])
  
  // Percentage complete (0-100)
  percentComplete Int             @default(0)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

// ============ Budget Lines ============

model BudgetLine {
  id              String          @id @default(uuid())
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Categorization
  lineType        BudgetLineType
  description     String
  
  // Amounts
  estimatedAmount Decimal         @db.Decimal(12, 2)
  approvedAmount  Decimal?        @db.Decimal(12, 2)
  actualAmount    Decimal?        @db.Decimal(12, 2)
  
  // Status
  status          BudgetStatus    @default(DRAFT)
  
  // Reference (e.g., PO number, invoice number)
  reference       String?
  
  // Notes
  notes           String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([projectId])
  @@index([lineType])
  @@index([status])
}

// ============ Project Notes ============

model ProjectNote {
  id            String    @id @default(uuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Note content
  content       String
  
  // Visibility
  isInternal    Boolean   @default(true)  // false = visible to customer
  isPinned      Boolean   @default(false)
  
  // Author
  authorId      String
  author        User      @relation("ProjectNoteAuthor", fields: [authorId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
  @@index([isPinned])
}

// ============ Project Attachments ============

model ProjectAttachment {
  id            String    @id @default(uuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  fileName      String
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  
  // Categorization
  category      String?   // "contract", "artwork", "photo", "document", etc.
  description   String?
  
  uploadedById  String
  uploadedBy    User      @relation("ProjectAttachmentUploader", fields: [uploadedById], references: [id])
  uploadedAt    DateTime  @default(now())

  @@index([projectId])
  @@index([category])
}

// ============ Job Templates ============

model JobTemplate {
  id              String            @id @default(uuid())
  name            String            @unique
  description     String?
  
  // Category
  category        TemplateCategory  @default(CUSTOM)
  
  // Template configuration (stored as JSON)
  // Includes: default routing, line items, materials, labor estimates
  configuration   Json
  
  // Pricing
  basePrice       Decimal?          @db.Decimal(12, 2)
  estimatedHours  Decimal?          @db.Decimal(8, 2)
  
  // Default routing
  defaultRouting  PrintingMethod[]  @default([])
  
  // Tags
  tags            String[]          @default([])
  
  // Status
  isActive        Boolean           @default(true)
  
  // Usage tracking
  timesUsed       Int               @default(0)
  lastUsedAt      DateTime?
  
  // Author
  createdById     String
  createdBy       User              @relation("TemplateCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Template items (pre-defined line items)
  templateItems   TemplateLineItem[]

  @@index([category])
  @@index([isActive])
}

// ============ Template Line Items ============

model TemplateLineItem {
  id            String       @id @default(uuid())
  templateId    String
  template      JobTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  // Item details
  description   String
  quantity      Decimal      @db.Decimal(10, 2)
  unit          String?      // sqft, linear ft, each, etc.
  
  // Pricing
  unitPrice     Decimal?     @db.Decimal(10, 2)
  
  // Material reference (if applicable)
  materialSku   String?
  
  // Ordering
  sortOrder     Int          @default(0)
  
  // Optional/required
  isOptional    Boolean      @default(false)
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([templateId])
}

// ============================================================================
// NEW-CRITICAL-02: MATERIAL NESTING & WASTE OPTIMIZATION
// ============================================================================

// Nesting status enum
enum NestingStatus {
  DRAFT           // Being created
  PENDING         // Waiting to be nested
  PROCESSING      // Nesting algorithm running
  COMPLETED       // Nesting done
  APPROVED        // Approved for cutting
  IN_PRODUCTION   // Currently being cut
  FINISHED        // All cuts complete
  CANCELLED       // Cancelled
}

// Cut status for individual items
enum CutStatus {
  PENDING         // Not yet cut
  IN_PROGRESS     // Currently cutting
  COMPLETED       // Cut finished
  FAILED          // Cut failed
  SKIPPED         // Skipped/not needed
}

// Waste category
enum WasteCategory {
  USABLE_REMNANT  // Large enough to reuse
  EDGE_TRIM       // Edge waste, recyclable
  SCRAP           // Too small to reuse
  DEFECTIVE       // Material defect
  SETUP_WASTE     // Calibration/setup cuts
}

// Material sheet/panel status
enum SheetStatus {
  AVAILABLE       // Ready to use
  RESERVED        // Reserved for a job
  IN_USE          // Currently being cut
  DEPLETED        // Fully used
  DAMAGED         // Damaged, cannot use
}

// ============ Material Sheet/Panel Inventory ============

model MaterialSheet {
  id              String        @id @default(uuid())
  
  // Material reference
  materialId      String?       // Link to InventoryItem
  materialSku     String
  materialName    String
  
  // Sheet dimensions (in inches)
  width           Decimal       @db.Decimal(10, 3)
  height          Decimal       @db.Decimal(10, 3)
  thickness       Decimal?      @db.Decimal(6, 3)
  
  // Area tracking
  totalAreaSqIn   Decimal       @db.Decimal(12, 3)
  usedAreaSqIn    Decimal       @db.Decimal(12, 3)  @default(0)
  remainingAreaSqIn Decimal     @db.Decimal(12, 3)
  utilizationPct  Decimal       @db.Decimal(5, 2)   @default(0)
  
  // Status
  status          SheetStatus   @default(AVAILABLE)
  
  // Source tracking
  poNumber        String?       // Purchase order reference
  lotNumber       String?       // Batch/lot tracking
  receivedAt      DateTime?
  
  // Cost
  unitCost        Decimal?      @db.Decimal(10, 2)
  
  // Location
  warehouseLocation String?
  binNumber       String?
  
  // Quality
  gradeRating     String?       // A, B, C grade
  hasDefects      Boolean       @default(false)
  defectNotes     String?
  
  // Remnant tracking
  isRemnant       Boolean       @default(false)
  parentSheetId   String?
  parentSheet     MaterialSheet? @relation("SheetRemnants", fields: [parentSheetId], references: [id])
  remnants        MaterialSheet[] @relation("SheetRemnants")
  
  // Nesting relationships
  nestPlacements  NestPlacement[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([materialSku])
  @@index([status])
  @@index([isRemnant])
}

// ============ Nesting Job ============

model NestingJob {
  id              String        @id @default(uuid())
  jobNumber       String        @unique
  name            String
  description     String?
  
  // Status
  status          NestingStatus @default(DRAFT)
  
  // Material constraints
  materialSku     String?       // Limit to specific material
  maxSheetWidth   Decimal?      @db.Decimal(10, 3)
  maxSheetHeight  Decimal?      @db.Decimal(10, 3)
  
  // Nesting parameters
  itemSpacing     Decimal       @db.Decimal(6, 3)   @default(0.25) // Gap between items
  edgeMargin      Decimal       @db.Decimal(6, 3)   @default(0.5)  // Edge margin
  allowRotation   Boolean       @default(true)
  prioritizeByDueDate Boolean   @default(true)
  
  // Results summary
  totalItems      Int           @default(0)
  nestedItems     Int           @default(0)
  sheetsUsed      Int           @default(0)
  totalMaterialArea Decimal?    @db.Decimal(12, 3)
  totalUsedArea   Decimal?      @db.Decimal(12, 3)
  overallUtilization Decimal?   @db.Decimal(5, 2)
  
  // Waste tracking
  totalWasteArea  Decimal?      @db.Decimal(12, 3)
  wasteCost       Decimal?      @db.Decimal(10, 2)
  
  // Timing
  startedAt       DateTime?
  completedAt     DateTime?
  processingTimeMs Int?
  
  // Assignment
  createdById     String
  createdBy       User          @relation("NestingJobCreator", fields: [createdById], references: [id])
  approvedById    String?
  approvedBy      User?         @relation("NestingJobApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  
  // Relations
  items           NestItem[]
  placements      NestPlacement[]
  wasteRecords    WasteRecord[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([materialSku])
}

// ============ Items to be Nested ============

model NestItem {
  id              String        @id @default(uuid())
  nestingJobId    String
  nestingJob      NestingJob    @relation(fields: [nestingJobId], references: [id], onDelete: Cascade)
  
  // Work order reference
  workOrderId     String?
  lineItemId      String?
  
  // Item details
  itemName        String
  quantity        Int           @default(1)
  
  // Dimensions (in inches)
  width           Decimal       @db.Decimal(10, 3)
  height          Decimal       @db.Decimal(10, 3)
  areaSqIn        Decimal       @db.Decimal(12, 3)
  
  // Constraints
  canRotate       Boolean       @default(true)
  grainDirection  String?       // "horizontal", "vertical", "none"
  
  // Priority
  priority        Int           @default(5) // 1=highest, 10=lowest
  dueDate         DateTime?
  
  // Status
  nestedCount     Int           @default(0) // How many have been placed
  cutCount        Int           @default(0) // How many have been cut
  
  // Placements
  placements      NestPlacement[]
  
  createdAt       DateTime      @default(now())

  @@index([nestingJobId])
  @@index([workOrderId])
}

// ============ Nest Placements (where items go on sheets) ============

model NestPlacement {
  id              String        @id @default(uuid())
  nestingJobId    String
  nestingJob      NestingJob    @relation(fields: [nestingJobId], references: [id], onDelete: Cascade)
  
  // Sheet reference
  sheetId         String
  sheet           MaterialSheet @relation(fields: [sheetId], references: [id])
  
  // Item reference
  nestItemId      String
  nestItem        NestItem      @relation(fields: [nestItemId], references: [id], onDelete: Cascade)
  
  // Position on sheet (in inches from bottom-left)
  positionX       Decimal       @db.Decimal(10, 3)
  positionY       Decimal       @db.Decimal(10, 3)
  
  // Orientation
  isRotated       Boolean       @default(false)
  rotationDegrees Int           @default(0)
  
  // Cut status
  cutStatus       CutStatus     @default(PENDING)
  cutStartedAt    DateTime?
  cutCompletedAt  DateTime?
  
  // Quality check
  passedQC        Boolean?
  qcNotes         String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([nestingJobId])
  @@index([sheetId])
  @@index([cutStatus])
}

// ============ Waste/Scrap Tracking ============

model WasteRecord {
  id              String        @id @default(uuid())
  
  // Source
  nestingJobId    String?
  nestingJob      NestingJob?   @relation(fields: [nestingJobId], references: [id])
  workOrderId     String?
  
  // Material
  materialSku     String
  materialName    String
  
  // Dimensions
  width           Decimal?      @db.Decimal(10, 3)
  height          Decimal?      @db.Decimal(10, 3)
  areaSqIn        Decimal       @db.Decimal(12, 3)
  weight          Decimal?      @db.Decimal(10, 3) // in lbs
  
  // Category
  category        WasteCategory
  
  // Value
  estimatedCost   Decimal?      @db.Decimal(10, 2)
  
  // Disposition
  isRecyclable    Boolean       @default(false)
  wasRecycled     Boolean       @default(false)
  recycledAt      DateTime?
  recycleValue    Decimal?      @db.Decimal(10, 2)
  
  // Notes
  reason          String?
  notes           String?
  
  // Tracking
  recordedById    String
  recordedBy      User          @relation("WasteRecorder", fields: [recordedById], references: [id])
  recordedAt      DateTime      @default(now())

  @@index([nestingJobId])
  @@index([category])
  @@index([materialSku])
  @@index([recordedAt])
}

// ============ Material Utilization Metrics ============

model MaterialUtilizationSnapshot {
  id              String        @id @default(uuid())
  
  // Period
  periodStart     DateTime
  periodEnd       DateTime
  periodType      String        // "daily", "weekly", "monthly"
  
  // Material (null = all materials)
  materialSku     String?
  materialName    String?
  
  // Usage metrics
  totalMaterialUsed   Decimal   @db.Decimal(12, 3)  // sq in
  totalWasteGenerated Decimal   @db.Decimal(12, 3)  // sq in
  utilizationRate     Decimal   @db.Decimal(5, 2)   // percentage
  
  // Cost metrics
  materialCost        Decimal?  @db.Decimal(12, 2)
  wasteCost           Decimal?  @db.Decimal(12, 2)
  recycleRevenue      Decimal?  @db.Decimal(10, 2)
  netMaterialCost     Decimal?  @db.Decimal(12, 2)
  
  // Counts
  sheetsUsed          Int       @default(0)
  nestingJobsCompleted Int      @default(0)
  itemsNested         Int       @default(0)
  
  // Remnant metrics
  remnantsCreated     Int       @default(0)
  remnantsUsed        Int       @default(0)
  
  // Comparison to previous period
  utilizationChange   Decimal?  @db.Decimal(5, 2)   // +/- percentage
  wasteChange         Decimal?  @db.Decimal(5, 2)
  
  createdAt           DateTime  @default(now())

  @@unique([periodStart, periodEnd, materialSku])
  @@index([periodType])
  @@index([materialSku])
}

// ============ Nesting Algorithm Configuration ============

model NestingConfig {
  id              String        @id @default(uuid())
  name            String        @unique
  description     String?
  
  // Algorithm settings
  algorithmType   String        @default("bottom-left")  // "bottom-left", "best-fit", "genetic"
  maxIterations   Int           @default(1000)
  timeoutMs       Int           @default(30000)
  
  // Spacing defaults
  defaultItemSpacing  Decimal   @db.Decimal(6, 3)   @default(0.25)
  defaultEdgeMargin   Decimal   @db.Decimal(6, 3)   @default(0.5)
  
  // Optimization goals (weights 0-100)
  utilizationWeight   Int       @default(70)
  cutPathWeight       Int       @default(20)  // Minimize cut distance
  setupTimeWeight     Int       @default(10)  // Minimize sheet changes
  
  // Remnant handling
  minRemnantSize      Decimal   @db.Decimal(10, 3)  @default(36)  // sq in minimum to save
  preferRemnants      Boolean   @default(true)  // Use remnants before new sheets
  
  // Active/default
  isDefault           Boolean   @default(false)
  isActive            Boolean   @default(true)
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([isDefault])
}

// ============================================================================
// NEW-CRITICAL-03: ADVANCED NOTIFICATION & COMMUNICATION HUB
// ============================================================================

// Notification channel type
enum NotificationChannel {
  IN_APP        // In-application notification
  EMAIL         // Email delivery
  SMS           // SMS text message
  PUSH          // Push notification
  SLACK         // Slack integration
  TEAMS         // Microsoft Teams
  WEBHOOK       // Custom webhook
}

// Notification priority
enum NotificationPriority {
  LOW           // Can wait, batch delivery OK
  NORMAL        // Standard delivery
  HIGH          // Deliver promptly
  URGENT        // Immediate delivery required
}

// Notification status
enum NotificationDeliveryStatus {
  PENDING       // Queued for delivery
  SENDING       // Currently being sent
  DELIVERED     // Successfully delivered
  FAILED        // Delivery failed
  BOUNCED       // Email bounced
  READ          // User has read it
  DISMISSED     // User dismissed without reading
}

// Message thread status
enum ThreadStatus {
  OPEN          // Active conversation
  RESOLVED      // Issue resolved
  ARCHIVED      // Archived for records
}

// Announcement target scope
enum AnnouncementScope {
  ALL           // All users
  ROLE          // Specific roles
  DEPARTMENT    // Specific departments
  USER          // Specific users
  CUSTOMER      // Customer portal users
}

// ============ Notification Template ============

model NotificationTemplate {
  id              String              @id @default(uuid())
  code            String              @unique  // e.g., "ORDER_CREATED", "PROOF_APPROVED"
  name            String
  description     String?
  
  // Template content (supports variables like {{orderNumber}})
  subjectTemplate String?             // For email
  bodyTemplate    String              // Main message body
  htmlTemplate    String?             // Rich HTML version
  
  // Channels this template supports
  channels        NotificationChannel[]
  
  // Default settings
  defaultPriority NotificationPriority @default(NORMAL)
  
  // Categorization
  category        String?             // "orders", "proofs", "shipping", "system"
  
  // Variables available in this template
  variables       String[]            @default([])
  
  // Active flag
  isActive        Boolean             @default(true)
  isSystem        Boolean             @default(false) // System templates can't be deleted
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([code])
  @@index([category])
}

// ============ User Notification Preferences ============

model NotificationPreference {
  id              String              @id @default(uuid())
  userId          String
  user            User                @relation("NotificationPreferences", fields: [userId], references: [id], onDelete: Cascade)
  
  // Template/category this preference applies to
  templateCode    String?             // Specific template, or null for category-wide
  category        String?             // Category-wide preference
  
  // Channel preferences
  enabledChannels NotificationChannel[]
  disabledChannels NotificationChannel[]
  
  // Delivery preferences
  emailEnabled    Boolean             @default(true)
  smsEnabled      Boolean             @default(false)
  pushEnabled     Boolean             @default(true)
  inAppEnabled    Boolean             @default(true)
  
  // Quiet hours (don't disturb)
  quietHoursStart String?             // "22:00" format
  quietHoursEnd   String?             // "07:00" format
  timezone        String?             @default("America/Chicago")
  
  // Digest preferences
  digestEnabled   Boolean             @default(false)
  digestFrequency String?             // "daily", "weekly"
  digestTime      String?             // "09:00"
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([userId, templateCode])
  @@index([userId])
}

// ============ Notification Queue ============

model NotificationQueue {
  id              String                    @id @default(uuid())
  
  // Recipient
  userId          String?
  user            User?                     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  recipientEmail  String?                   // For non-user recipients
  recipientPhone  String?                   // For SMS
  recipientName   String?
  
  // Template reference
  templateCode    String?
  
  // Content
  subject         String?
  body            String
  htmlBody        String?
  
  // Delivery
  channel         NotificationChannel
  priority        NotificationPriority      @default(NORMAL)
  status          NotificationDeliveryStatus @default(PENDING)
  
  // Related entity
  entityType      String?                   // "WorkOrder", "Quote", "Proof", etc.
  entityId        String?
  
  // Scheduling
  scheduledFor    DateTime?                 // null = send immediately
  sentAt          DateTime?
  deliveredAt     DateTime?
  readAt          DateTime?
  
  // Error tracking
  attempts        Int                       @default(0)
  lastError       String?
  nextRetryAt     DateTime?
  
  // Metadata
  metadata        Json?                     // Additional data for templates
  
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@index([userId, status])
  @@index([channel, status])
  @@index([scheduledFor])
  @@index([status])
}

// ============ Internal Messaging ============

model MessageThread {
  id              String              @id @default(uuid())
  subject         String
  
  // Thread type
  entityType      String?             // "WorkOrder", "Quote", "Customer", etc.
  entityId        String?
  
  // Status
  status          ThreadStatus        @default(OPEN)
  
  // Participants
  createdById     String
  createdBy       User                @relation("ThreadCreator", fields: [createdById], references: [id])
  
  // Messages
  messages        Message[]
  participants    ThreadParticipant[]
  
  // Last activity
  lastMessageAt   DateTime?
  messageCount    Int                 @default(0)
  
  // Flags
  isPinned        Boolean             @default(false)
  isUrgent        Boolean             @default(false)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([entityType, entityId])
  @@index([status])
  @@index([lastMessageAt])
}

// ============ Thread Participants ============

model ThreadParticipant {
  id              String              @id @default(uuid())
  threadId        String
  thread          MessageThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User                @relation("ThreadParticipant", fields: [userId], references: [id], onDelete: Cascade)
  
  // Read tracking
  lastReadAt      DateTime?
  unreadCount     Int                 @default(0)
  
  // Notifications
  notifyOnReply   Boolean             @default(true)
  isMuted         Boolean             @default(false)
  
  // Permissions
  canReply        Boolean             @default(true)
  isAdmin         Boolean             @default(false)  // Can add/remove participants
  
  joinedAt        DateTime            @default(now())
  leftAt          DateTime?

  @@unique([threadId, userId])
  @@index([userId])
}

// ============ Messages ============

model Message {
  id              String              @id @default(uuid())
  threadId        String
  thread          MessageThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  
  // Author
  authorId        String
  author          User                @relation("MessageAuthor", fields: [authorId], references: [id])
  
  // Content
  content         String
  contentType     String              @default("text")  // "text", "html", "markdown"
  
  // Attachments
  attachments     MessageAttachment[]
  
  // Reply to
  replyToId       String?
  replyTo         Message?            @relation("MessageReplies", fields: [replyToId], references: [id])
  replies         Message[]           @relation("MessageReplies")
  
  // Flags
  isEdited        Boolean             @default(false)
  editedAt        DateTime?
  isDeleted       Boolean             @default(false)
  deletedAt       DateTime?
  
  // Reactions (stored as JSON: { "👍": ["userId1", "userId2"] })
  reactions       Json?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([threadId])
  @@index([authorId])
}

// ============ Message Attachments ============

model MessageAttachment {
  id              String              @id @default(uuid())
  messageId       String
  message         Message             @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  fileName        String
  fileUrl         String
  fileSize        Int?
  mimeType        String?
  
  uploadedAt      DateTime            @default(now())

  @@index([messageId])
}

// ============ Announcements ============

model Announcement {
  id              String              @id @default(uuid())
  title           String
  content         String
  contentType     String              @default("text")  // "text", "html", "markdown"
  
  // Targeting
  scope           AnnouncementScope   @default(ALL)
  targetRoles     UserRole[]          @default([])
  targetUserIds   String[]            @default([])
  
  // Scheduling
  startsAt        DateTime            @default(now())
  expiresAt       DateTime?
  
  // Display settings
  priority        NotificationPriority @default(NORMAL)
  isPinned        Boolean             @default(false)
  requiresAck     Boolean             @default(false)  // Requires acknowledgment
  
  // Styling
  bannerColor     String?             // For banner display
  icon            String?
  
  // Author
  createdById     String
  createdBy       User                @relation("AnnouncementAuthor", fields: [createdById], references: [id])
  
  // Stats
  viewCount       Int                 @default(0)
  ackCount        Int                 @default(0)
  
  // Status
  isActive        Boolean             @default(true)
  isDraft         Boolean             @default(false)
  
  // Acknowledgments
  acknowledgments AnnouncementAck[]
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([scope])
  @@index([startsAt, expiresAt])
  @@index([isActive])
}

// ============ Announcement Acknowledgments ============

model AnnouncementAck {
  id              String              @id @default(uuid())
  announcementId  String
  announcement    Announcement        @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User                @relation("AnnouncementAcks", fields: [userId], references: [id], onDelete: Cascade)
  
  acknowledgedAt  DateTime            @default(now())

  @@unique([announcementId, userId])
  @@index([userId])
}

// ============ Communication Log (external) ============

model CommunicationLog {
  id              String              @id @default(uuid())
  
  // Related entity
  entityType      String              // "Customer", "Vendor", "WorkOrder"
  entityId        String
  
  // Communication details
  channel         String              // "email", "phone", "in_person", "meeting"
  direction       String              // "inbound", "outbound"
  subject         String?
  summary         String
  details         String?
  
  // Participants
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  
  // Internal user
  userId          String
  user            User                @relation("CommunicationLogger", fields: [userId], references: [id])
  
  // Timing
  occurredAt      DateTime            @default(now())
  duration        Int?                // Minutes
  
  // Follow-up
  requiresFollowUp Boolean            @default(false)
  followUpDate    DateTime?
  followUpNotes   String?
  followUpCompleted Boolean           @default(false)
  followUpCompletedAt DateTime?
  
  // Attachments stored as JSON array
  attachments     Json?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([entityType, entityId])
  @@index([userId])
  @@index([occurredAt])
  @@index([requiresFollowUp, followUpCompleted])
}

// ============================================================================
// NEW-CRITICAL-04: EQUIPMENT CALIBRATION & CERTIFICATION EXTENSIONS
// ============================================================================

// Calibration records for equipment (extends existing Equipment model)
model Calibration {
  id                String            @id @default(uuid())
  
  equipmentId       String
  equipment         Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  // Calibration details
  calibrationType   CalibrationType
  calibrationDate   DateTime
  dueDate           DateTime
  
  // Performer
  performedBy       String?           // Internal user or external
  performedByUserId String?
  performedByUser   User?             @relation("CalibrationPerformer", fields: [performedByUserId], references: [id])
  
  // External calibration
  externalCompany   String?
  externalTechName  String?
  certificateNumber String?
  
  // Results
  result            CalibrationResult
  tolerancesMet     Boolean           @default(true)
  adjustmentsMade   Boolean           @default(false)
  adjustmentNotes   String?
  
  // Measurements stored as JSON
  measurements      Json?             // Before/after readings
  
  // Reference standards used
  standardsUsed     String?
  traceability      String?           // Traceability chain
  
  // Environmental conditions
  temperature       Decimal?          @db.Decimal(5, 2)
  humidity          Decimal?          @db.Decimal(5, 2)
  
  // Documentation
  certificateUrl    String?
  reportUrl         String?
  
  // Cost tracking
  cost              Decimal?          @db.Decimal(10, 2)
  
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  @@index([equipmentId])
  @@index([calibrationDate])
  @@index([dueDate])
  @@index([result])
}

// Calibration type
enum CalibrationType {
  INITIAL
  PERIODIC
  AFTER_REPAIR
  AFTER_MOVE
  VERIFICATION
  ADJUSTMENT
}

// Calibration result
enum CalibrationResult {
  PASS
  PASS_WITH_ADJUSTMENT
  FAIL
  CONDITIONAL
  DEFERRED
}

// Equipment certifications and compliance
model EquipmentCertification {
  id                String              @id @default(uuid())
  
  equipmentId       String
  equipment         Equipment           @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  // Certification details
  certificationType CertificationType
  certificationName String
  issuingAuthority  String
  
  // Validity
  issueDate         DateTime
  expirationDate    DateTime?
  
  // Status
  status            CertificationStatus @default(VALID)
  
  // Documentation
  certificateNumber String?
  certificateUrl    String?
  
  // Compliance
  complianceStandard String?            // "ISO 9001", "OSHA", etc.
  requirements       String?
  
  // Renewal tracking
  renewalReminder   Int?                // Days before expiry
  renewalCost       Decimal?            @db.Decimal(10, 2)
  lastRenewalDate   DateTime?
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([equipmentId])
  @@index([expirationDate])
  @@index([status])
}

// Certification types
enum CertificationType {
  SAFETY
  QUALITY
  ENVIRONMENTAL
  CALIBRATION_CERT
  OPERATOR
  WARRANTY
  INSURANCE
  REGULATORY
}

// Certification status
enum CertificationStatus {
  VALID
  EXPIRING_SOON
  EXPIRED
  SUSPENDED
  REVOKED
  PENDING_RENEWAL
}

// Equipment parts inventory
model EquipmentPart {
  id                String            @id @default(uuid())
  
  equipmentId       String
  equipment         Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  // Part details
  partNumber        String
  name              String
  description       String?
  
  // Classification
  category          String?
  isConsumable      Boolean           @default(false)
  isCritical        Boolean           @default(false)
  
  // Inventory
  quantityOnHand    Int               @default(0)
  minimumQuantity   Int               @default(1)
  reorderPoint      Int               @default(1)
  
  // Pricing
  unitCost          Decimal?          @db.Decimal(10, 2)
  vendor            String?
  vendorPartNumber  String?
  
  // Lifespan
  expectedLifeHours Int?
  replacementInterval Int?            // Days
  
  // Last replaced
  lastReplacedAt    DateTime?
  
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  @@unique([equipmentId, partNumber])
  @@index([equipmentId])
  @@index([isCritical])
}

// Equipment meters (usage tracking)
model EquipmentMeter {
  id                String            @id @default(uuid())
  
  equipmentId       String
  equipment         Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  
  // Meter details
  name              String            // "Runtime Hours", "Ink Usage", "Cuts"
  unit              String            // "hours", "liters", "count"
  
  // Current reading
  currentReading    Decimal           @db.Decimal(15, 4)
  lastReadingDate   DateTime          @default(now())
  
  // Maintenance triggers
  maintenanceThreshold Decimal?       @db.Decimal(15, 4)  // Trigger maintenance at this value
  calibrationThreshold Decimal?       @db.Decimal(15, 4)  // Trigger calibration
  
  // Tracking
  readingHistory    Json?             // Array of { date, reading }
  
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  @@unique([equipmentId, name])
  @@index([equipmentId])
}

// ============================================================================
// NEW-CRITICAL-05: ADVANCED USER TRAINING & COMPETENCY
// ============================================================================

// Training programs/courses
model TrainingProgram {
  id                String              @id @default(uuid())
  
  // Program details
  code              String              @unique
  name              String
  description       String?
  
  // Classification
  category          TrainingCategory
  level             TrainingLevel       @default(BEGINNER)
  
  // Content
  objectives        String?             // Learning objectives
  curriculum        Json?               // Modules/topics as JSON array
  duration          Int?                // Estimated hours to complete
  
  // Requirements
  prerequisites     String?             // Required prior training
  equipmentRequired String?             // Equipment needed for training
  stationsApplicable PrintingMethod[]   // Which stations this applies to
  
  // Delivery
  deliveryMethod    TrainingDeliveryMethod @default(IN_PERSON)
  materials         Json?               // Links to training materials
  
  // Certification
  certificationRequired Boolean         @default(false)
  certificationValidDays Int?           // How long certification is valid
  recertificationRequired Boolean       @default(false)
  
  // Status
  isActive          Boolean             @default(true)
  version           String?             // Content version
  
  createdById       String?
  createdBy         User?               @relation("TrainingProgramCreator", fields: [createdById], references: [id])
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  sessions          TrainingSession[]
  userCompetencies  UserCompetency[]
  
  @@index([category])
  @@index([isActive])
}

// Training category
enum TrainingCategory {
  EQUIPMENT_OPERATION
  SAFETY
  QUALITY_CONTROL
  SOFTWARE_SYSTEMS
  CUSTOMER_SERVICE
  PRODUCTION_PROCESS
  MAINTENANCE
  LEADERSHIP
  COMPLIANCE
  GENERAL
}

// Training level
enum TrainingLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
  CERTIFICATION
}

// Training delivery method
enum TrainingDeliveryMethod {
  IN_PERSON
  ONLINE
  HYBRID
  SELF_PACED
  ON_THE_JOB
  MENTORSHIP
}

// Training sessions (scheduled or completed training events)
model TrainingSession {
  id                String              @id @default(uuid())
  
  programId         String
  program           TrainingProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  
  // Session details
  title             String
  description       String?
  
  // Scheduling
  scheduledDate     DateTime
  scheduledEndDate  DateTime?
  location          String?             // Physical or virtual location
  
  // Status
  status            TrainingSessionStatus @default(SCHEDULED)
  
  // Instructor
  instructorId      String?
  instructor        User?               @relation("TrainingInstructor", fields: [instructorId], references: [id])
  externalInstructor String?            // If not internal user
  
  // Capacity
  maxParticipants   Int?
  
  // Results
  completedAt       DateTime?
  notes             String?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  enrollments       TrainingEnrollment[]
  
  @@index([programId])
  @@index([scheduledDate])
  @@index([status])
}

// Training session status
enum TrainingSessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

// User enrollment in training sessions
model TrainingEnrollment {
  id                String              @id @default(uuid())
  
  sessionId         String
  session           TrainingSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  userId            String
  user              User                @relation("TrainingEnrollments", fields: [userId], references: [id], onDelete: Cascade)
  
  // Enrollment status
  status            EnrollmentStatus    @default(ENROLLED)
  enrolledAt        DateTime            @default(now())
  
  // Attendance
  attended          Boolean             @default(false)
  attendedAt        DateTime?
  
  // Completion
  completedAt       DateTime?
  
  // Assessment
  passed            Boolean?
  score             Decimal?            @db.Decimal(5, 2)
  assessmentNotes   String?
  
  // Certification if applicable
  certificateIssued Boolean             @default(false)
  certificateNumber String?
  certificateUrl    String?
  
  // Feedback
  feedback          String?
  rating            Int?                // 1-5 rating
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([sessionId, userId])
  @@index([userId])
  @@index([status])
}

// Enrollment status
enum EnrollmentStatus {
  ENROLLED
  WAITLISTED
  ATTENDED
  COMPLETED
  NO_SHOW
  CANCELLED
  FAILED
}

// User competencies (skills/certifications per user)
model UserCompetency {
  id                String              @id @default(uuid())
  
  userId            String
  user              User                @relation("UserCompetencies", fields: [userId], references: [id], onDelete: Cascade)
  
  // What this competency covers
  competencyType    CompetencyType
  
  // Reference to related entity
  programId         String?             // Training program if applicable
  program           TrainingProgram?    @relation(fields: [programId], references: [id])
  equipmentType     String?             // Equipment type if applicable
  station           PrintingMethod?     // Station if applicable
  
  // Competency details
  name              String
  description       String?
  
  // Level
  level             SkillLevel          @default(BASIC)
  
  // Validity
  acquiredDate      DateTime
  expirationDate    DateTime?
  
  // Certification
  isCertified       Boolean             @default(false)
  certificationNumber String?
  certificationUrl  String?
  issuingAuthority  String?
  
  // Status
  status            CompetencyStatus    @default(ACTIVE)
  
  // Verification
  verifiedById      String?
  verifiedBy        User?               @relation("CompetencyVerifier", fields: [verifiedById], references: [id])
  verifiedAt        DateTime?
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([userId, competencyType, name])
  @@index([userId])
  @@index([competencyType])
  @@index([expirationDate])
  @@index([status])
}

// Competency type
enum CompetencyType {
  EQUIPMENT_OPERATION
  STATION_CERTIFICATION
  SAFETY_CERTIFICATION
  SOFTWARE_PROFICIENCY
  QUALITY_CERTIFICATION
  SPECIALIZED_SKILL
  LICENSE
  GENERAL_TRAINING
}

// Competency status
enum CompetencyStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  SUSPENDED
  REVOKED
}

// Training requirements for roles/positions
model TrainingRequirement {
  id                String              @id @default(uuid())
  
  // Who this applies to
  targetType        TrainingTargetType
  targetValue       String              // Role name, department, or "ALL"
  
  // What training is required
  requirementName   String
  description       String?
  
  // Competency requirements
  requiredCompetencies Json?            // Array of { type, name, level }
  requiredPrograms  Json?               // Array of program IDs
  
  // Timing
  completionDeadlineDays Int?           // Days to complete after hire/assignment
  renewalIntervalDays Int?              // How often to renew
  
  // Priority
  priority          TrainingPriorityLevel @default(REQUIRED)
  
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([targetType, targetValue, requirementName])
  @@index([targetType])
  @@index([isActive])
}

// Who training requirement targets
enum TrainingTargetType {
  ROLE
  DEPARTMENT
  ALL_USERS
  STATION
}

// Training priority
enum TrainingPriorityLevel {
  REQUIRED
  RECOMMENDED
  OPTIONAL
}

// ============================================================================
// NEW-CRITICAL-06: VENDOR RELATIONSHIP MANAGEMENT
// ============================================================================

// Vendor contracts with terms and expiry tracking
model VendorContract {
  id                String              @id @default(uuid())
  contractNumber    String              @unique
  vendorId          String
  vendor            Vendor              @relation(fields: [vendorId], references: [id])
  
  // Contract details
  name              String
  description       String?
  contractType      VendorContractType
  status            ContractStatus      @default(DRAFT)
  
  // Dates
  startDate         DateTime
  endDate           DateTime
  signedDate        DateTime?
  terminationDate   DateTime?
  
  // Renewal
  autoRenew         Boolean             @default(false)
  renewalPeriodDays Int?                // Auto-renewal period
  renewalNoticeDays Int?                // Days notice before renewal
  
  // Terms
  paymentTerms      String?             // Net 30, etc.
  minimumOrderValue Decimal?            @db.Decimal(10, 2)
  annualCommitment  Decimal?            @db.Decimal(12, 2)
  discountPercent   Float?              // Contract-wide discount
  exclusivityTerms  String?
  
  // Legal
  termsAndConditions String?            @db.Text
  liabilityLimit    Decimal?            @db.Decimal(12, 2)
  insuranceRequired Boolean             @default(false)
  insuranceMinimum  Decimal?            @db.Decimal(10, 2)
  
  // Documents
  documentUrls      Json?               // Array of document URLs
  
  // Tracking
  createdById       String
  createdBy         User                @relation("VendorContractsCreated", fields: [createdById], references: [id])
  approvedById      String?
  approvedBy        User?               @relation("VendorContractsApproved", fields: [approvedById], references: [id])
  approvedAt        DateTime?
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([vendorId])
  @@index([status])
  @@index([endDate])
  @@index([autoRenew])
}

// Contract types
enum VendorContractType {
  MASTER_AGREEMENT       // Long-term master service agreement
  BLANKET_PURCHASE       // Pre-negotiated rates for recurring purchases
  FIXED_PRICE            // Fixed price for specific deliverables
  TIME_AND_MATERIALS     // Hourly/daily rates
  CONSIGNMENT            // Vendor-owned inventory on-site
  EXCLUSIVE              // Exclusive supplier agreement
  DISTRIBUTOR            // Distribution agreement
  SERVICE_LEVEL          // SLA-based contract
  LEASE                  // Equipment lease
  MAINTENANCE            // Maintenance/support contract
}

// Contract status
enum ContractStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  TERMINATED
  SUSPENDED
  RENEWED
}

// Vendor pricing tiers and volume discounts
model VendorPricing {
  id                String              @id @default(uuid())
  vendorId          String
  vendor            Vendor              @relation(fields: [vendorId], references: [id])
  contractId        String?
  
  // Item/Category
  itemMasterId      String?
  itemMaster        ItemMaster?         @relation(fields: [itemMasterId], references: [id])
  categoryName      String?             // Alternative to specific item
  
  // Pricing structure
  pricingType       VendorPricingType
  basePrice         Decimal             @db.Decimal(10, 4)
  currency          String              @default("USD")
  unitOfMeasure     String
  
  // Volume tiers (JSON array of { minQty, maxQty, price, discount })
  volumeTiers       Json?
  
  // Discounts
  contractDiscount  Float?              // % discount from contract
  volumeDiscount    Float?              // Current volume discount
  
  // Validity
  effectiveDate     DateTime
  expirationDate    DateTime?
  
  // Lead time
  leadTimeDays      Int?
  minimumOrderQty   Int?
  
  isActive          Boolean             @default(true)
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([vendorId, itemMasterId, pricingType, effectiveDate])
  @@index([vendorId])
  @@index([itemMasterId])
  @@index([effectiveDate])
}

// Pricing types
enum VendorPricingType {
  LIST_PRICE         // Standard list price
  CONTRACT_PRICE     // Contracted price
  VOLUME_PRICE       // Volume-based pricing
  PROMOTIONAL        // Temporary promotional price
  SPOT_PRICE         // One-time negotiated price
  COST_PLUS          // Cost plus margin
}

// Vendor certifications (ISO, insurance, capabilities)
model VendorCertification {
  id                String              @id @default(uuid())
  vendorId          String
  vendor            Vendor              @relation(fields: [vendorId], references: [id])
  
  // Certification details
  certificationType VendorCertificationType
  certificationName String
  issuingBody       String?
  certificateNumber String?
  
  // Dates
  issueDate         DateTime
  expirationDate    DateTime?
  
  // Status
  status            CertificationStatus @default(VALID)
  
  // Verification
  verifiedById      String?
  verifiedBy        User?               @relation("VendorCertificationsVerified", fields: [verifiedById], references: [id])
  verifiedAt        DateTime?
  
  // Documents
  documentUrl       String?
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([vendorId, certificationType, certificationName])
  @@index([vendorId])
  @@index([expirationDate])
  @@index([status])
}

// Vendor certification types
enum VendorCertificationType {
  ISO_9001                // Quality management
  ISO_14001               // Environmental management
  ISO_27001               // Information security
  OSHA_COMPLIANCE         // Safety compliance
  MINORITY_OWNED          // Minority business certification
  WOMAN_OWNED             // Woman-owned business
  VETERAN_OWNED           // Veteran-owned business
  SMALL_BUSINESS          // Small business certification
  LIABILITY_INSURANCE     // General liability insurance
  WORKERS_COMP            // Workers compensation insurance
  PROFESSIONAL_LICENSE    // Professional license
  TRADE_CERTIFICATION     // Trade-specific certification
  ENVIRONMENTAL_PERMIT    // Environmental permits
  CREDIT_RATING           // Credit/financial rating
  BONDING                 // Performance bonding
  OTHER                   // Other certification
}

// User ratings and reviews of vendors
model VendorRating {
  id                String              @id @default(uuid())
  vendorId          String
  vendor            Vendor              @relation(fields: [vendorId], references: [id])
  
  // Rating context
  purchaseOrderId   String?             // Optional link to PO
  ratedById         String
  ratedBy           User                @relation("VendorRatingsGiven", fields: [ratedById], references: [id])
  ratingDate        DateTime            @default(now())
  
  // Scores (1-5)
  qualityScore      Int                 // Product/service quality
  deliveryScore     Int                 // On-time delivery
  priceScore        Int                 // Value for money
  communicationScore Int                // Responsiveness
  overallScore      Int                 // Overall satisfaction
  
  // Details
  title             String?
  review            String?             @db.Text
  pros              String?
  cons              String?
  
  // Would recommend
  wouldRecommend    Boolean             @default(true)
  
  // Visibility
  isPublic          Boolean             @default(false) // Visible to all users
  isVerified        Boolean             @default(false) // Verified purchase
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([vendorId])
  @@index([ratedById])
  @@index([overallScore])
}

// Vendor communication log
model VendorCommunication {
  id                String              @id @default(uuid())
  vendorId          String
  vendor            Vendor              @relation(fields: [vendorId], references: [id])
  vendorContactId   String?
  vendorContact     VendorContact?      @relation(fields: [vendorContactId], references: [id])
  
  // Communication details
  channel           CommunicationChannel
  direction         CommunicationDirection
  subject           String?
  content           String              @db.Text
  
  // Context
  relatedEntityType String?             // PurchaseOrder, Quote, Issue, etc.
  relatedEntityId   String?
  
  // Participants
  userId            String
  user              User                @relation("VendorCommunicationsLogged", fields: [userId], references: [id])
  
  // Tracking
  communicationDate DateTime            @default(now())
  followUpDate      DateTime?
  followUpComplete  Boolean             @default(false)
  
  // Attachments
  attachmentUrls    Json?
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([vendorId])
  @@index([vendorContactId])
  @@index([userId])
  @@index([communicationDate])
  @@index([followUpDate])
}

// Vendor price quote requests
model VendorQuoteRequest {
  id                String              @id @default(uuid())
  requestNumber     String              @unique
  
  // Request details
  title             String
  description       String?             @db.Text
  requestType       QuoteRequestType
  status            QuoteRequestStatus  @default(DRAFT)
  
  // Items requested (JSON array)
  lineItems         Json                // Array of { description, quantity, specs, etc. }
  
  // Vendors to request from
  vendors           VendorQuoteResponse[]
  
  // Dates
  requestDate       DateTime?
  responseDeadline  DateTime?
  requiredByDate    DateTime?
  
  // Requester
  requestedById     String
  requestedBy       User                @relation("VendorQuotesRequested", fields: [requestedById], references: [id])
  
  // Selection
  selectedVendorId  String?
  selectedResponseId String?
  selectionReason   String?
  awardedAt         DateTime?
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([status])
  @@index([requestDate])
  @@index([requestedById])
}

// Quote request types
enum QuoteRequestType {
  RFQ                     // Request for Quote
  RFP                     // Request for Proposal
  RFI                     // Request for Information
  EMERGENCY               // Emergency/rush quote
  REBID                   // Re-bidding existing contract
}

// Quote request status
enum QuoteRequestStatus {
  DRAFT
  SENT
  RESPONSES_RECEIVED
  UNDER_REVIEW
  AWARDED
  CANCELLED
  EXPIRED
}

// Vendor responses to quote requests
model VendorQuoteResponse {
  id                String              @id @default(uuid())
  quoteRequestId    String
  quoteRequest      VendorQuoteRequest  @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  vendorId          String
  vendor            Vendor              @relation(fields: [vendorId], references: [id])
  
  // Response details
  status            QuoteResponseStatus @default(PENDING)
  sentAt            DateTime?           // When request was sent
  respondedAt       DateTime?           // When vendor responded
  
  // Quote
  quoteNumber       String?
  totalAmount       Decimal?            @db.Decimal(12, 2)
  currency          String              @default("USD")
  validUntil        DateTime?
  leadTimeDays      Int?
  
  // Line items (JSON with pricing)
  lineItems         Json?
  
  // Terms
  paymentTerms      String?
  shippingTerms     String?
  warranty          String?
  
  // Attachments
  attachmentUrls    Json?
  
  // Evaluation
  evaluationScore   Float?              // Calculated evaluation score
  evaluationNotes   String?
  isSelected        Boolean             @default(false)
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([quoteRequestId, vendorId])
  @@index([vendorId])
  @@index([status])
}

// Quote response status
enum QuoteResponseStatus {
  PENDING           // Not yet sent to vendor
  SENT              // Sent, awaiting response
  RECEIVED          // Response received
  NO_RESPONSE       // Vendor did not respond
  DECLINED          // Vendor declined to quote
  UNDER_REVIEW      // Being evaluated
  SELECTED          // Won the bid
  NOT_SELECTED      // Did not win
}

// ============================================================================
// NEW-CRITICAL-07: ADVANCED SHIPPING & LOGISTICS
// ============================================================================

// Carrier accounts with credentials and rate tables
model CarrierAccount {
  id                String              @id @default(uuid())
  carrier           Carrier
  accountName       String              // Display name
  accountNumber     String
  
  // API credentials (encrypted in practice)
  apiKey            String?
  apiSecret         String?
  accessToken       String?
  
  // Account details
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  
  // Settings
  defaultService    String?             // Default service level
  isDefault         Boolean             @default(false)
  isActive          Boolean             @default(true)
  
  // Rate info
  discountPercent   Float?              // Negotiated discount
  fuelSurchargeRate Float?              // Current fuel surcharge
  residentialSurcharge Decimal?         @db.Decimal(10, 2)
  
  // Pickup info
  pickupScheduled   Boolean             @default(false)
  pickupAddress     Json?               // Pickup location details
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  shippingRates     ShippingRate[]
  trackingEvents    TrackingEvent[]
  
  @@unique([carrier, accountNumber])
  @@index([carrier])
  @@index([isActive])
}

// Pre-negotiated rates per carrier/service/zone
model ShippingRate {
  id                String              @id @default(uuid())
  carrierAccountId  String
  carrierAccount    CarrierAccount      @relation(fields: [carrierAccountId], references: [id], onDelete: Cascade)
  zoneId            String?
  zone              ShippingZone?       @relation(fields: [zoneId], references: [id])
  
  // Service details
  serviceCode       String              // Carrier's service code
  serviceName       String              // Display name
  deliveryDays      Int?                // Expected transit days
  
  // Rate type
  rateType          ShippingRateType
  
  // Weight-based rates
  weightBreaks      Json?               // Array of { minWeight, maxWeight, rate }
  perPoundRate      Decimal?            @db.Decimal(10, 4)
  
  // Flat rates
  flatRate          Decimal?            @db.Decimal(10, 2)
  
  // Dimensional weight
  dimFactor         Int?                // Dimensional weight divisor
  
  // Surcharges
  fuelSurcharge     Boolean             @default(true)
  residentialSurcharge Decimal?         @db.Decimal(10, 2)
  deliveryAreaSurcharge Decimal?        @db.Decimal(10, 2)
  
  // Validity
  effectiveDate     DateTime
  expirationDate    DateTime?
  isActive          Boolean             @default(true)
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([carrierAccountId, serviceCode, zoneId, effectiveDate])
  @@index([carrierAccountId])
  @@index([zoneId])
  @@index([serviceCode])
}

// Shipping rate types
enum ShippingRateType {
  WEIGHT_BASED       // Rate based on weight breaks
  FLAT_RATE          // Single rate regardless of weight
  DIMENSIONAL        // Rate based on dim weight
  CUSTOM             // Custom calculation
}

// Geographic zones for rate calculation
model ShippingZone {
  id                String              @id @default(uuid())
  zoneName          String              @unique
  zoneCode          String              @unique
  description       String?
  
  // Geographic coverage (array of zip code prefixes or ranges)
  zipPrefixes       Json?               // ["123", "124", "125"]
  zipRanges         Json?               // [{ start: "10000", end: "10999" }]
  statesCovered     Json?               // ["NY", "NJ", "CT"]
  countryCodes      Json?               // ["US", "CA"]
  
  // Zone characteristics
  isResidential     Boolean             @default(false)
  isRemote          Boolean             @default(false)
  isInternational   Boolean             @default(false)
  
  // Additional charges
  additionalHandling Boolean            @default(false)
  holidayDelivery   Boolean             @default(true)
  
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  rates             ShippingRate[]
  
  @@index([zoneName])
}

// Freight quotes for LTL/FTL shipments
model FreightQuote {
  id                String              @id @default(uuid())
  quoteNumber       String              @unique
  workOrderId       String?
  workOrder         WorkOrder?          @relation(fields: [workOrderId], references: [id])
  
  // Quote type
  freightType       FreightType
  status            FreightQuoteStatus  @default(DRAFT)
  
  // Origin
  originName        String
  originAddress     String
  originCity        String
  originState       String
  originZip         String
  originCountry     String              @default("US")
  originContact     String?
  originPhone       String?
  
  // Destination
  destName          String
  destAddress       String
  destCity          String
  destState         String
  destZip           String
  destCountry       String              @default("US")
  destContact       String?
  destPhone         String?
  destIsResidential Boolean             @default(false)
  destHasLiftgate   Boolean             @default(false)
  destInsideDelivery Boolean            @default(false)
  
  // Shipment details
  freightClass      String?             // NMFC freight class
  pieces            Int                 @default(1)
  weight            Decimal             @db.Decimal(10, 2)
  pallets           Int?
  dimensions        Json?               // Array of { length, width, height }
  stackable         Boolean             @default(true)
  hazmat            Boolean             @default(false)
  
  // Dates
  pickupDate        DateTime?
  deliveryDate      DateTime?
  guaranteedDelivery Boolean            @default(false)
  
  // Quotes received (JSON array from multiple carriers)
  quotes            Json?               // Array of { carrier, rate, transitDays, etc. }
  selectedQuoteIdx  Int?                // Index of selected quote
  
  // Costs
  freightCost       Decimal?            @db.Decimal(10, 2)
  fuelSurcharge     Decimal?            @db.Decimal(10, 2)
  accessorialCharges Decimal?           @db.Decimal(10, 2)
  totalCost         Decimal?            @db.Decimal(10, 2)
  
