  name      String
  title     String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // NEW-CRITICAL-06
  communications VendorCommunication[]

  @@index([vendorId])
}

model PurchaseOrder {
  id           String    @id @default(uuid())
  poNumber     String    @unique
  vendorId     String
  vendor       Vendor    @relation(fields: [vendorId], references: [id])
  status       POStatus  @default(DRAFT)
  orderDate    DateTime  @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  subtotal     Decimal   @default(0) @db.Decimal(10, 2)
  taxAmount    Decimal   @default(0) @db.Decimal(10, 2)
  shippingCost Decimal   @default(0) @db.Decimal(10, 2)
  total        Decimal   @default(0) @db.Decimal(10, 2)
  notes        String?
  createdById  String
  createdBy    User      @relation("POCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lineItems POLineItem[]
  receipts  POReceipt[]

  @@index([vendorId])
  @@index([status])
  @@index([orderDate])
}

model POLineItem {
  id               String        @id @default(uuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemMasterId     String?
  itemMaster       ItemMaster?   @relation(fields: [itemMasterId], references: [id])
  description      String
  quantity         Int
  quantityReceived Int           @default(0)
  unitCost         Decimal       @db.Decimal(10, 2)
  totalCost        Decimal       @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  receiptItems POReceiptLineItem[]

  @@index([purchaseOrderId])
}

model POReceipt {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receivedDate    DateTime      @default(now())
  receivedById    String
  receivedBy      User          @relation("POReceivedBy", fields: [receivedById], references: [id])
  notes           String?
  createdAt       DateTime      @default(now())

  lineItems POReceiptLineItem[]

  @@index([purchaseOrderId])
}

model POReceiptLineItem {
  id               String     @id @default(uuid())
  receiptId        String
  receipt          POReceipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  poLineItemId     String
  poLineItem       POLineItem @relation(fields: [poLineItemId], references: [id])
  quantityReceived Int
  notes            String?

  @@index([receiptId])
  @@index([poLineItemId])
}

enum POStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  PARTIAL
  RECEIVED
  CANCELLED
}

// ============ Subcontractor Management ============

enum SubcontractorService {
  ELECTRICAL
  INSTALLATION
  WELDING
  PAINTING
  PERMITTING
  CRANE_SERVICE
  FABRICATION
  CNC_ROUTING
  POWDER_COATING
  OTHER
}

enum RateType {
  HOURLY
  FIXED
  PER_UNIT
  PER_SQFT
}

enum SubcontractStatus {
  PENDING
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  INVOICED
  PAID
  CANCELLED
}

model Subcontractor {
  id              String                 @id @default(uuid())
  name            String
  company         String?
  contactName     String
  email           String?
  phone           String
  address         String?
  city            String?
  state           String?
  zip             String?
  services        SubcontractorService[]
  rate            Decimal?               @db.Decimal(10, 2)
  rateType        RateType               @default(FIXED)
  insuranceExpiry DateTime?
  insuranceDoc    String? // URL to insurance certificate
  licenseNumber   String?
  licenseExpiry   DateTime?
  licenseDoc      String? // URL to license document
  w9OnFile        Boolean                @default(false)
  rating          Decimal?               @db.Decimal(2, 1) // 0.0 - 5.0
  notes           String?
  isActive        Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  jobs      SubcontractJob[]
  documents Document[]

  @@index([name])
  @@index([isActive])
}

model SubcontractJob {
  id              String               @id @default(uuid())
  jobNumber       String               @unique
  subcontractorId String
  subcontractor   Subcontractor        @relation(fields: [subcontractorId], references: [id])
  workOrderId     String
  workOrder       WorkOrder            @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  service         SubcontractorService
  description     String
  scheduledDate   DateTime?
  completedDate   DateTime?
  quotedAmount    Decimal              @db.Decimal(10, 2)
  actualAmount    Decimal?             @db.Decimal(10, 2)
  status          SubcontractStatus    @default(PENDING)
  poNumber        String? // External PO reference
  invoiceNumber   String? // Subcontractor's invoice
  invoiceDate     DateTime?
  paidDate        DateTime?
  notes           String?
  createdById     String
  createdBy       User                 @relation("SubcontractCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([subcontractorId])
  @@index([workOrderId])
  @@index([status])
}

// ============ Shipments ============

model Shipment {
  id                String         @id @default(uuid())
  workOrderId       String
  workOrder         WorkOrder      @relation(fields: [workOrderId], references: [id])
  carrier           Carrier
  trackingNumber    String?
  shipDate          DateTime?
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  status            ShipmentStatus @default(PENDING)
  weight            Decimal?       @db.Decimal(10, 2)
  dimensions        String? // LxWxH
  shippingCost      Decimal?       @db.Decimal(10, 2)
  signedBy          String?
  proofOfDelivery   String? // Photo/signature URL
  notes             String?
  createdById       String
  createdBy         User           @relation("ShipmentCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  packages ShipmentPackage[]
  attachments       OrderAttachment[]   @relation("ShipmentAttachments")

  // NEW-CRITICAL-07: Tracking events
  trackingEvents    TrackingEvent[]

  // Shop Floor: Shipping label scans
  labelScans        ShippingLabelScan[] @relation("ShipmentLabelScans")

  @@index([workOrderId])
  @@index([status])
  @@index([shipDate])
}

model ShipmentPackage {
  id             String   @id @default(uuid())
  shipmentId     String
  shipment       Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  trackingNumber String?
  weight         Decimal? @db.Decimal(10, 2)
  dimensions     String?
  description    String?

  @@index([shipmentId])
}

enum Carrier {
  UPS
  FEDEX
  USPS
  DHL
  FREIGHT
  CUSTOMER_PICKUP
  OWN_DELIVERY
  OTHER
}

enum ShipmentStatus {
  PENDING
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  EXCEPTION
}

// ============ Bill of Materials ============

model BillOfMaterials {
  id           String     @id @default(uuid())
  itemMasterId String     @unique
  itemMaster   ItemMaster @relation(fields: [itemMasterId], references: [id])
  version      Int        @default(1)
  isActive     Boolean    @default(true)
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  components BOMComponent[]

  @@index([itemMasterId])
}

model BOMComponent {
  id           String          @id @default(uuid())
  bomId        String
  bom          BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentId  String
  component    ItemMaster      @relation("ComponentOf", fields: [componentId], references: [id])
  quantity     Decimal         @db.Decimal(10, 4)
  unit         String          @default("EACH")
  wastePercent Decimal?        @db.Decimal(5, 2)
  notes        String?
  sortOrder    Int             @default(0)

  @@index([bomId])
  @@index([componentId])
}

// ============ Material Usage ============

model MaterialUsage {
  id           String     @id @default(uuid())
  workOrderId  String
  workOrder    WorkOrder  @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  itemMasterId String
  itemMaster   ItemMaster @relation("MaterialUsedIn", fields: [itemMasterId], references: [id])
  quantity     Decimal    @db.Decimal(10, 4)
  unit         String     @default("EACH")
  unitCost     Decimal    @db.Decimal(10, 2)
  totalCost    Decimal    @db.Decimal(10, 2)
  usedAt       DateTime   @default(now())
  recordedById String
  recordedBy   User       @relation("MaterialRecordedBy", fields: [recordedById], references: [id])
  notes        String?

  @@index([workOrderId])
  @@index([itemMasterId])
  @@index([usedAt])
}

// ============ Job Costing ============

model JobCost {
  id          String    @id @default(uuid())
  workOrderId String    @unique
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  // Revenue
  quotedAmount   Decimal  @db.Decimal(10, 2)
  invoicedAmount Decimal? @db.Decimal(10, 2)

  // Labor Costs (calculated from TimeEntry)
  laborHours Decimal @default(0) @db.Decimal(10, 2)
  laborRate  Decimal @default(0) @db.Decimal(10, 2)
  laborCost  Decimal @default(0) @db.Decimal(10, 2)

  // Material Costs (from MaterialUsage)
  materialCost Decimal @default(0) @db.Decimal(10, 2)

  // Other Direct Costs
  subcontractCost Decimal? @db.Decimal(10, 2)
  shippingCost    Decimal? @db.Decimal(10, 2)
  otherDirectCost Decimal? @db.Decimal(10, 2)

  // Overhead (optional allocation)
  overheadPercent Decimal? @db.Decimal(5, 2)
  overheadCost    Decimal? @db.Decimal(10, 2)

  // Totals
  totalCost   Decimal @default(0) @db.Decimal(10, 2)
  grossProfit Decimal @default(0) @db.Decimal(10, 2)
  grossMargin Decimal @default(0) @db.Decimal(5, 2)

  calculatedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([workOrderId])
}

// ============ Quality Control ============

model QCChecklist {
  id             String          @id @default(uuid())
  name           String          @unique
  description    String?
  printingMethod PrintingMethod? // Optional: specific to certain production methods
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  items       QCChecklistItem[]
  inspections QCInspection[]

  @@index([isActive])
  @@index([printingMethod])
}

model QCChecklistItem {
  id          String      @id @default(uuid())
  checklistId String
  checklist   QCChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  sortOrder   Int         @default(0)
  description String
  isCritical  Boolean     @default(false) // Must pass for order to proceed
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  results QCInspectionResult[]

  @@index([checklistId])
}

model QCInspection {
  id            String          @id @default(uuid())
  workOrderId   String
  workOrder     WorkOrder       @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  checklistId   String
  checklist     QCChecklist     @relation(fields: [checklistId], references: [id])
  station       PrintingMethod? // Which station was inspected
  status        QCStatus        @default(PENDING)
  inspectedById String?
  inspectedBy   User?           @relation("QCInspectedBy", fields: [inspectedById], references: [id])
  inspectedAt   DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  results QCInspectionResult[]
  defects Defect[]              // SSS-019: Defects found during inspection

  @@index([workOrderId])
  @@index([checklistId])
  @@index([status])
  @@index([inspectedAt])
}

model QCInspectionResult {
  id              String          @id @default(uuid())
  inspectionId    String
  inspection      QCInspection    @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checklistItemId String
  checklistItem   QCChecklistItem @relation(fields: [checklistItemId], references: [id])
  passed          Boolean? // null = not yet inspected
  notes           String?
  photoUrl        String? // Evidence photo
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  evidence        QCEvidence[]    // SSS-019: Evidence attachments

  @@unique([inspectionId, checklistItemId])
  @@index([inspectionId])
}

enum QCStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
  PASSED_WITH_NOTES
  NEEDS_REWORK
}

// ============ Equipment / Asset Management ============

model Equipment {
  id              String          @id @default(uuid())
  name            String
  type            String // Printer, Cutter, Laminator, Router, Welder, etc.
  manufacturer    String?
  model           String?
  serialNumber    String?
  purchaseDate    DateTime?
  purchaseCost    Decimal?        @db.Decimal(12, 2)
  warrantyExpires DateTime?
  location        String? // Physical location in shop
  station         PrintingMethod? // Which production area
  status          EquipmentStatus @default(OPERATIONAL)
  notes           String?
  imageUrl        String?
  
  // Network connectivity for live monitoring
  ipAddress       String?  // IP address for SNMP/network monitoring
  snmpCommunity   String?  @default("public") // SNMP community string
  connectionType  String?  // SNMP, JDF, FOLDER, WINDOWS_SPOOLER
  
  // NEW-CRITICAL-04: Calibration tracking fields
  requiresCalibration Boolean     @default(false)
  calibrationInterval Int?        // Days between calibrations
  lastCalibrated      DateTime?
  nextCalibrationDue  DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  maintenanceSchedules MaintenanceSchedule[]
  maintenanceLogs      MaintenanceLog[]
  downtimeEvents       DowntimeEvent[]
  
  // NEW-CRITICAL-04: Extended relations
  calibrations         Calibration[]
  certifications       EquipmentCertification[]
  parts                EquipmentPart[]
  meters               EquipmentMeter[]
  
  // NEW-CRITICAL-09: Energy consumption
  energyRecords        EnergyConsumptionRecord[] @relation("EquipmentEnergyUsage")
  
  // Equipment Watch Rules
  watchRules           EquipmentWatchRule[]
  
  // Equipment data cache (Zund stats, ink levels, etc.)
  cachedData           EquipmentDataCache[] @relation("EquipmentCachedData")
  
  // Print & RIP job relations
  printJobs            PrintJob[]           @relation("PrintJobEquipment")
  ripJobs              RipJob[]             @relation("RipJobEquipment")

  @@index([status])
  @@index([station])
  @@index([nextCalibrationDue])
}

model MaintenanceSchedule {
  id            String               @id @default(uuid())
  equipmentId   String
  equipment     Equipment            @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  taskName      String
  description   String?
  frequency     MaintenanceFrequency
  intervalDays  Int? // Custom interval if frequency is CUSTOM
  lastCompleted DateTime?
  nextDue       DateTime
  instructions  String?
  estimatedTime Int? // Minutes
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  logs MaintenanceLog[]

  @@index([equipmentId])
  @@index([nextDue])
}

model MaintenanceLog {
  id            String               @id @default(uuid())
  equipmentId   String
  equipment     Equipment            @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  scheduleId    String?
  schedule      MaintenanceSchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  taskName      String
  description   String?
  performedById String
  performedBy   User                 @relation("MaintenancePerformedBy", fields: [performedById], references: [id])
  performedAt   DateTime             @default(now())
  timeSpent     Int? // Minutes
  partsCost     Decimal?             @db.Decimal(10, 2)
  laborCost     Decimal?             @db.Decimal(10, 2)
  notes         String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([equipmentId])
  @@index([performedAt])
}

model DowntimeEvent {
  id           String         @id @default(uuid())
  equipmentId  String
  equipment    Equipment      @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  reason       DowntimeReason
  description  String?
  startedAt    DateTime       @default(now())
  endedAt      DateTime?
  reportedById String
  reportedBy   User           @relation("DowntimeReportedBy", fields: [reportedById], references: [id])
  resolvedById String?
  resolvedBy   User?          @relation("DowntimeResolvedBy", fields: [resolvedById], references: [id])
  resolution   String?
  impactLevel  ImpactLevel    @default(MEDIUM)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([equipmentId])
  @@index([startedAt])
}

enum EquipmentStatus {
  OPERATIONAL
  DEGRADED    // Working but slower (new for routing intelligence)
  MAINTENANCE
  DOWN
  WARMING_UP  // Starting up (new for routing intelligence)
  OFFLINE     // Not available (new for routing intelligence)
  RETIRED
}

enum MaintenanceFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  BIANNUALLY
  YEARLY
  CUSTOM
}

enum DowntimeReason {
  BREAKDOWN
  MAINTENANCE
  PARTS_SHORTAGE
  OPERATOR_ERROR
  POWER_OUTAGE
  CALIBRATION
  SOFTWARE_ISSUE
  OTHER
}

enum ImpactLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============ Equipment Data Cache ============
// Caches data polled from equipment (Zund statistics, ink levels, SNMP data, etc.)
// so pages load fast without hitting external SQLite/network devices each time.

model EquipmentDataCache {
  id              String    @id @default(uuid())
  
  // Equipment reference (optional — some sources like Zund stats are shared)
  equipmentId     String?
  equipment       Equipment? @relation("EquipmentCachedData", fields: [equipmentId], references: [id], onDelete: Cascade)
  
  // Source identification
  sourceType      String    // "ZUND_STATISTICS", "SNMP_INK_LEVELS", "PRINTER_STATUS", etc.
  sourceKey       String    // Unique key for dedup (e.g., Zund JobID, SNMP OID, timestamp key)
  
  // Cached payload
  data            Json      // The actual cached data (flexible JSON)
  
  // Timestamps
  capturedAt      DateTime  // When the data was originally captured on the equipment
  cachedAt        DateTime  @default(now()) // When it was stored in PostgreSQL
  expiresAt       DateTime? // Optional TTL — stale after this time
  
  @@unique([sourceType, sourceKey])
  @@index([equipmentId])
  @@index([sourceType])
  @@index([sourceType, cachedAt])
  @@index([expiresAt])
}

// ============ Customer Portal ============

model PortalUser {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  verifyToken   String?
  resetToken    String?
  resetExpires  DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  // Company (new) - will replace customerId
  companyId         String?
  company           Company?                @relation("CompanyPortalUsers", fields: [companyId], references: [id])
  
  // Contact link (portal user is a specific person)
  contactId         String?                 @unique
  contact           Contact?                @relation("ContactPortalUser", fields: [contactId], references: [id])
  
  // Customer (legacy - being deprecated)
  customerId        String?
  customer          Customer?               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  proofApprovals    ProofApproval[]
  portalMessages    PortalMessage[]
  portalSessions    PortalSession[]
  notificationPrefs PortalNotificationPref?

  @@index([companyId])
  @@index([customerId])
  @@index([email])
}

model PortalSession {
  id           String     @id @default(uuid())
  portalUserId String
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  token        String     @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime   @default(now())

  @@index([token])
  @@index([portalUserId])
}

model PortalNotificationPref {
  id           String     @id @default(uuid())
  portalUserId String     @unique
  portalUser   PortalUser @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  preferences  Json // { order_status: { emailEnabled: true, portalEnabled: true }, ... }
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model PortalInvite {
  id          String    @id @default(uuid())
  token       String    @unique @default(uuid())
  email       String?   // Optional: pre-fill the registrant's email
  customerId  String
  customer    Customer  @relation("CustomerPortalInvites", fields: [customerId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("PortalInvitesCreated", fields: [createdById], references: [id])
  expiresAt   DateTime  // e.g. 7 days from creation
  usedAt      DateTime? // null until the invite is consumed
  usedByEmail String?   // email of the person who used it
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([customerId])
  @@index([expiresAt])
}

model ProofApproval {
  id            String          @id @default(uuid())
  orderId       String
  order         WorkOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  attachmentId  String
  attachment    OrderAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  status        ProofStatus     @default(PENDING)
  requestedAt   DateTime        @default(now())
  respondedAt   DateTime?
  respondedById String?
  respondedBy   PortalUser?     @relation(fields: [respondedById], references: [id])
  comments      String? // Customer feedback
  revision      Int             @default(1)
  dueDate       DateTime? // Deadline for response
  reminderSent  Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([orderId])
  @@index([status])
}

enum ProofStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  EXPIRED
}

model PortalMessage {
  id             String     @id @default(uuid())
  threadId       String // Groups messages into conversations
  orderId        String? // Optional: link to specific order
  order          WorkOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  subject        String?
  content        String
  isFromCustomer Boolean    @default(true)
  isRead         Boolean    @default(false)
  readAt         DateTime?
  attachments    Json? // Array of { fileName, fileUrl }
  createdAt      DateTime   @default(now())

  // Relations - either portal user or internal user
  portalUserId String?
  portalUser   PortalUser? @relation(fields: [portalUserId], references: [id], onDelete: SetNull)
  userId       String?
  user         User?       @relation("PortalMessageFrom", fields: [userId], references: [id], onDelete: SetNull)
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([orderId])
  @@index([customerId])
  @@index([createdAt])
}

// ============ Email Automation ============

model EmailTemplate {
  id           String       @id @default(uuid())
  name         String       @unique
  description  String?
  trigger      EmailTrigger
  subject      String // Can include {{variables}}
  htmlBody     String // HTML template with {{variables}}
  textBody     String? // Plain text fallback
  isActive     Boolean      @default(true)
  delayMinutes Int          @default(0) // Delay before sending (for follow-ups)

  // Conditions for when to send
  conditions Json? // { orderStatus: ['COMPLETED'], daysSince: 3, etc. }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queuedEmails EmailQueue[]
}

model EmailQueue {
  id         String         @id @default(uuid())
  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  // Email details
  recipientEmail String
  recipientName  String?
  subject        String
  htmlBody       String
  textBody       String?

  // Scheduling
  scheduledAt DateTime // When to send
  sentAt      DateTime? // When actually sent
  status      EmailStatus @default(PENDING)

  // Error tracking
  attempts      Int       @default(0)
  lastAttemptAt DateTime?
  error         String?

  // Context for tracking
  orderId    String?
  order      WorkOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customerId String?
  customer   Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  quoteId    String?
  quote      Quote?     @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([status])
  @@index([scheduledAt])
  @@index([orderId])
  @@index([customerId])
}

enum EmailTrigger {
  // Order lifecycle
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  ORDER_COMPLETED
  ORDER_SHIPPED
  ORDER_ON_HOLD

  // Quote lifecycle
  QUOTE_SENT
  QUOTE_FOLLOWUP_3DAY
  QUOTE_FOLLOWUP_7DAY
  QUOTE_FOLLOWUP_14DAY
