  // Production List Settings
  productionListPath          String?  // Directory path where Production List .xlsm files live
  enableProductionListSync    Boolean @default(false) // Whether sync from production list to ERP is enabled
  brendaTallyPath             String?  // Override path to Brenda's Daily List folder
  christinaTallyPath          String?  // Override path to Christina's Daily List folder
  pamTallyPath                String?  // Override path to Pam's Daily List (Shipping Tally) folder

