// ============ Credit Approvals ============

enum CreditApprovalStatus {
  PENDING
  APPROVED
  DENIED
}

model CreditApproval {
  id              String               @id @default(uuid())
  customerId      String
  customer        Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrderId     String?
  workOrder       WorkOrder?           @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  requestedAmount Decimal              @db.Decimal(10, 2)
  status          CreditApprovalStatus @default(PENDING)
  requestedById   String
  requestedBy     User                 @relation("CreditRequestedBy", fields: [requestedById], references: [id])
  approvedById    String?
  approvedBy      User?                @relation("CreditApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([customerId])
  @@index([status])
}

// ============ Quotes / Estimates ============

model Quote {
  id              String      @id @default(uuid())
  quoteNumber     String      @unique
  status          QuoteStatus @default(DRAFT)
  customerName    String // Denormalized for quick display
  description     String?
  validUntil      DateTime?
  subtotal        Decimal     @default(0) @db.Decimal(10, 2)
  taxRate         Decimal     @default(0) @db.Decimal(5, 4) // e.g., 0.0725 for 7.25%
  taxAmount       Decimal     @default(0) @db.Decimal(10, 2)
  discountPercent Decimal     @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @default(0) @db.Decimal(10, 2)
  notes           String?
  internalNotes   String? // Notes not shown to customer
  sentAt          DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  convertedAt     DateTime? // When converted to work order
  lostReason      String? // Why the quote was lost
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  // Company (new) - will replace customerId
  companyId        String?
  company          Company?        @relation("CompanyQuotes", fields: [companyId], references: [id])
  
  // Customer (legacy - being deprecated)
  customerId       String?
  customer         Customer?       @relation(fields: [customerId], references: [id])
  
  createdById      String
  createdBy        User            @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  assignedToId     String?
  assignedTo       User?           @relation("QuoteAssignedTo", fields: [assignedToId], references: [id])
  convertedOrderId String?         @unique
  lineItems        QuoteLineItem[]
  emailQueue       EmailQueue[]
  documents        Document[]      @relation("QuoteDocuments")
  
  // NEW-CRITICAL-08: Change orders
  changeOrders     ChangeOrder[]
  
  // NEW-CRITICAL-10: Quote Intelligence
  scorecard        QuoteScorecard?
  comparisons      QuoteComparison[]
  pricingApplications PricingRuleApplication[]
  analysis         QuoteAnalysis?

  // ============ Performance Indexes ============
  @@index([status])
  @@index([createdAt])
  @@index([customerId])
  @@index([status, createdAt])                         // Quote list by status
  @@index([status, validUntil])                        // Expiring quotes
  @@index([assignedToId, status])                      // Sales rep dashboard
  @@index([customerId, status])                        // Customer quote history
}

model QuoteLineItem {
  id          String   @id @default(uuid())
  itemNumber  Int
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  quoteId      String
  quote        Quote       @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  itemMasterId String?
  itemMaster   ItemMaster? @relation(fields: [itemMasterId], references: [id])

  @@unique([quoteId, itemNumber])
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

// ============ Notifications ============

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String? // URL to navigate to when clicked
  isRead    Boolean          @default(false)
  data      Json? // Additional metadata (orderId, etc.)
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

enum NotificationType {
  ORDER_CREATED
  ORDER_STATUS_CHANGED
  ORDER_ASSIGNED
  ORDER_DUE_SOON
  ORDER_OVERDUE
  STATION_COMPLETED
  REPRINT_REQUESTED
  REPRINT_RESOLVED
  TIME_OFF_APPROVED
  TIME_OFF_DENIED
  QUOTE_APPROVED
  QUOTE_REJECTED
  MENTION
  SYSTEM
}

// ============ System Settings ============

model SystemSettings {
  id String @id @default("system")

  // Company Information
  companyName    String  @default("Wilde Signs")
  companyLogo    String? // URL to company logo
  companyAddress String?
  companyCity    String?
  companyState   String?
  companyZip     String?
  companyPhone   String?
  companyEmail   String?
  companyWebsite String?

  // Default Values
  defaultPriority     Int     @default(3)
  defaultPaymentTerms String  @default("Net 30")
  orderNumberPrefix   String  @default("")
  quoteNumberPrefix   String  @default("Q-")
  autoAssignOrders    Boolean @default(false)

  // Email Settings
  emailFromName          String  @default("Wilde Signs")
  emailFromAddress       String?
  emailSignature         String?
  sendOrderCreatedEmail  Boolean @default(true)
  sendOrderStatusEmail   Boolean @default(true)
  sendOrderAssignedEmail Boolean @default(true)
  sendQuoteEmail         Boolean @default(true)

  // Notification Settings
  notifyOnNewOrder     Boolean @default(true)
  notifyOnOrderDueSoon Boolean @default(true)
  dueSoonDays          Int     @default(3)
  notifyOnOverdue      Boolean @default(true)

  // Business Hours
  businessHoursStart String @default("08:00")
  businessHoursEnd   String @default("17:00")
  workDays           Int[]  @default([1, 2, 3, 4, 5]) // Monday-Friday

  // Feature Flags
  enableTimeTracking Boolean @default(true)
  enableInventory    Boolean @default(true)
  enableQuotes       Boolean @default(true)
  enableCustomers    Boolean @default(true)
  enableReprints     Boolean @default(true)
  enableScheduling   Boolean @default(true)

