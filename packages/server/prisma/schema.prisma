  requestedBy       User                @relation("FreightQuotesRequested", fields: [requestedById], references: [id])
  
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([workOrderId])
  @@index([status])
  @@index([pickupDate])
}

// Freight types
enum FreightType {
  LTL                // Less than truckload
  FTL                // Full truckload
  PARTIAL_TL         // Partial truckload
  EXPEDITED          // Expedited/hot shot
  WHITE_GLOVE        // White glove/special handling
  FLATBED            // Flatbed/specialized
}

// Freight quote status
enum FreightQuoteStatus {
  DRAFT
  QUOTING            // Getting quotes from carriers
  QUOTED             // Quotes received
  BOOKED             // Shipment booked
  PICKED_UP          // Freight picked up
  IN_TRANSIT         // In transit
  DELIVERED          // Delivered
  CANCELLED          // Cancelled
}

// Local delivery route planning
model DeliveryRoute {
  id                String              @id @default(uuid())
  routeDate         DateTime            @db.Date
  routeName         String?
  
  // Driver/vehicle
  driverId          String?
  driver            User?               @relation("DeliveryRouteDriver", fields: [driverId], references: [id])
  vehicleInfo       String?             // Vehicle description
  
  // Route status
  status            DeliveryRouteStatus @default(PLANNED)
  
  // Timing
  startTime         DateTime?
  endTime           DateTime?
  totalMiles        Decimal?            @db.Decimal(10, 2)
  totalTime         Int?                // Minutes
  
  // Stops
  stops             DeliveryStop[]
  
  // Optimization
  optimized         Boolean             @default(false)
  optimizedAt       DateTime?
  routePolyline     String?             @db.Text    // Encoded polyline
  
