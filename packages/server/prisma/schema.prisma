  customerId      String
  
  // Score date
  scoreDate       DateTime            @default(now())
  
  // Financial metrics
  lifetimeValue   Decimal?            @db.Decimal(12, 2)
  last12MonthsRevenue Decimal?        @db.Decimal(12, 2)
  averageOrderValue Decimal?          @db.Decimal(10, 2)
  paymentScore    Int?                @default(100) // 0-100, payment reliability
  
