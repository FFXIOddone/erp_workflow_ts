// ============================================================================
// NEW-CRITICAL-10: Advanced Pricing & Quote Intelligence
// ============================================================================

enum PricingStrategy {
  COST_PLUS              // Cost + markup percentage
  MARKET_BASED           // Based on market rates
  VALUE_BASED            // Based on perceived value
  COMPETITIVE            // Match/beat competitors
  DYNAMIC                // Real-time based on demand
  TIERED                 // Volume-based tiers
  PROMOTIONAL            // Special pricing
  CUSTOM                 // Custom calculation
}

enum QuoteConfidenceLevel {
  LOW                    // < 50% likely to close
  MEDIUM                 // 50-70% likely
  HIGH                   // 70-90% likely
  VERY_HIGH              // > 90% likely
}

enum PriceAdjustmentType {
  DISCOUNT_PERCENT
  DISCOUNT_AMOUNT
  MARKUP_PERCENT
  MARKUP_AMOUNT
  OVERRIDE
  VOLUME_DISCOUNT
  LOYALTY_DISCOUNT
  PROMOTIONAL
  RUSH_FEE
  COMPLEXITY_FACTOR
}

enum PricingRuleCondition {
  QUANTITY_GREATER_THAN
  QUANTITY_LESS_THAN
  TOTAL_GREATER_THAN
  TOTAL_LESS_THAN
  CUSTOMER_TYPE_EQUALS
  PRODUCT_CATEGORY_EQUALS
  ORDER_FREQUENCY_ABOVE
  LIFETIME_VALUE_ABOVE
  FIRST_ORDER
  REPEAT_CUSTOMER
  RUSH_ORDER
  SEASONAL
}

enum QuoteScoreCategory {
  WIN_PROBABILITY
  PROFITABILITY
  STRATEGIC_VALUE
  RISK
  COMPLEXITY
}

enum CompetitorPriceSource {
  WEBSITE
  RFQ_RESPONSE
  CUSTOMER_FEEDBACK
  SALES_INTEL
  PUBLIC_RECORD
  ESTIMATE
}

// Pricing rules - dynamic pricing logic
model PricingRule {
  id                String              @id @default(uuid())
  name              String
  description       String?
  
  // Rule definition
  priority          Int                 @default(100)  // Lower = higher priority
  isActive          Boolean             @default(true)
  
  // Conditions (JSON array of conditions)
  conditions        Json                // Array of { field, operator, value }
  conditionLogic    String?             // AND, OR, or custom expression
  
  // Action
  adjustmentType    PriceAdjustmentType
  adjustmentValue   Float               // Percentage or fixed amount
  minAdjustment     Float?              // Floor for adjustment
  maxAdjustment     Float?              // Cap for adjustment
  
  // Scope
  appliesToProducts String[]            // Product categories or "ALL"
  appliesToCustomers String[]           // Customer segments or "ALL"
  excludeProducts   String[]            // Excluded categories
  excludeCustomers  String[]            // Excluded customers
  
  // Validity
  startDate         DateTime?
  endDate           DateTime?
  usageLimit        Int?                // Max times rule can apply
  usageCount        Int                 @default(0)
  
  // Stacking
  stackable         Boolean             @default(false)
  stackOrder        Int?                // Order when stacking
  
  // Audit
  createdById       String?
  createdBy         User?               @relation("PricingRulesCreated", fields: [createdById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Track applications
  applications      PricingRuleApplication[]
  
  @@index([isActive])
  @@index([priority])
}

// Track when pricing rules are applied
model PricingRuleApplication {
  id                String              @id @default(uuid())
  ruleId            String
  rule              PricingRule         @relation(fields: [ruleId], references: [id])
  
  // Context
  quoteId           String?
  quote             Quote?              @relation(fields: [quoteId], references: [id])
  quoteLineItemId   String?
  workOrderId       String?
  
  // Application details
  originalPrice     Float
  adjustedPrice     Float
  adjustmentAmount  Float
  
  appliedAt         DateTime            @default(now())
  appliedById       String?
  appliedBy         User?               @relation("PricingRulesApplied", fields: [appliedById], references: [id])
  
  @@index([ruleId])
  @@index([quoteId])
  @@index([appliedAt])
}

// Quote scoring and intelligence
model QuoteScorecard {
  id                String              @id @default(uuid())
  quoteId           String              @unique
  quote             Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  
  // Win probability
  winProbability    Float?              // 0-100%
  confidenceLevel   QuoteConfidenceLevel?
  
  // Profitability metrics
  estimatedMargin   Float?              // Percentage
  estimatedProfit   Float?              // Dollar amount
  profitabilityScore Float?             // 0-100
  
  // Strategic value
  strategicScore    Float?              // 0-100
  strategicFactors  Json?               // Array of factors
  
  // Risk assessment
  riskScore         Float?              // 0-100 (lower is better)
  riskFactors       Json?               // Array of risk factors
  
  // Complexity
  complexityScore   Float?              // 0-100
  complexityFactors Json?
  
  // Comparison to similar quotes
  similarQuotesCount Int?
  avgSimilarQuoteValue Float?
  avgSimilarWinRate Float?
  
  // AI/ML predictions
  predictedOutcome  String?             // WIN, LOSE, PENDING
  predictionConfidence Float?
  predictionModel   String?             // Model version used
  
  // Recommendations
  recommendations   Json?               // Array of suggestions
  
  // Audit
  calculatedAt      DateTime            @default(now())
  calculatedById    String?
  calculatedBy      User?               @relation("QuoteScorecards", fields: [calculatedById], references: [id])
  
  @@index([winProbability])
}

// Quote comparison history - track similar quotes
model QuoteComparison {
  id                String              @id @default(uuid())
  
  // Source quote
  quoteId           String
  quote             Quote               @relation(fields: [quoteId], references: [id])
  
  // Comparison quote
  comparedQuoteId   String
  
  // Similarity metrics
  overallSimilarity Float               // 0-100%
  productSimilarity Float?
  sizeSimilarity    Float?
  customerSimilarity Float?
  
  // Outcome comparison
  sourceOutcome     String?             // WON, LOST, PENDING
  comparedOutcome   String?
  
  // Price comparison
  sourcePriceTotal  Float?
  comparedPriceTotal Float?
  priceVariance     Float?              // Percentage difference
  
  // Insights
  keyDifferences    Json?               // Array of differences
  learnings         String?             // What we can learn
  
  createdAt         DateTime            @default(now())
  
  @@index([quoteId])
  @@index([overallSimilarity])
}

// Competitor pricing intelligence
model CompetitorPrice {
  id                String              @id @default(uuid())
  
  // Competitor
  competitorName    String
  competitorId      String?             // If we track competitors as entities
  
  // Product/Service
  productCategory   String
  productDescription String?
  
  // Price data
  price             Float
  priceUnit         String?             // Per sqft, each, etc.
  currency          String              @default("USD")
  
  // Context
  source            CompetitorPriceSource
  sourceUrl         String?
  sourceDocument    String?
  
  // Validity
  observedAt        DateTime
  validFrom         DateTime?
  validUntil        DateTime?
  
  // Quality
  confidenceLevel   Int?                // 1-5
  isVerified        Boolean             @default(false)
  
  // Notes
  notes             String?
  
  // Audit
  recordedById      String?
  recordedBy        User?               @relation("CompetitorPricesRecorded", fields: [recordedById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([competitorName])
  @@index([productCategory])
  @@index([observedAt])
}

// Price history for analytics
model PriceHistory {
  id                String              @id @default(uuid())
  
  // What was priced
  entityType        String              // QUOTE_LINE, PRODUCT, SERVICE
  entityId          String
  
  // Price details
  price             Float
  costBasis         Float?
  margin            Float?
  
  // Context
  strategy          PricingStrategy?
  customerId        String?
  quoteId           String?
  workOrderId       String?
  
  // Outcome (if known)
  accepted          Boolean?
  wonOrder          Boolean?
  finalPrice        Float?
  
  // Adjustments applied
  adjustments       Json?               // Array of adjustments
  
  recordedAt        DateTime            @default(now())
  
  @@index([entityType, entityId])
  @@index([recordedAt])
  @@index([customerId])
}

// Customer price sensitivity profile
model CustomerPriceProfile {
  id                String              @id @default(uuid())
  customerId        String              @unique
  
  // Price sensitivity
  priceElasticity   Float?              // How sensitive to price changes
  sensitivityScore  Float?              // 0-100 (100 = very price sensitive)
  preferredPricing  PricingStrategy?
  
  // Historical behavior
  avgAcceptedDiscount Float?            // Average discount on won quotes
  avgRejectedPrice  Float?              // Average price on lost quotes
  priceThreshold    Float?              // Typical budget level
  
  // Value indicators
  lifetimeValue     Float?
  avgOrderValue     Float?
  orderFrequency    Float?              // Orders per year
  
  // Payment behavior
  paymentTermsPreferred String?
  avgDaysToPayment  Float?
  
  // Negotiation patterns
  negotiatesOften   Boolean             @default(false)
  typicalCounterOffer Float?            // Typical discount requested
  
  // Segments
  priceSegment      String?             // BUDGET, VALUE, PREMIUM
  loyaltyTier       String?             // BRONZE, SILVER, GOLD, PLATINUM
  
  // Last updated
  updatedAt         DateTime            @updatedAt
  
  @@index([priceSegment])
}

// Quote win/loss analysis
model QuoteAnalysis {
  id                String              @id @default(uuid())
  quoteId           String              @unique
  quote             Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  
  // Outcome
  outcome           String              // WON, LOST, NO_DECISION
  outcomeReason     String?             // Primary reason
  outcomeDetails    String?             // Detailed explanation
  
  // If lost
  lostToCompetitor  String?             // Competitor name
  competitorPrice   Float?
  priceWasReason    Boolean?
  
  // Factors analyzed
  priceCompetitiveness Float?           // 0-100
  responseTime      Int?                // Days to respond
  proposalQuality   Float?              // 0-100
  relationshipStrength Float?           // 0-100
  
  // Lessons
  lessonsLearned    String?
  improvementAreas  Json?               // Array of areas
  
  // Follow-up
  followUpRequired  Boolean             @default(false)
  followUpNotes     String?
  followUpDate      DateTime?
  
  // Audit
  analyzedById      String?
  analyzedBy        User?               @relation("QuotesAnalyzed", fields: [analyzedById], references: [id])
  analyzedAt        DateTime            @default(now())
  
  @@index([outcome])
}

// =====================================================================
// Equipment Watch Rules — Configurable metric monitoring + email alerts
// =====================================================================

enum WatchRuleOperator {
  LESS_THAN
  LESS_THAN_OR_EQUAL
  GREATER_THAN
  GREATER_THAN_OR_EQUAL
  EQUALS
  NOT_EQUALS
}

model EquipmentWatchRule {
  id              String   @id @default(uuid())
  name            String   // e.g. "VUTEk Ink Low"
  description     String?

  // ─── What to watch (the "mad lib" fields) ───
  dataSources     String[] // e.g. ["VUTEK_INK", "HP_INK"] — one or more data sources
  metricField     String?  // Override metric per single source; null = use default per source
  operator        WatchRuleOperator @default(LESS_THAN_OR_EQUAL)
  threshold       Float    // e.g. 30

  // Optional: restrict to one piece of equipment (null = all of that type)
  equipmentId     String?
  equipment       Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  // ─── Who to notify ───
  recipients      String[] // email addresses

  // ─── Email template (mad-lib customizable) ───
  emailSubject    String   @default("Equipment Alert: {{ruleName}}")
  emailBodyHtml   String?  // Custom HTML body; null = auto-generated summary

  // ─── Schedule ───
  scheduleTime    String   @default("17:00") // 24-hour "HH:mm"
  scheduleDays    Int[]    @default([1, 2, 3, 4, 5]) // 1=Mon … 7=Sun

  // ─── Control ───
  isActive        Boolean  @default(true)
  lastNotifiedAt  DateTime?
  lastEvaluatedAt DateTime?

  // ─── Audit ───
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String
  createdBy       User     @relation("WatchRuleCreatedBy", fields: [createdById], references: [id])

  // History
  notifications   EquipmentWatchNotification[]

  @@index([isActive])
  @@index([equipmentId])
}

model EquipmentWatchNotification {
  id             String   @id @default(uuid())
  ruleId         String
  rule           EquipmentWatchRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  sentAt         DateTime @default(now())
  recipients     String[]
  subject        String

  // Snapshot of what triggered the alert
  triggeredItems Json     // Array<{ label, currentValue, threshold, equipmentName }>

  success        Boolean  @default(true)
  error          String?

  @@index([ruleId])
  @@index([sentAt])
}

// ─── Production List Integration ─────────────────────────────────────────────
// Tracks sync operations between the Excel Production List and the ERP.

model ProductionListSync {
  id             String   @id @default(uuid())
  direction      String   // IMPORT, EXPORT, BIDIRECTIONAL
  status         String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED, PARTIAL
  fileName       String?  // Path or name of the spreadsheet file
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  totalRows      Int      @default(0)
  matched        Int      @default(0)
  spreadsheetOnly Int     @default(0)
  erpOnly        Int      @default(0)
  imported       Int      @default(0)
  updated        Int      @default(0)
  exported       Int      @default(0)
  skipped        Int      @default(0)
  errors         Int      @default(0)
  details        Json?    // Array of per-row results
  errorMessage   String?
  userId         String
  user           User     @relation("ProductionListSyncs", fields: [userId], references: [id])
  snapshots      ProductionListSnapshot[]

  @@index([userId])
  @@index([startedAt])
  @@index([status])
}

// Snapshot of a production list row at sync time — allows comparison & audit
model ProductionListSnapshot {
  id             String   @id @default(uuid())
  syncId         String
  sync           ProductionListSync @relation(fields: [syncId], references: [id], onDelete: Cascade)
  orderNumber    String
  customerName   String
  description    String?
  section        String   // Which Excel section the row belongs to
  salesperson    String?
  mustShipDate   DateTime?
  proofDate      DateTime?
  approvalDate   DateTime?
  printCutDate   DateTime?
  printStatus    String?
  notes          String?
  style          String?  // NORMAL, ATTENTION, INNER_WORKINGS, MUST_SHIP
  isPriority     Boolean  @default(false)
  isStrikethrough Boolean @default(false)
  // Link to ERP order if matched
  workOrderId    String?
  workOrder      WorkOrder? @relation("ProductionListSnapshots", fields: [workOrderId], references: [id])

  @@index([syncId])
  @@index([orderNumber])
  @@index([workOrderId])
}

// ============ Design Revision Requests (Phase 3) ============

model DesignRevisionRequest {
  id             String               @id @default(uuid())
  orderId        String
  order          WorkOrder            @relation("OrderRevisionRequests", fields: [orderId], references: [id], onDelete: Cascade)
  requestedById  String
  requestedBy    User                 @relation("RevisionRequestsCreated", fields: [requestedById], references: [id])
  reason         DesignRevisionReason
  notes          String?
  status         DesignRevisionStatus @default(PENDING)
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?                @relation("RevisionRequestsResolved", fields: [resolvedById], references: [id])
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([orderId])
  @@index([status])
}

enum DesignRevisionReason {
  WRONG_SIZE
  COLORS_OFF
  WRONG_MATERIAL
  LAYOUT_ISSUE
  TEXT_ERROR
  FILE_CORRUPT
  OTHER
}

enum DesignRevisionStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

