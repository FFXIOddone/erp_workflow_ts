enum SustainabilityGoalType {
  WASTE_REDUCTION
  ENERGY_REDUCTION
  EMISSION_REDUCTION
  RECYCLING_RATE
  RENEWABLE_USAGE
  WATER_REDUCTION
  SUSTAINABLE_SOURCING
  CERTIFICATION_TARGET
  CUSTOM
}

enum GoalTimeframe {
  MONTHLY
  QUARTERLY
  ANNUAL
  MULTI_YEAR
}

// Material environmental profile - eco data for materials
model MaterialEnvironmentalProfile {
  id                String              @id @default(uuid())
  itemMasterId      String              @unique
  itemMaster        ItemMaster          @relation(fields: [itemMasterId], references: [id])
  
  // Material composition
  materialCategory  MaterialCategory
  primaryMaterial   String?             // e.g., "PVC", "Aluminum 6061"
  materialWeight    Float?              // Weight per unit in specified unit
  weightUnit        String?             // LBS, KG, OZ, G
  
  // Recyclability
  recyclabilityRating RecyclabilityRating?
  recycledContentPercent Float?         // Percentage of recycled content
  recyclablePercent Float?              // Percentage that can be recycled
  recyclingInstructions String?
  
  // Certifications
  certifications    Json?               // Array of { type, certNumber, validUntil }
  hasFscCertification Boolean           @default(false)
  hasGreenguardCert Boolean             @default(false)
  
  // Environmental impact
  carbonFootprint   Float?              // kg CO2e per unit
  embodiedEnergy    Float?              // MJ per unit
  waterUsage        Float?              // Liters per unit
  
  // VOC and chemical info
  vocContent        Float?              // g/L VOC content
  isVocFree         Boolean             @default(false)
  containsHazardous Boolean             @default(false)
  hazardousMaterials String?            // Comma-separated list
  sdsDocumentUrl    String?             // Safety Data Sheet URL
  
  // End of life
  biodegradable     Boolean             @default(false)
  compostable       Boolean             @default(false)
  expectedLifespan  Int?                // Years
  disposalMethod    WasteDisposalMethod?
  disposalInstructions String?
  
  // Supplier sustainability
  supplierSustainabilityScore Float?    // 0-100
  locallySourced    Boolean             @default(false)
  distanceFromSource Float?             // Miles/Km
  
  // Metadata
  dataSource        String?             // Where this data came from
  verifiedAt        DateTime?
  verifiedById      String?
  verifiedBy        User?               @relation("MaterialProfilesVerified", fields: [verifiedById], references: [id])
  notes             String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([materialCategory])
  @@index([recyclabilityRating])
}

// Waste log entry - track waste generated
model WasteLogEntry {
  id                String              @id @default(uuid())
  
  // Source
  workOrderId       String?
  workOrder         WorkOrder?          @relation("WorkOrderWaste", fields: [workOrderId], references: [id])
  stationId         String?
  
  // Waste details
  category          ProductionWasteCategory
  materialType      String?             // Description of material
  itemMasterId      String?             // Link to material if applicable
  
  // Quantity
  quantity          Float
  unit              String              // LBS, KG, SQ_FT, etc.
  estimatedWeight   Float?              // Converted to standard unit (kg)
  
  // Disposal
  disposalMethod    WasteDisposalMethod
  disposalVendorId  String?
  disposalVendor    Vendor?             @relation("WasteDisposalVendor", fields: [disposalVendorId], references: [id])
  disposalCost      Float?
  disposalDate      DateTime?
  disposalDocumentUrl String?
  manifestNumber    String?             // Hazardous waste manifest
  
  // Environmental impact
  carbonOffset      Float?              // kg CO2e saved/generated
  recyclableValue   Float?              // $ value if recycled
  
  // Audit
  loggedById        String
  loggedBy          User                @relation("WasteLogsCreated", fields: [loggedById], references: [id])
  loggedAt          DateTime            @default(now())
  verifiedById      String?
  verifiedBy        User?               @relation("WasteLogsVerified", fields: [verifiedById], references: [id])
  verifiedAt        DateTime?
  
  notes             String?
  
  @@index([workOrderId])
  @@index([category])
  @@index([loggedAt])
  @@index([disposalMethod])
}

// Energy consumption record
model EnergyConsumptionRecord {
  id                String              @id @default(uuid())
  
  // Period
  periodStart       DateTime
  periodEnd         DateTime
  
  // Source
  energySource      EnergySource
  equipmentId       String?
  equipment         Equipment?          @relation("EquipmentEnergyUsage", fields: [equipmentId], references: [id])
  areaName          String?             // Building area/zone
  
  // Consumption
  quantity          Float               // Amount consumed
  unit              String              // KWH, THERMS, GALLONS, etc.
  kwhEquivalent     Float?              // Standardized to kWh
  
  // Cost
  cost              Float?
  ratePerUnit       Float?
  
  // Environmental
  carbonEmissions   Float?              // kg CO2e
  emissionScope     EmissionScope?
  renewablePercent  Float?              // % from renewable sources
  
  // Comparison
  previousPeriodQty Float?              // For trend analysis
  baselineQty       Float?              // Baseline comparison
  variancePercent   Float?              // % change from baseline
  
  // Meter info
  meterNumber       String?
  meterReadingStart Float?
  meterReadingEnd   Float?
  isEstimated       Boolean             @default(false)
  
  // Audit
  recordedById      String?
  recordedBy        User?               @relation("EnergyRecordsCreated", fields: [recordedById], references: [id])
  createdAt         DateTime            @default(now())
  verifiedAt        DateTime?
  
  notes             String?
  
  @@index([periodStart, periodEnd])
  @@index([energySource])
  @@index([equipmentId])
}

// Carbon emission tracking
model CarbonEmissionRecord {
  id                String              @id @default(uuid())
  
  // Period
  periodStart       DateTime
  periodEnd         DateTime
  
  // Source categorization
  emissionScope     EmissionScope
  sourceCategory    String              // e.g., "Production", "Transportation", "Facilities"
  sourceDescription String?
  
  // Emissions
  emissionsKgCo2e   Float               // kg CO2 equivalent
  emissionsMtCo2e   Float?              // Metric tons CO2e
  
  // Activity data
  activityType      String?             // e.g., "Electricity", "Fleet Fuel", "Business Travel"
  activityQuantity  Float?
  activityUnit      String?
  emissionFactor    Float?              // kg CO2e per activity unit
  emissionFactorSource String?          // EPA, GHG Protocol, etc.
  
  // Related records
  workOrderId       String?
  workOrder         WorkOrder?          @relation("WorkOrderEmissions", fields: [workOrderId], references: [id])
  energyRecordId    String?
  shipmentId        String?
  vendorId          String?
  
  // Offsets
  offsetsApplied    Float?              // kg CO2e offset
  offsetCertificateUrl String?
  netEmissions      Float?              // Emissions - offsets
  
  // Audit
  calculatedById    String?
  calculatedBy      User?               @relation("EmissionsCalculated", fields: [calculatedById], references: [id])
  calculatedAt      DateTime            @default(now())
  verifiedById      String?
  verifiedBy        User?               @relation("EmissionsVerified", fields: [verifiedById], references: [id])
  verifiedAt        DateTime?
  methodology       String?             // Calculation methodology used
  
  notes             String?
  
  @@index([periodStart, periodEnd])
  @@index([emissionScope])
  @@index([sourceCategory])
}

// Sustainability goals and targets
model SustainabilityGoal {
  id                String              @id @default(uuid())
  
  // Goal definition
  goalType          SustainabilityGoalType
  title             String
  description       String?
  
  // Timeframe
  timeframe         GoalTimeframe
  startDate         DateTime
  targetDate        DateTime
  
  // Targets
  baselineValue     Float               // Starting point
  baselineDate      DateTime
  targetValue       Float               // Goal target
  targetUnit        String              // %, kg, kWh, etc.
  isReduction       Boolean             @default(true)  // True if goal is to reduce
  
  // Progress
  currentValue      Float?
  lastMeasuredAt    DateTime?
  progressPercent   Float?              // % of goal achieved
  onTrack           Boolean?            // Meeting trajectory?
  
  // Scope
  appliesToArea     String?             // Specific area or "All"
  appliesToCategory String?             // Specific category
  
  // Status
  isActive          Boolean             @default(true)
  achievedAt        DateTime?
  
  // Owner
  ownerId           String?
  owner             User?               @relation("SustainabilityGoalsOwned", fields: [ownerId], references: [id])
  
  // Audit
  createdById       String?
  createdBy         User?               @relation("SustainabilityGoalsCreated", fields: [createdById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Child records
  progressSnapshots SustainabilitySnapshot[]
  
  notes             String?
  
  @@index([goalType])
  @@index([targetDate])
  @@index([isActive])
}

// Sustainability metric snapshots - periodic measurements
model SustainabilitySnapshot {
  id                String              @id @default(uuid())
  
  // Goal reference
  goalId            String
  goal              SustainabilityGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  // Snapshot timing
  snapshotDate      DateTime
  periodStart       DateTime
  periodEnd         DateTime
  
  // Metrics
  measuredValue     Float
  unit              String
  changeFromPrevious Float?             // +/- change
  changePercent     Float?
  
  // Context
  context           String?             // Explanation of any anomalies
  affectingFactors  String?             // Factors that affected this period
  
  // Audit
  recordedById      String?
  recordedBy        User?               @relation("SnapshotsRecorded", fields: [recordedById], references: [id])
  recordedAt        DateTime            @default(now())
  
  @@index([goalId])
  @@index([snapshotDate])
}

// Work order sustainability summary
model WorkOrderSustainability {
  id                String              @id @default(uuid())
  workOrderId       String              @unique
  workOrder         WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  // Material impact
  totalMaterialWeight Float?            // kg
  recycledContentWeight Float?          // kg
  recycledContentPercent Float?
  
  // Waste generated
  totalWasteWeight  Float?              // kg
  recycledWasteWeight Float?            // kg
  recyclingRate     Float?              // %
  landfillWeight    Float?              // kg
  
  // Energy
  estimatedEnergyUsage Float?           // kWh
  renewableEnergyPercent Float?
  
  // Carbon
  totalCarbonEmissions Float?           // kg CO2e
  carbonScope1      Float?
  carbonScope2      Float?
  carbonScope3      Float?
  carbonPerUnit     Float?              // kg CO2e per output unit
  carbonOffset      Float?
  netCarbon         Float?
  
  // Scores
  sustainabilityScore Float?            // 0-100 overall score
  materialScore     Float?              // 0-100 
  wasteScore        Float?              // 0-100
