enum MaterialCategory {
  VINYL
  ALUMINUM
  ACRYLIC
  WOOD
  STEEL
  PLASTIC
  PAPER
  FABRIC
  COMPOSITE
  ELECTRONIC
  INK
  ADHESIVE
  OTHER
}

enum RecyclabilityRating {
  FULLY_RECYCLABLE
  PARTIALLY_RECYCLABLE
  SPECIALTY_RECYCLING
  NOT_RECYCLABLE
  COMPOSTABLE
  BIODEGRADABLE
}

enum EnvironmentalCertificationType {
  FSC                   // Forest Stewardship Council
  GREENGUARD
  ENERGY_STAR
  CRADLE_TO_CRADLE
  ISO_14001
  LEED_COMPLIANT
  EPA_SAFER_CHOICE
  UL_ECOLOGO
  CARBON_NEUTRAL
  RECYCLED_CONTENT
  VOC_FREE
  CUSTOM
}

enum ProductionWasteCategory {
  PRODUCTION_SCRAP
  SETUP_WASTE
  DEFECTIVE_OUTPUT
  PACKAGING
  CHEMICAL_WASTE
  ELECTRONIC_WASTE
  HAZARDOUS
  GENERAL_WASTE
  RECYCLABLE_WASTE
}

enum WasteDisposalMethod {
  RECYCLED
  COMPOSTED
  LANDFILL
  INCINERATED
  HAZARDOUS_DISPOSAL
  RETURNED_TO_VENDOR
  REPURPOSED
  DONATED
}

enum EnergySource {
  GRID_ELECTRICITY
  SOLAR
  WIND
  NATURAL_GAS
  PROPANE
  DIESEL
  HYBRID
  RENEWABLE_CREDIT
}

enum EmissionScope {
