// ============ Document Management ============

model Document {
  id          String           @id @default(uuid())
  name        String // User-friendly document name
  fileName    String // Original file name
  filePath    String // Storage path (relative to uploads dir)
  fileType    String // File extension (.pdf, .ai, etc.)
  fileSize    Int // Size in bytes
  mimeType    String // MIME type
  category    DocumentCategory
  tags        String[] // Searchable tags
  description String? // Optional description

  // Version control
  version  Int        @default(1)
  parentId String? // Previous version ID
  parent   Document?  @relation("DocumentVersions", fields: [parentId], references: [id], onDelete: SetNull)
  versions Document[] @relation("DocumentVersions")
  isLatest Boolean    @default(true)

  // Polymorphic associations - document can belong to multiple entities
  // Company (new) - will replace customerId
  companyId       String?
  company         Company?       @relation("CompanyDocuments", fields: [companyId], references: [id], onDelete: SetNull)
  
  // Customer (legacy - being deprecated)
  customerId      String?
  customer        Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderId         String?
  order           WorkOrder?     @relation("OrderDocuments", fields: [orderId], references: [id], onDelete: SetNull)
  quoteId         String?
  quote           Quote?         @relation("QuoteDocuments", fields: [quoteId], references: [id], onDelete: SetNull)
  vendorId        String?
  vendor          Vendor?        @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  subcontractorId String?
  subcontractor   Subcontractor? @relation(fields: [subcontractorId], references: [id], onDelete: SetNull)

  // Thumbnail for images
  thumbnailPath String? // Path to generated thumbnail

  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Document Management System relations
  documentVersions    DocumentVersion[]       @relation("DocumentVersions")
  tagAssignments      DocumentTagAssignment[] @relation("DocumentTags")
  accessRules         DocumentAccess[]        @relation("DocumentAccessRules")
  accessLogs          DocumentAccessLog[]     @relation("DocumentAccessLogs")

  @@index([customerId])
  @@index([orderId])
  @@index([quoteId])
  @@index([vendorId])
  @@index([subcontractorId])
  @@index([category])
  @@index([isLatest])
}

enum DocumentCategory {
  DESIGN_FILE // AI, PSD, InDesign files
  PROOF // Proof PDFs for approval
  CONTRACT // Signed contracts
  LOGO // Customer logos
  BRAND_GUIDE // Brand guidelines
  INVOICE // Invoices
  PURCHASE_ORDER // PO documents
  DELIVERY_RECEIPT // Signed delivery receipts
  PHOTO // Progress photos, install photos
  INSURANCE // Insurance certificates
  LICENSE // Business licenses
  W9 // W-9 forms
  QUOTE // Quote documents
  SPECIFICATION // Technical specs
  OTHER // Miscellaneous
}

// ============ Recurring Orders / Subscriptions ============

model RecurringOrder {
  id               String             @id @default(uuid())
  name             String // e.g., "Monthly Banner Service"
  description      String?
  frequency        RecurringFrequency
  customDays       Int? // For CUSTOM frequency, number of days
  startDate        DateTime
  endDate          DateTime? // Optional end date
  nextGenerateDate DateTime // Next date to generate order
  lastGeneratedAt  DateTime? // Last time order was generated
  isActive         Boolean            @default(true)
  isPaused         Boolean            @default(false)
  pausedReason     String?
  notifyDaysBefore Int                @default(3) // Days before to notify customer
  discountPercent  Decimal?           @db.Decimal(5, 2) // Recurring discount
  notes            String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  // Company (new) - will replace customerId
  companyId       String?
  company         Company?            @relation("CompanyRecurringOrders", fields: [companyId], references: [id])
  
  // Customer (legacy - being deprecated)
  customerId      String?
  customer        Customer?           @relation(fields: [customerId], references: [id])
  
  templateId      String?
  template        OrderTemplate?      @relation(fields: [templateId], references: [id])
  lineItems       RecurringLineItem[]
  generatedOrders WorkOrder[]         @relation("RecurringOrderSource")
  generationLogs  RecurringOrderLog[]

  @@index([customerId])
  @@index([nextGenerateDate])
  @@index([isActive])
}

model RecurringLineItem {
  id          String  @id @default(uuid())
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  notes       String?

  // Relations
  recurringOrderId String
  recurringOrder   RecurringOrder @relation(fields: [recurringOrderId], references: [id], onDelete: Cascade)
  itemMasterId     String?
  itemMaster       ItemMaster?    @relation(fields: [itemMasterId], references: [id])

  @@index([recurringOrderId])
}

model RecurringOrderLog {
  id               String          @id @default(uuid())
  action           RecurringAction
  details          String?
  generatedOrderId String? // If order was generated
  errorMessage     String? // If generation failed
  createdAt        DateTime        @default(now())

  // Relations
  recurringOrderId String
  recurringOrder   RecurringOrder @relation(fields: [recurringOrderId], references: [id], onDelete: Cascade)

  @@index([recurringOrderId])
  @@index([createdAt])
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUALLY
  YEARLY
  CUSTOM // Use customDays field
}

enum RecurringAction {
  CREATED
  UPDATED
  PAUSED
  RESUMED
  CANCELLED
  ORDER_GENERATED
  GENERATION_FAILED
  NOTIFICATION_SENT
  SKIPPED
}

// ============ Installation / Field Service ============

model InstallationJob {
  id        String @id @default(uuid())
  jobNumber String @unique // e.g., "INS-2026-0001"

  // Job details
  type        InstallType     @default(NEW_INSTALL)
  status      InstallStatus   @default(UNSCHEDULED)
  priority    InstallPriority @default(NORMAL)
  description String?

  // Location
  siteAddress String
  siteCity    String?
  siteState   String?
  siteZip     String?
  siteContact String? // On-site contact name
  sitePhone   String? // On-site contact phone

  // Scheduling
  scheduledDate   DateTime?
  scheduledTime   String? // HH:mm format
  estimatedHours  Decimal?  @db.Decimal(5, 2)
  actualStartTime DateTime?
  actualEndTime   DateTime?

  // Notes
  internalNotes   String? // Internal crew notes
  customerNotes   String? // Visible to customer
  completionNotes String? // Post-completion notes

  // Cost tracking
  estimatedCost Decimal? @db.Decimal(10, 2)
  actualCost    Decimal? @db.Decimal(10, 2)
  mileage       Decimal? @db.Decimal(8, 2)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // Relations
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  // Company (new) - will replace customerId
  companyId   String?
  company     Company?  @relation("CompanyInstallationJobs", fields: [companyId], references: [id])
  
  // Customer (legacy - being deprecated)
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])

  // Many-to-many: installers assigned to this job
  installers InstallerAssignment[]
  photos     InstallPhoto[]
  events     InstallEvent[]

  @@index([workOrderId])
  @@index([customerId])
  @@index([scheduledDate])
  @@index([status])
}

model InstallerAssignment {
  id          String   @id @default(uuid())
  isLead      Boolean  @default(false) // Lead installer for the job
  hoursWorked Decimal? @db.Decimal(5, 2)
  notes       String?
  assignedAt  DateTime @default(now())

  // Relations
  installationJobId String
  installationJob   InstallationJob @relation(fields: [installationJobId], references: [id], onDelete: Cascade)
  userId            String
  user              User            @relation(fields: [userId], references: [id])

  @@unique([installationJobId, userId])
  @@index([userId])
}

model InstallerSchedule {
  id          String   @id @default(uuid())
  date        DateTime @db.Date
  isAvailable Boolean  @default(true)
  startTime   String? // HH:mm format
  endTime     String? // HH:mm format
  notes       String? // e.g., "On vacation", "Training"

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([date])
}

model InstallPhoto {
  id        String           @id @default(uuid())
  filename  String
  filepath  String
  caption   String?
  photoType InstallPhotoType @default(PROGRESS)
  takenAt   DateTime         @default(now())

  // Relations
  installationJobId String
  installationJob   InstallationJob @relation(fields: [installationJobId], references: [id], onDelete: Cascade)
  uploadedById      String?
  uploadedBy        User?           @relation(fields: [uploadedById], references: [id])

  @@index([installationJobId])
}

model InstallEvent {
  id          String           @id @default(uuid())
  eventType   InstallEventType
  description String?
  metadata    Json? // Additional event data
  createdAt   DateTime         @default(now())

  // Relations
  installationJobId String
  installationJob   InstallationJob @relation(fields: [installationJobId], references: [id], onDelete: Cascade)
  userId            String?
  user              User?           @relation(fields: [userId], references: [id])

  @@index([installationJobId])
  @@index([createdAt])
}

enum InstallStatus {
  UNSCHEDULED
  SCHEDULED
  EN_ROUTE
  ON_SITE
  IN_PROGRESS
  COMPLETED
  INCOMPLETE
  RESCHEDULED
  CANCELLED
