// ============ QB Auto-Poll Log ============

model QBPollLog {
  id               String   @id @default(uuid())
  polledAt         DateTime @default(now())
  newOrdersCreated Int      @default(0)
  errors           String[] @default([])
  lastQBTimestamp  String?
  invoicesFound    Int      @default(0)
  salesOrdersFound Int      @default(0)
