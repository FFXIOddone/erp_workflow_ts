// ============ Webhooks / External Integrations ============

model Webhook {
  id          String  @id @default(uuid())
  name        String // Human-readable name
  description String?

  // Configuration
  url      String // Target URL to POST to
  secret   String? // HMAC secret for signature verification
  isActive Boolean @default(true)

  // Event subscriptions (which events trigger this webhook)
  events WebhookEventType[]

  // Filtering (optional)
  filterCustomerId String? // Only trigger for specific customer
  filterStation    PrintingMethod? // Only trigger for specific station

  // Rate limiting / retry config
  maxRetries   Int @default(3)
  retryDelayMs Int @default(1000) // Initial retry delay
  timeoutMs    Int @default(10000)

  // Headers to include
  headers Json? // Custom headers as key-value pairs

  // Metadata
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastTriggeredAt DateTime?

  // Relations
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id])
  deliveries  WebhookDelivery[]

  @@index([isActive])
  @@index([createdById])
}

model WebhookDelivery {
  id String @id @default(uuid())

  // What triggered this
  eventType WebhookEventType
  eventId   String? // Reference to the source event (orderId, etc.)

  // Request details
  payload Json // The JSON payload sent

  // Response details
  status         WebhookDeliveryStatus @default(PENDING)
  responseCode   Int? // HTTP response code
  responseBody   String? // Response body (truncated if large)
  responseTimeMs Int? // Response time in milliseconds

  // Retry tracking
  attemptNumber Int       @default(1)
  nextRetryAt   DateTime?
  errorMessage  String?

  // Timestamps
  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  // Relations
  webhookId String
  webhook   Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
  @@index([createdAt])
  @@index([eventType])
}

// Events that can trigger webhooks
enum WebhookEventType {
  // Order lifecycle
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_STATUS_CHANGED
  ORDER_COMPLETED
  ORDER_SHIPPED
  ORDER_CANCELLED

  // Station progress
  STATION_STARTED
  STATION_COMPLETED

  // Quotes
  QUOTE_CREATED
  QUOTE_SENT
  QUOTE_APPROVED
  QUOTE_REJECTED
  QUOTE_CONVERTED

  // Customer
  CUSTOMER_CREATED
  CUSTOMER_UPDATED

  // Proofs
  PROOF_UPLOADED
  PROOF_APPROVED
  PROOF_REJECTED

  // Installation
  INSTALL_SCHEDULED
  INSTALL_STARTED
  INSTALL_COMPLETED

  // Inventory
  INVENTORY_LOW
  INVENTORY_DEPLETED

  // Shipments
  SHIPMENT_CREATED
  SHIPMENT_SHIPPED
  SHIPMENT_DELIVERED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

// ============ Labor Rates ============

model LaborRate {
  id              String          @id @default(uuid())
  name            String          // e.g., "Standard Rate", "Premium Rate", "Overtime"
  description     String?
  
  // Rate configuration
  hourlyRate      Decimal         @db.Decimal(10, 2)
  isDefault       Boolean         @default(false) // Default rate for the station/role
  
  // Applicability
  station         PrintingMethod?  // Specific station or null for all
  userRole        UserRole?        // Specific role or null for all
  
  // Effective dates (for time-based rate changes)
  effectiveFrom   DateTime         @default(now())
  effectiveTo     DateTime?
  
  // Multipliers for special conditions
  overtimeMultiplier Decimal       @default(1.5) @db.Decimal(4, 2) // e.g., 1.5 for time-and-a-half
  rushMultiplier     Decimal       @default(1.25) @db.Decimal(4, 2) // e.g., 1.25 for rush jobs
  
  // Metadata
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  createdById     String
  createdBy       User            @relation("LaborRateCreatedBy", fields: [createdById], references: [id])
  history         LaborRateHistory[]
  
  @@index([station])
  @@index([userRole])
  @@index([isActive])
  @@index([isDefault])
}

model LaborRateHistory {
  id              String          @id @default(uuid())
  
  // Reference to the labor rate
  laborRateId     String
  laborRate       LaborRate       @relation(fields: [laborRateId], references: [id], onDelete: Cascade)
  
  // Who made the change
  changedById     String
  changedBy       User            @relation("LaborRateChangedBy", fields: [changedById], references: [id])
  
  // Change tracking
  changeType      String          // CREATE, UPDATE, DEACTIVATE, REACTIVATE
  previousValues  Json?           // Snapshot of previous values
  newValues       Json            // Snapshot of new values
  reason          String?         // Reason for the change
  
  createdAt       DateTime        @default(now())
  
  @@index([laborRateId])
  @@index([changedById])
  @@index([createdAt])
}
// ============ System Alerts ============

model Alert {
  id              String          @id @default(uuid())
  
  // Alert content
  title           String
  message         String
  type            AlertType       @default(INFO)
  severity        AlertSeverity   @default(MEDIUM)
  
  // Targeting
  isGlobal        Boolean         @default(false)  // Show to all users
  targetRoles     UserRole[]      // Show to specific roles (if not global)
  
  // Display settings
  isDismissible   Boolean         @default(true)   // Can users dismiss it?
  showOnPages     String[]        // Specific page paths to show on, empty = all
  
  // Scheduling
  startsAt        DateTime        @default(now())
  expiresAt       DateTime?       // When to auto-expire
  
  // Metadata
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  createdById     String
  createdBy       User            @relation("AlertCreatedBy", fields: [createdById], references: [id])
  dismissedBy     AlertDismissal[]
  history         AlertHistory[]
  
  @@index([isActive])
  @@index([isGlobal])
  @@index([startsAt])
  @@index([expiresAt])
}

model AlertRule {
  id              String          @id @default(uuid())
  name            String          // Rule name for identification
  description     String?
  
  // Trigger configuration
  triggerType     AlertTriggerType
  triggerConfig   Json            // Condition configuration (thresholds, entity types, etc.)
  
  // Alert template
  alertType       AlertType       @default(WARNING)
  alertSeverity   AlertSeverity   @default(MEDIUM)
  titleTemplate   String          // Template with {{variables}}
  messageTemplate String          // Template with {{variables}}
  
  // Behavior
  isActive        Boolean         @default(true)
  cooldownMinutes Int             @default(60)    // Min time between alerts from this rule
  lastTriggeredAt DateTime?
  
  // Metadata
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  createdById     String
  createdBy       User            @relation("AlertRuleCreatedBy", fields: [createdById], references: [id])
  generatedAlerts AlertHistory[]
  
  @@index([isActive])
  @@index([triggerType])
}

model AlertHistory {
  id              String          @id @default(uuid())
  
  // Alert snapshot
  title           String
  message         String
  type            AlertType
  severity        AlertSeverity
  
  // Context
  entityType      String?         // What entity triggered this (Order, Inventory, etc.)
  entityId        String?         // ID of the triggering entity
  metadata        Json?           // Additional context data
  
  // Timestamps
  triggeredAt     DateTime        @default(now())
  resolvedAt      DateTime?
  
  // Relations
  alertId         String?
  alert           Alert?          @relation(fields: [alertId], references: [id], onDelete: SetNull)
  alertRuleId     String?
  alertRule       AlertRule?      @relation(fields: [alertRuleId], references: [id], onDelete: SetNull)
  resolvedById    String?
  resolvedBy      User?           @relation("AlertResolvedBy", fields: [resolvedById], references: [id])
  
  @@index([alertId])
  @@index([alertRuleId])
  @@index([triggeredAt])
  @@index([entityType, entityId])
}

model AlertDismissal {
  id              String          @id @default(uuid())
  dismissedAt     DateTime        @default(now())
  
  // Relations
  alertId         String
  alert           Alert           @relation(fields: [alertId], references: [id], onDelete: Cascade)
  userId          String
  user            User            @relation("AlertDismissedBy", fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([alertId, userId])
  @@index([userId])
}

enum AlertType {
  INFO
  SUCCESS
  WARNING
  ERROR
  MAINTENANCE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertTriggerType {
  // Inventory triggers
  INVENTORY_LOW_STOCK
  INVENTORY_DEPLETED
  INVENTORY_EXPIRING
  
  // Order triggers
  ORDER_OVERDUE
  ORDER_STUCK_IN_STATION
  ORDER_REQUIRES_ATTENTION
  
  // Production triggers
  EQUIPMENT_DOWNTIME
  EQUIPMENT_MAINTENANCE_DUE
  PRODUCTION_BOTTLENECK
  
  // Business triggers
  QUOTE_EXPIRING
  PAYMENT_OVERDUE
  CUSTOMER_CREDIT_EXCEEDED
  
  // System triggers
  SCHEDULED
  MANUAL
  API_TRIGGERED
}

// ============ Third Party Integration Models ============

model Integration {
  id                  String              @id @default(uuid())
  name                String              // User-friendly name (e.g., "QuickBooks Desktop", "WooCommerce Store")
  type                IntegrationType     
  provider            String              // Provider identifier (e.g., "quickbooks", "woocommerce", "stripe")
  description         String?
  
  // Configuration
  baseUrl             String?             // API base URL for external services
  config              Json                @default("{}")  // Provider-specific config (non-sensitive)
  
  // Status
  isEnabled           Boolean             @default(true)
  status              IntegrationStatus   @default(DISCONNECTED)
  lastSyncAt          DateTime?
  lastErrorAt         DateTime?
  lastError           String?
  
  // Sync settings
  syncInterval        Int?                // Minutes between auto-sync (null = manual only)
  autoSync            Boolean             @default(false)
  
  // Metadata
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relations
  credentials         IntegrationCredential[]
  syncLogs            IntegrationSyncLog[]
  createdById         String
  createdBy           User                @relation("IntegrationCreatedBy", fields: [createdById], references: [id])
  
  @@index([type])
  @@index([provider])
  @@index([status])
}

model IntegrationCredential {
  id                  String              @id @default(uuid())
  integrationId       String
  integration         Integration         @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  // Credential storage (encrypted)
  credentialType      CredentialType      @default(API_KEY)
  key                 String              // Credential identifier (e.g., "api_key", "access_token", "client_id")
  value               String              // Encrypted value
  expiresAt           DateTime?           // For OAuth tokens
  
  // OAuth-specific
  refreshToken        String?             // Encrypted refresh token
  refreshTokenExpiresAt DateTime?
  scope               String?             // OAuth scope
  tokenType           String?             // Bearer, Basic, etc.
  
  // Metadata
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  lastUsedAt          DateTime?
  
  @@unique([integrationId, key])
  @@index([credentialType])
}

model IntegrationSyncLog {
  id                  String              @id @default(uuid())
  integrationId       String
  integration         Integration         @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  // Sync details
  syncType            SyncType            @default(MANUAL)
  direction           SyncDirection       @default(PULL)
  entityType          String?             // What was synced (e.g., "customers", "orders", "products")
  
  // Results
  status              SyncStatus          @default(PENDING)
  recordsProcessed    Int                 @default(0)
  recordsCreated      Int                 @default(0)
  recordsUpdated      Int                 @default(0)
  recordsFailed       Int                 @default(0)
  
  // Timing
  startedAt           DateTime            @default(now())
  completedAt         DateTime?
  durationMs          Int?
  
  // Error handling
  errorMessage        String?
  errorDetails        Json?
  
  @@index([integrationId])
  @@index([syncType])
  @@index([status])
  @@index([startedAt])
}

enum IntegrationType {
  ACCOUNTING      // QuickBooks, Xero
  ECOMMERCE       // WooCommerce, Shopify
  PAYMENT         // Stripe, Square
  SHIPPING        // UPS, FedEx, USPS
  EMAIL           // SendGrid, Mailgun
  STORAGE         // S3, Google Cloud Storage
  CRM             // Salesforce, HubSpot
  CALENDAR        // Google Calendar, Outlook
  CUSTOM          // Custom API integrations
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  SYNCING
  RATE_LIMITED
  EXPIRED         // OAuth token expired
  REQUIRES_REAUTH // Needs user to re-authorize
}

enum CredentialType {
  API_KEY
  OAUTH2
  BASIC_AUTH
  BEARER_TOKEN
  CERTIFICATE
  HMAC_SECRET
}

enum SyncType {
  MANUAL          // User-initiated sync
  SCHEDULED       // Auto-scheduled sync
  WEBHOOK         // Triggered by webhook
  REALTIME        // Continuous sync
}

enum SyncDirection {
  PULL            // External -> ERP
  PUSH            // ERP -> External
  BIDIRECTIONAL   // Both directions
}

enum SyncStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  PARTIAL         // Some records failed
  CANCELLED
}

// ============ Saved Filter Models ============

model SavedFilter {
  id              String          @id @default(uuid())
  name            String          
  description     String?
  
  // Filter target
  entityType      FilterEntityType
  pageKey         String          // Unique key for the page (e.g., "orders", "inventory", "quotes")
  
  // Filter configuration
  filterConfig    Json            // The actual filter values
  sortConfig      Json?           // Sort configuration (field, direction)
  columnConfig    Json?           // Visible columns configuration
  
  // Sharing
  isDefault       Boolean         @default(false)  // Default filter for this entity/user
  isShared        Boolean         @default(false)  // Visible to all users
  sharedWithRoles UserRole[]      @default([])     // Specific roles that can see this
  
  // Usage tracking
  usageCount      Int             @default(0)
  lastUsedAt      DateTime?
  
  // Metadata
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  userId          String
  user            User            @relation("SavedFilterCreatedBy", fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, entityType, name])  // User can't have duplicate names per entity
  @@index([entityType])
  @@index([pageKey])
  @@index([isShared])
  @@index([userId])
}

enum FilterEntityType {
  ORDERS
  QUOTES
  CUSTOMERS
  INVENTORY
  INSTALLATIONS
  PRODUCTION
  INVOICES
  SHIPMENTS
  REPORTS
  USERS
  PROOFS
}

// ============ Price Book ============

model PriceBookCategory {
  id              String          @id @default(uuid())
  name            String          // e.g., "Vehicle Graphics", "Banners", "A-Frame Signs"
  description     String?
  parentId        String?         // For nested categories
  parent          PriceBookCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children        PriceBookCategory[] @relation("CategoryHierarchy")
  sortOrder       Int             @default(0)
  
  // Display
  icon            String?         // Icon name for UI
  color           String?         // Color code for UI
  
  // Metadata
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relations
  items           PriceBookItem[]
  
  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
}

model PriceBookItem {
  id              String          @id @default(uuid())
  sku             String          @unique  // Internal SKU/product code
  name            String
  description     String?
  
  // Categorization
  categoryId      String?
  category        PriceBookCategory? @relation(fields: [categoryId], references: [id])
  
  // Pricing
  basePrice       Decimal         @db.Decimal(10, 2)  // Base selling price
  costPrice       Decimal?        @db.Decimal(10, 2)  // Internal cost
  pricingUnit     PricingUnit     @default(EACH)      // How price is calculated
  minQuantity     Int             @default(1)         // Minimum order quantity
  
  // Pricing tiers (quantity-based pricing)
  pricingTiers    Json?           // Array of { minQty, maxQty, price, discountPercent }
  
  // Labor
  laborRateId     String?         // Link to labor rate for labor-based items
  estimatedHours  Decimal?        @db.Decimal(6, 2)  // Estimated labor hours
  
  // Artwork options (for products with stock designs)
  artworkOptions  Json?           // Array of { id, name, thumbnailUrl, description }

  // Materials (for items that consume inventory)
  materialItems   Json?           // Array of { inventoryItemId, quantity, wasteFactor }
  
  // Station/Production
  defaultStation  PrintingMethod? // Default production station
  estimatedLeadDays Int?          // Typical production time
  
  // Metadata
  isActive        Boolean         @default(true)
  isTaxable       Boolean         @default(true)
  tags            String[]        @default([])
  notes           String?
  
  // External references
  quickbooksItemId String?        // QuickBooks item ID
  externalSku     String?         // External/vendor SKU
  
  // Audit
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdById     String
  createdBy       User            @relation("PriceBookItemCreatedBy", fields: [createdById], references: [id])
  
  // History
  history         PriceBookHistory[]
  
  @@index([categoryId])
  @@index([isActive])
  @@index([defaultStation])
  @@index([laborRateId])
}

model PriceBookHistory {
  id              String          @id @default(uuid())
  itemId          String
  item            PriceBookItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  // Change tracking
  changeType      String          // CREATE, UPDATE, PRICE_CHANGE, DEACTIVATE
  previousValues  Json?
  newValues       Json
  reason          String?
  
  // Who and when
  changedById     String
  changedBy       User            @relation("PriceBookChangedBy", fields: [changedById], references: [id])
  createdAt       DateTime        @default(now())
  
  @@index([itemId])
  @@index([changedById])
  @@index([createdAt])
}

enum PricingUnit {
  EACH            // Per item
  SQFT            // Per square foot
  SQIN            // Per square inch
  LNFT            // Per linear foot
  HOUR            // Per labor hour
  SET             // Per set (custom quantity)
  PACK            // Per pack
}

