// Customer relationship type for hierarchy
enum CustomerRelationType {
  PARENT               // Parent company
  SUBSIDIARY           // Child company
  FRANCHISE            // Franchise location
  AFFILIATE            // Affiliated company
  PARTNER              // Business partner
  BILLING              // Billing relationship
}

// Customer hierarchy for parent/child relationships
model CustomerHierarchy {
  id              String              @id @default(uuid())
  
  // Parent-child relationship
  parentCustomerId String
  childCustomerId  String
  relationType    CustomerRelationType
  
  // Relationship details
  effectiveFrom   DateTime            @default(now())
  effectiveUntil  DateTime?
  isPrimary       Boolean             @default(true)  // Primary parent if multiple
  
