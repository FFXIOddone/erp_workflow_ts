enum InstallPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum InstallType {
  NEW_INSTALL
  REMOVAL
  REPAIR
  SURVEY
  PERMIT_PICKUP
  SITE_CHECK
  RETROFIT
  MAINTENANCE
}

enum InstallPhotoType {
  BEFORE
  PROGRESS
  AFTER
  ISSUE
  PERMIT
  SITE
}

enum InstallEventType {
  CREATED
  SCHEDULED
  RESCHEDULED
  ASSIGNED
  UNASSIGNED
  STATUS_CHANGED
  EN_ROUTE
  ARRIVED
  STARTED
  COMPLETED
