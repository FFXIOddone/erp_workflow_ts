// ============ SSS-008/SSS-011: NLP Query & Command Palette ============

// Natural language query parsing and execution
model NLPQuery {
  id                String              @id @default(uuid())
  
  // User who made the query
  userId            String
  user              User                @relation("UserNLPQueries", fields: [userId], references: [id], onDelete: Cascade)
  
  // Original natural language input
  rawQuery          String              // "show me overdue orders for Acme"
  normalizedQuery   String?             // Cleaned/normalized version
  
  // Parsed intent
  intent            QueryIntent         // What the user wants to do
  confidence        Float               @default(0.0) // 0-1 confidence in parsing
  
  // Extracted entities
  entities          Json                // { customer: "Acme", status: "overdue", dateRange: {...} }
  
  // Generated query/action
  generatedSQL      String?             // For data queries
  generatedAction   String?             // For action commands
  actionParams      Json?               // Parameters for action
  
  // Execution
  wasExecuted       Boolean             @default(false)
  executedAt        DateTime?
  resultCount       Int?                // Number of results returned
  executionTimeMs   Int?                // How long it took
  
  // Feedback for learning
  wasSuccessful     Boolean?            // Did user get what they wanted
  feedbackScore     Int?                // 1-5 rating
  feedbackNotes     String?
  
  // Metadata
  createdAt         DateTime            @default(now())
  
  @@index([userId])
  @@index([intent])
  @@index([createdAt])
}

// Query intent types
enum QueryIntent {
  SEARCH            // Find/search for something
  REPORT            // Generate a report
  COMPARE           // Compare two things
  AGGREGATE         // Sum/count/average
  NAVIGATE          // Go to a page/record
  CREATE            // Create new record
  UPDATE            // Modify existing record
  DELETE            // Remove record
  EXPORT            // Export data
  SCHEDULE          // Schedule something
  NOTIFY            // Send notification
  HELP              // Get help/documentation
}

// Saved queries for reuse
model SavedQuery {
  id                String              @id @default(uuid())
  
  // Owner
  userId            String
  user              User                @relation("UserSavedQueries", fields: [userId], references: [id], onDelete: Cascade)
  
  // Query definition
  name              String              // User-friendly name
  description       String?
  rawQuery          String              // Original NL query
  parsedIntent      QueryIntent
  parsedEntities    Json                // Stored entities
  
  // Generated artifacts
  generatedSQL      String?
  generatedAction   String?
  actionParams      Json?
  
  // Sharing
  isShared          Boolean             @default(false)
  sharedWithRoles   String[]            // Roles that can see this
  
  // Usage tracking
  useCount          Int                 @default(0)
  lastUsedAt        DateTime?
  
  // Scheduling (for recurring reports)
  isScheduled       Boolean             @default(false)
  scheduleFrequency ScheduleFrequency?
  scheduleCron      String?             // Cron expression for custom
  nextRunAt         DateTime?
  lastRunAt         DateTime?
  
  // Pinned to dashboard
  isPinned          Boolean             @default(false)
  dashboardPosition Int?
  
  // Metadata
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([userId])
  @@index([isShared])
  @@index([isPinned])
}

// Schedule frequency for saved queries
enum ScheduleFrequency {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  CUSTOM            // Uses scheduleCron
}

// Command palette history and quick actions
model CommandHistory {
  id                String              @id @default(uuid())
  
  // User
  userId            String
  user              User                @relation("UserCommandHistory", fields: [userId], references: [id], onDelete: Cascade)
  
  // Command details
  commandType       CommandType
  command           String              // The actual command/search
  context           String?             // Page/context when executed
  
  // Target (what was acted on)
  targetType        String?             // "order", "customer", "quote"
  targetId          String?             // ID of the target
  targetLabel       String?             // Display label
  
  // Execution
  wasSuccessful     Boolean             @default(true)
  resultCount       Int?
  executionTimeMs   Int?
  
  // Metadata
  executedAt        DateTime            @default(now())
  
  @@index([userId])
  @@index([commandType])
  @@index([executedAt])
}

// Types of commands in the palette
enum CommandType {
  SEARCH            // Search query
  NAVIGATION        // Go to page/record
  ACTION            // Quick action (create, edit)
  NLP_QUERY         // Natural language query
  SHORTCUT          // Keyboard shortcut
  RECENT            // Recent item
}

// Quick actions registry (system-defined actions)
model QuickAction {
  id                String              @id @default(uuid())
  
  // Action definition
  code              String              @unique // "create_quote", "new_order"
  name              String              // "Create Quote"
  description       String?
  
  // Categorization
  category          ActionCategory
  keywords          String[]            // For fuzzy matching
  
  // Routing
  routePath         String?             // Navigation path
  actionHandler     String?             // Action handler name
  requiredParams    Json?               // Required parameters
  
  // Access control
  requiredRoles     String[]            // Roles that can use this
  requiredPermission String?            // Specific permission needed
  
  // Display
  icon              String?             // Icon name
  shortcut          String?             // Keyboard shortcut hint
  
  // Status
  isEnabled         Boolean             @default(true)
  sortOrder         Int                 @default(100)
  
  // Usage tracking
  useCount          Int                 @default(0)
  
  // User preferences for this action
  userPreferences   UserActionPreference[]
  
  @@index([category])
  @@index([isEnabled])
}

// Categories for quick actions
enum ActionCategory {
  CREATE            // Create new records
  NAVIGATION        // Go to pages
  WORKFLOW          // Workflow actions
  REPORT            // Generate reports
  COMMUNICATION     // Send emails/notifications
  SETTINGS          // Settings/preferences
  TOOLS             // Utility tools
}

// User-specific action preferences
model UserActionPreference {
  id                String              @id @default(uuid())
  
  userId            String
  user              User                @relation("UserActionPreferences", fields: [userId], references: [id], onDelete: Cascade)
  
  // Action reference
  actionId          String
  action            QuickAction         @relation(fields: [actionId], references: [id], onDelete: Cascade)
  
  // Personalization
  isPinned          Boolean             @default(false)
  customShortcut    String?             // User's custom shortcut
  useCount          Int                 @default(0)
  lastUsedAt        DateTime?
  
  // Hide action for this user
  isHidden          Boolean             @default(false)
  
  @@unique([userId, actionId])
  @@index([userId])
}

// Search suggestions learned from user behavior
model SearchSuggestion {
  id                String              @id @default(uuid())
  
  // Can be global or per-user
  userId            String?
  user              User?               @relation("UserSearchSuggestions", fields: [userId], references: [id], onDelete: Cascade)
  
  // Suggestion
  phrase            String              // The search phrase
  targetType        String              // What type of thing it finds
  resultCount       Int                 @default(0) // Typical result count
  
  // Scoring
  globalScore       Float               @default(0) // Popularity across all users
  userScore         Float               @default(0) // This user's preference
  
  // Last seen
  lastUsedAt        DateTime            @default(now())
  
  @@unique([userId, phrase])
  @@index([phrase])
  @@index([globalScore])
}

// ============ SSS-015: Integration Automation Platform ============

// Workflow definition - the template for automation
model Workflow {
  id                String              @id @default(uuid())
  
  // Ownership
  createdById       String
  createdBy         User                @relation("WorkflowCreatedBy", fields: [createdById], references: [id])
  
  // Definition
  name              String
  description       String?
  code              String              @unique // "order_created_notify", "quote_approved_sync"
  category          WorkflowCategory
  
  // Trigger configuration
  triggerType       WorkflowTriggerType
  triggerEvent      String?             // Event name like "ORDER_CREATED", "QUOTE_APPROVED"
  triggerSchedule   String?             // Cron expression for scheduled triggers
  triggerWebhook    String?             // Webhook endpoint for external triggers
  triggerConditions Json?               // Conditions that must be met to fire
  
  // Steps (ordered list of actions)
  steps             WorkflowStep[]
  
  // Execution history
  executions        WorkflowExecution[]
  
  // Versioning
  version           Int                 @default(1)
  isPublished       Boolean             @default(false)
  publishedAt       DateTime?
  
  // Error handling
  maxRetries        Int                 @default(3)
  retryDelaySeconds Int                 @default(60)
  onErrorAction     WorkflowErrorAction @default(STOP)
  notifyOnError     Boolean             @default(true)
  errorNotifyEmails String[]
  
  // Status
  isActive          Boolean             @default(true)
  lastTriggeredAt   DateTime?
  successCount      Int                 @default(0)
  failureCount      Int                 @default(0)
  
  // Metadata
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([category])
  @@index([triggerType])
  @@index([isActive])
  @@index([code])
}

// Workflow categories
enum WorkflowCategory {
  NOTIFICATIONS     // Send emails, SMS, push notifications
  INTEGRATIONS      // Sync with external systems
  DATA_SYNC         // Sync data between internal systems
  AUTOMATION        // Internal automation tasks
  REPORTING         // Automated report generation
  MAINTENANCE       // System maintenance tasks
}

// Types of workflow triggers
enum WorkflowTriggerType {
  EVENT             // Triggered by system event
  SCHEDULE          // Triggered on schedule (cron)
  WEBHOOK           // Triggered by external webhook
  MANUAL            // Manually triggered by user
  CONDITION         // Triggered when condition becomes true
}

// What to do when workflow errors
enum WorkflowErrorAction {
  STOP              // Stop execution immediately
  CONTINUE          // Skip failed step, continue
  RETRY             // Retry failed step
  FALLBACK          // Execute fallback step
}

// Individual step in a workflow
model WorkflowStep {
  id                String              @id @default(uuid())
  
  // Parent workflow
  workflowId        String
  workflow          Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  // Step definition
  name              String
  description       String?
  stepOrder         Int                 // Order in workflow (1, 2, 3...)
  stepType          WorkflowStepType
  
  // Action configuration
  actionType        WorkflowActionType
  actionConfig      Json                // Action-specific configuration
  
  // Conditions
  conditions        Json?               // Conditions to execute this step
  skipOnCondition   Boolean             @default(false) // Skip if conditions not met vs fail
  
  // Timeout
  timeoutSeconds    Int                 @default(30)
  
  // Error handling (overrides workflow defaults)
  maxRetries        Int?
  retryDelaySeconds Int?
  onError           WorkflowErrorAction?
  
  // Branching
  nextStepOnSuccess String?             // Step ID to go to on success
  nextStepOnFailure String?             // Step ID to go to on failure
  
  // Execution logs for this step
  stepExecutions    WorkflowStepExecution[]
  
  // Metadata
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([workflowId])
  @@index([stepOrder])
}

// Types of workflow steps
enum WorkflowStepType {
  ACTION            // Execute an action
  CONDITION         // Branch based on condition
  DELAY             // Wait for specified time
  LOOP              // Loop over items
  PARALLEL          // Execute multiple actions in parallel
  TRANSFORM         // Transform data
  APPROVAL          // Wait for human approval
}

// Types of actions a step can perform
enum WorkflowActionType {
  // Notifications
  SEND_EMAIL        // Send email
  SEND_SMS          // Send SMS
  SEND_PUSH         // Send push notification
  SEND_WEBHOOK      // Call external webhook
  
  // Data operations
  CREATE_RECORD     // Create a new record
  UPDATE_RECORD     // Update existing record
  DELETE_RECORD     // Delete record
  QUERY_DATA        // Query data from database
  
  // External integrations
  SYNC_QUICKBOOKS   // Sync to QuickBooks
  SYNC_WOOCOMMERCE  // Sync to WooCommerce
  CALL_API          // Call external API
  
  // Internal operations
  ASSIGN_ORDER      // Assign order to user/station
  UPDATE_STATUS     // Update order/quote status
  GENERATE_DOCUMENT // Generate PDF/document
  RUN_REPORT        // Run and send report
  
  // Flow control
  WAIT              // Wait for specified time
  BRANCH            // Conditional branching
  MERGE             // Merge parallel branches
}

// Execution instance of a workflow
model WorkflowExecution {
  id                String              @id @default(uuid())
  
  // Workflow reference
  workflowId        String
  workflow          Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  // Trigger context
  triggeredBy       WorkflowTriggerType
  triggerData       Json?               // Data that triggered the workflow
  triggerEntityType String?             // "WorkOrder", "Quote", etc.
  triggerEntityId   String?             // ID of triggering entity
  
  // Execution state
  status            WorkflowExecutionStatus @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?
  currentStepId     String?             // Currently executing step
  
  // Step executions
  stepExecutions    WorkflowStepExecution[]
  
  // Results
  output            Json?               // Final output data
  error             String?             // Error message if failed
  errorDetails      Json?               // Detailed error info
  
  // Retry tracking
  attemptNumber     Int                 @default(1)
  nextRetryAt       DateTime?
  
  // Duration tracking
  durationMs        Int?
  
  // Metadata
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([workflowId])
  @@index([status])
  @@index([startedAt])
  @@index([triggerEntityType, triggerEntityId])
}

// Execution status
enum WorkflowExecutionStatus {
  PENDING           // Waiting to start
  RUNNING           // Currently executing
  WAITING           // Waiting for external input/approval
  PAUSED            // Manually paused
  COMPLETED         // Successfully completed
  FAILED            // Failed with error
  CANCELLED         // Manually cancelled
  RETRYING          // Waiting to retry
}

// Individual step execution within a workflow run
model WorkflowStepExecution {
  id                String              @id @default(uuid())
  
  // Parent execution
  executionId       String
  execution         WorkflowExecution   @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  // Step reference
  stepId            String
  step              WorkflowStep        @relation(fields: [stepId], references: [id], onDelete: Cascade)
  
  // Execution state
  status            WorkflowStepStatus  @default(PENDING)
  startedAt         DateTime?
  completedAt       DateTime?
  
  // Input/Output
  inputData         Json?               // Input to this step
  outputData        Json?               // Output from this step
  
  // Error handling
  error             String?
  errorDetails      Json?
  attemptNumber     Int                 @default(1)
  
  // Duration
  durationMs        Int?
  
  // Metadata
  createdAt         DateTime            @default(now())
  
  @@index([executionId])
  @@index([stepId])
  @@index([status])
}

// Step execution status
enum WorkflowStepStatus {
  PENDING           // Not yet started
  RUNNING           // Currently executing
  WAITING           // Waiting for approval/external
  SKIPPED           // Skipped due to conditions
  COMPLETED         // Successfully completed
  FAILED            // Failed with error
  RETRYING          // Waiting to retry
}

// Workflow template library (pre-built workflows)
model WorkflowTemplate {
  id                String              @id @default(uuid())
  
  // Template info
  name              String
  description       String
  code              String              @unique
  category          WorkflowCategory
  
  // Template definition
  definition        Json                // Full workflow definition
  
  // Usage stats
  useCount          Int                 @default(0)
  
  // Metadata
  isBuiltIn         Boolean             @default(false) // System-provided vs user-created
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([category])
  @@index([useCount])
}

// Workflow variable - reusable across workflows
model WorkflowVariable {
  id                String              @id @default(uuid())
  
  // Variable definition
  name              String              @unique
  description       String?
  variableType      WorkflowVariableType
  defaultValue      String?
  
  // Encryption for sensitive values
  isSecret          Boolean             @default(false)
  encryptedValue    String?
  
  // Scope
  isGlobal          Boolean             @default(true) // Available to all workflows
  workflowIds       String[]            // If not global, which workflows can use it
  
  // Metadata
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([isGlobal])
}

// Variable types
enum WorkflowVariableType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  SECRET            // Encrypted credential
  API_KEY           // API key (encrypted)
  CONNECTION_STRING // Database/service connection
}

// ============ CRITICAL-01: Data Integrity & Validation Foundation ============

// Soft delete tracking mixin (add to entities that need soft delete)
// Example: Add deletedAt/deletedBy to WorkOrder, Quote, Customer, etc.

// Data retention policy configuration
model DataRetentionPolicy {
  id                String              @id @default(uuid())
  
  // Target
  entityType        String              @unique // "WorkOrder", "Quote", "ActivityLog"
  
  // Retention rules
  retentionDays     Int                 // Days to retain before archival
  archiveDays       Int?                // Days in archive before deletion (null = forever)
  
  // Actions
  archiveAction     ArchiveAction       @default(ARCHIVE)
  purgeAction       PurgeAction         @default(SOFT_DELETE)
  
  // Exceptions
  keepIfHasChildren Boolean             @default(true) // Keep if related records exist
  keepIfActive      Boolean             @default(true) // Keep if status is active
  keepStatuses      String[]            // Statuses to never archive
  
  // Legal hold
  legalHoldField    String?             // Field name for legal hold flag
  
  // Schedule
  isEnabled         Boolean             @default(true)
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  
  // Metadata
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([entityType])
}

// What to do when archiving
enum ArchiveAction {
  ARCHIVE           // Move to archive table
  COMPRESS          // Compress and store
  EXPORT            // Export to file
  NONE              // Just mark as archived
}

// What to do when purging
enum PurgeAction {
  SOFT_DELETE       // Set deletedAt
  HARD_DELETE       // Actually delete
  ANONYMIZE         // Remove PII but keep record
}

// Optimistic locking version tracking
// Add "version Int @default(1)" to entities needing optimistic locking

// Record version history for critical entities
model RecordVersion {
  id                String              @id @default(uuid())
  
  // Entity reference
  entityType        String              // "WorkOrder", "Quote", etc.
  entityId          String
  version           Int                 // 1, 2, 3...
  
  // Change info
  changedById       String?
  changedBy         User?               @relation("RecordVersionChangedBy", fields: [changedById], references: [id])
  changeType        ChangeType
  changeReason      String?
  
  // Before/after data
  previousData      Json?               // Full record before change
  currentData       Json                // Full record after change
  changedFields     String[]            // List of changed fields
  
  // Metadata
  createdAt         DateTime            @default(now())
  
  @@unique([entityType, entityId, version])
  @@index([entityType, entityId])
  @@index([changedById])
  @@index([createdAt])
}

// Type of change
enum ChangeType {
  CREATE
  UPDATE
  DELETE
  RESTORE
  ARCHIVE
}

// Business key validation registry
model BusinessKeyRegistry {
  id                String              @id @default(uuid())
  
  // Key definition
  entityType        String              // "WorkOrder", "Quote", etc.
  keyField          String              // "orderNumber", "quoteNumber"
  prefix            String?             // "WO-", "Q-"
  
  // Sequence tracking
  lastSequence      Int                 @default(0)
  sequenceFormat    String              @default("{prefix}{year}{seq:5}") // WO-2026-00001
  
  // Validation
  pattern           String?             // Regex pattern for validation
  isUnique          Boolean             @default(true)
  
  // Metadata
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([entityType, keyField])
}

// Field-level constraint definitions
model FieldConstraint {
  id                String              @id @default(uuid())
  
  // Target
  entityType        String
  fieldName         String
  
  // Constraint type
  constraintType    FieldConstraintType
  
  // Constraint value (depends on type)
  minValue          Float?              // For MIN, RANGE
  maxValue          Float?              // For MAX, RANGE
  pattern           String?             // For PATTERN (regex)
  allowedValues     String[]            // For ENUM
  customValidator   String?             // For CUSTOM (function name)
  
  // Error handling
  errorMessage      String
  severity          ConstraintSeverity  @default(ERROR)
  
  // Status
  isEnabled         Boolean             @default(true)
  
  // Creator relation
  createdById       String?
  createdBy         User?               @relation("FieldConstraintCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([entityType, fieldName, constraintType])
  @@index([entityType])
  @@index([createdById])
}

// Types of field constraints
enum FieldConstraintType {
  MIN               // Minimum value
  MAX               // Maximum value
  RANGE             // Between min and max
  PATTERN           // Regex pattern
  ENUM              // Must be one of allowed values
  NOT_NULL          // Cannot be null
  NOT_EMPTY         // Cannot be empty string/array
  UNIQUE            // Must be unique
  CUSTOM            // Custom validation function
}

// Severity of constraint violation
enum ConstraintSeverity {
  WARNING           // Show warning but allow
  ERROR             // Block operation
  INFO              // Just log
}

// ============ VALIDATION RULES ============

// Dynamic validation rules that can be configured without code changes
model ValidationRule {
  id                String              @id @default(uuid())
  
  // Rule identification
  name              String              // "Quote requires customer"
  description       String?
  
  // Target entity
  entityType        String              // "Quote", "WorkOrder", etc.
  triggerEvent      ValidationTrigger   // When to run validation
  
  // Validation logic
  expression        String              // JS expression: "entity.customerId != null"
  conditionExpression String?           // When to apply: "entity.status !== 'DRAFT'"
  
  // Error handling
  errorMessage      String
  errorField        String?             // Which field to highlight
  severity          ValidationSeverity  @default(ERROR)
  
  // Priority for ordering
  priority          Int                 @default(0)
  
  // Status
  isEnabled         Boolean             @default(true)
  
  // Creator relation
  createdById       String?
  createdBy         User?               @relation("ValidationRuleCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([entityType])
  @@index([isEnabled])
  @@index([createdById])
}

// When validation is triggered
enum ValidationTrigger {
  BEFORE_CREATE     // Before insert
  AFTER_CREATE      // After insert
  BEFORE_UPDATE     // Before update
  AFTER_UPDATE      // After update
  BEFORE_DELETE     // Before delete
  ON_STATUS_CHANGE  // When status field changes
  CUSTOM            // Custom trigger
}

// Validation severity levels
enum ValidationSeverity {
  ERROR             // Block operation
  WARNING           // Allow but warn
  INFO              // Just log
}

// ============ DATA INTEGRITY CHECKS ============

// Scheduled integrity checks for data quality
model DataIntegrityCheck {
  id                String              @id @default(uuid())
  
  // Check identification
  name              String              // "Orphan line items check"
  description       String?
  category          String?             // "Referential", "Business Rules", etc.
  
  // Check definition
  entityType        String?             // Target entity (optional for cross-entity)
  checkQuery        String              // SQL or Prisma query to find violations
  expectedResult    String?             // What correct result looks like
  
  // Scheduling
  frequency         CheckFrequency      @default(DAILY)
  lastRunAt         DateTime?
  nextRunAt         DateTime?
  
  // Results
  lastStatus        IntegrityCheckStatus @default(PENDING)
  lastViolationCount Int                @default(0)
  lastErrorMessage  String?
  
  // Auto-fix capability
  canAutoFix        Boolean             @default(false)
  autoFixQuery      String?             // Query to auto-correct issues
  
  // Status
  isEnabled         Boolean             @default(true)
  
  // Creator relation
  createdById       String?
  createdBy         User?               @relation("IntegrityCheckCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Anomaly logs
  anomalyLogs       DataAnomalyLog[]    @relation("IntegrityCheckAnomalies")
  
  @@index([entityType])
  @@index([frequency])
  @@index([isEnabled])
  @@index([createdById])
}

// Check frequency schedule
enum CheckFrequency {
  REAL_TIME         // On every change
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  ON_DEMAND         // Manual trigger only
}

// Integrity check status
enum IntegrityCheckStatus {
  PENDING           // Not yet run
  RUNNING           // Currently executing
  PASSED            // All checks passed
  FAILED            // One or more failures
  SKIPPED           // Check was skipped
}

// ============ DATA ANOMALY LOGGING ============

// Log of detected data anomalies
model DataAnomalyLog {
  id                String              @id @default(uuid())
  
  // Source
  integrityCheckId  String?
  integrityCheck    DataIntegrityCheck? @relation("IntegrityCheckAnomalies", fields: [integrityCheckId], references: [id])
  
  // Anomaly details
  anomalyType       AnomalyType
  entityType        String
  entityId          String?
  fieldName         String?
  
  // Description
  description       String
  details           Json?               // Additional structured details
  
  // Severity and status
  severity          AnomalySeverity     @default(MEDIUM)
  status            AnomalyStatus       @default(DETECTED)
  
  // Resolution
  resolvedAt        DateTime?
  resolvedById      String?
  resolutionNotes   String?
  
  createdAt         DateTime            @default(now())
  
  @@index([anomalyType])
  @@index([entityType, entityId])
  @@index([status])
  @@index([integrityCheckId])
  @@index([createdAt])
}

// Types of data anomalies
enum AnomalyType {
  ORPHAN_RECORD           // Record with missing parent
  DUPLICATE               // Duplicate record detected
  CONSTRAINT_VIOLATION    // Business rule violation
  DATA_CORRUPTION         // Corrupted or invalid data
  MISSING_REQUIRED        // Required field is null
  REFERENTIAL_INTEGRITY   // FK violation
  RANGE_VIOLATION         // Value outside allowed range
  FORMAT_ERROR            // Wrong data format
  STALE_DATA              // Data not updated as expected
  CIRCULAR_REFERENCE      // Self-referencing loop
}

// Anomaly severity
enum AnomalySeverity {
  LOW               // Cosmetic or minor issue
  MEDIUM            // Should be fixed
  HIGH              // Causes problems
  CRITICAL          // Breaks functionality
}

// Anomaly resolution status
enum AnomalyStatus {
  DETECTED          // Just found
  ACKNOWLEDGED      // User saw it
  IN_PROGRESS       // Being fixed
  RESOLVED          // Fixed
  IGNORED           // Marked as acceptable
  FALSE_POSITIVE    // Not actually an issue
}

// ============ AUDIT & COMPLIANCE ============

// Comprehensive audit event for field-level change tracking
model AuditEvent {
  id                String              @id @default(uuid())
  
  // What happened
  eventType         AuditEventType
  category          AuditCategory       @default(DATA_CHANGE)
  
  // Target entity
  entityType        String              // "WorkOrder", "Quote", etc.
  entityId          String
  entityName        String?             // Human-readable name for logs
  
  // Who did it
  userId            String?
  user              User?               @relation("UserAuditEvents", fields: [userId], references: [id])
  userEmail         String?             // Denormalized for historical queries
  userRole          String?             // Role at time of action
  
  // Change details
  action            String              // CREATE, UPDATE, DELETE, VIEW, EXPORT
  fieldChanges      Json?               // Array of {field, oldValue, newValue}
  previousState     Json?               // Full entity before change
  newState          Json?               // Full entity after change
  
  // Context
  reason            String?             // Why the change was made
  comment           String?             // User-provided notes
  ticketReference   String?             // Related support ticket
  
  // Request context
  ipAddress         String?
  userAgent         String?
  sessionId         String?
  requestId         String?             // Correlation ID
  
  // Timestamps
  timestamp         DateTime            @default(now())
  processedAt       DateTime?           // When async processing completed
  
  // Retention
  retainUntil       DateTime?           // When this record can be purged
  isLegalHold       Boolean             @default(false)
  
  @@index([entityType, entityId])
  @@index([userId])
  @@index([eventType])
  @@index([category])
  @@index([timestamp])
  @@index([isLegalHold])
}

// Types of audit events
enum AuditEventType {
  // Data lifecycle
  CREATE
  READ
  UPDATE
  DELETE
  RESTORE
  ARCHIVE
  EXPORT
  IMPORT
  
  // Access events
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  PERMISSION_CHANGE
  
  // Business events
  APPROVAL
  REJECTION
  SIGNATURE
  SUBMISSION
  CANCELLATION
  STATUS_CHANGE
  
  // System events
  SYSTEM_CONFIG
  INTEGRATION_SYNC
  SCHEDULED_JOB
  ERROR
}

// Categories for filtering audit events
enum AuditCategory {
  DATA_CHANGE       // Normal CRUD operations
  SECURITY          // Authentication, authorization
  BUSINESS          // Workflow actions
  COMPLIANCE        // Regulatory actions
  SYSTEM            // System operations
  INTEGRATION       // External system events
}

// Electronic signature log for compliance
model SignatureLog {
  id                String              @id @default(uuid())
  
  // What was signed
  entityType        String
  entityId          String
  documentType      SignatureDocType
  documentVersion   Int                 @default(1)
  
  // Signer info
  signerId          String
  signer            User                @relation("UserSignatures", fields: [signerId], references: [id])
  signerName        String              // Denormalized
  signerEmail       String              // Denormalized
  signerTitle       String?             // Job title at time of signing
  
  // Signature details
  signatureType     SignatureType
  signatureValue    String?             // Hash or certificate reference
  signatureImage    String?             // Base64 or URL of signature image
  certificateId     String?             // Digital certificate ID
  
  // Verification
  isVerified        Boolean             @default(false)
  verifiedAt        DateTime?
  verificationMethod String?
  
  // Intent
  signatureIntent   String              // "I approve this quote", "I authorize this change"
  legalStatement    String?             // Legal text shown at signing
  
  // Context
  ipAddress         String?
  userAgent         String?
  geolocation       String?
  
  // Timestamps
  signedAt          DateTime            @default(now())
  expiresAt         DateTime?           // Some signatures have validity periods
  
  @@index([entityType, entityId])
  @@index([signerId])
  @@index([signedAt])
  @@index([documentType])
}

// Document types that require signatures
enum SignatureDocType {
  QUOTE             // Quote approval
  PURCHASE_ORDER    // PO authorization
  WORK_ORDER        // Work order approval
  CHANGE_ORDER      // Change request approval
  QUALITY_CHECK     // QC sign-off
  SHIPPING          // Shipping authorization
  INVOICE           // Invoice approval
  CONTRACT          // Contract signing
  TIME_ENTRY        // Timesheet approval
  EXPENSE           // Expense approval
}

// Types of signatures
enum SignatureType {
  TYPED             // Typed name
  DRAWN             // Mouse/touch drawn
  UPLOADED          // Uploaded image
  DIGITAL           // PKI certificate
  BIOMETRIC         // Fingerprint/face
  PIN               // PIN verification
}

// Compliance rules for automated checks
model ComplianceRule {
  id                String              @id @default(uuid())
  
  // Rule identification
  name              String
  code              String              @unique
  description       String?
  
  // Category
  category          ComplianceCategory
  regulation        String?             // "GDPR", "SOX", "HIPAA"
  
  // Rule definition
  entityType        String?             // Which entities to check
  checkExpression   String              // JS expression for validation
  severity          ComplianceSeverity
  
  // Actions
  onViolation       ComplianceAction    @default(ALERT)
  alertRecipients   String[]            // User IDs or emails to notify
  blockingLevel     Int                 @default(0) // 0=warn, 1=soft block, 2=hard block
  
  // Schedule
  checkFrequency    CheckFrequency      @default(REAL_TIME)
  lastCheckedAt     DateTime?
  
  // Status
  isEnabled         Boolean             @default(true)
  effectiveFrom     DateTime?
  effectiveUntil    DateTime?
  
  // Audit
  createdById       String?
  createdBy         User?               @relation("ComplianceRuleCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Violation records
  violations        ComplianceViolation[] @relation("RuleViolations")
  
  @@index([category])
  @@index([entityType])
  @@index([isEnabled])
}

// Compliance categories
enum ComplianceCategory {
  DATA_PRIVACY      // GDPR, CCPA
  FINANCIAL         // SOX, financial controls
  SAFETY            // Workplace safety
  QUALITY           // ISO, quality standards
  SECURITY          // Cybersecurity compliance
  INDUSTRY          // Industry-specific regs
  INTERNAL          // Company policies
}

// Severity of compliance violations
enum ComplianceSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// What to do on compliance violation
enum ComplianceAction {
  LOG               // Just log it
  ALERT             // Send notification
  BLOCK             // Prevent action
  ESCALATE          // Notify management
  QUARANTINE        // Isolate the record
}

// Record of compliance violations
model ComplianceViolation {
  id                String              @id @default(uuid())
  
  // Which rule was violated
  ruleId            String
  rule              ComplianceRule      @relation("RuleViolations", fields: [ruleId], references: [id])
  
  // What entity violated
  entityType        String
  entityId          String
  fieldName         String?
  
  // Violation details
  description       String
  violationData     Json?               // The actual violating data
  severity          ComplianceSeverity
  
  // Status
  status            ViolationStatus     @default(OPEN)
  
  // Resolution
  resolvedById      String?
  resolvedAt        DateTime?
  resolution        String?
  remediation       String?             // Actions taken to fix
  
  // Evidence
  evidenceUrls      String[]
  
  createdAt         DateTime            @default(now())
  
  @@index([ruleId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
}

// Status of compliance violations
enum ViolationStatus {
  OPEN
  ACKNOWLEDGED
  IN_REMEDIATION
  RESOLVED
  WAIVED
  FALSE_POSITIVE
}

// RetentionBasis and ExpiryAction enums for data retention
enum RetentionBasis {
  LEGAL_REQUIREMENT   // Required by law
  BUSINESS_NEED       // Needed for operations
  CONSENT             // User consented
  CONTRACT            // Part of contract obligation
  LEGITIMATE_INTEREST // Legitimate business interest
}

enum ExpiryAction {
  DELETE            // Hard delete
  ANONYMIZE         // Remove PII but keep record
  ARCHIVE           // Move to cold storage
  REVIEW            // Flag for manual review
}

// Security access log
model AccessLog {
  id                String              @id @default(uuid())
  
  // Who accessed
  userId            String?
  user              User?               @relation("UserAccessLogs", fields: [userId], references: [id])
  userEmail         String?             // Denormalized
  sessionId         String?
  
  // What was accessed
  resourceType      String              // "WorkOrder", "Report", "API"
  resourceId        String?
  resourceName      String?
  
  // Access details
  accessType        AccessType
  accessMethod      String?             // "WEB", "API", "MOBILE"
  endpoint          String?             // API endpoint if applicable
  queryParams       Json?               // Request parameters
  
  // Result
  wasSuccessful     Boolean             @default(true)
  failureReason     String?
  dataVolume        Int?                // Records accessed/returned
  
  // Context
  ipAddress         String?
  userAgent         String?
  geolocation       String?
  deviceId          String?
  
  // Risk assessment
  riskScore         Int?                // 0-100, higher = more suspicious
  riskFactors       String[]            // ["unusual_time", "new_device", "bulk_export"]
  flaggedForReview  Boolean             @default(false)
  
  timestamp         DateTime            @default(now())
  
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([accessType])
  @@index([timestamp])
  @@index([flaggedForReview])
  @@index([riskScore])
}

// Types of access
enum AccessType {
  VIEW              // Read single record
  LIST              // List/search records
  EXPORT            // Export data
  DOWNLOAD          // Download file
  PRINT             // Print
  SHARE             // Share with others
  API_CALL          // API access
}

// ============ MULTI-TENANCY & ORGANIZATION ============

// Organization/tenant for multi-company support
model Organization {
  id                String              @id @default(uuid())
  
  // Basic info
  name              String
  legalName         String?             // Full legal name
  code              String              @unique // Short code "WILDE", "ACME"
  slug              String              @unique // URL-friendly slug
  
  // Type
  orgType           OrganizationType    @default(COMPANY)
  parentId          String?             // For hierarchical orgs
  parent            Organization?       @relation("OrgHierarchy", fields: [parentId], references: [id])
  children          Organization[]      @relation("OrgHierarchy")
  
  // Contact info
  email             String?
  phone             String?
  website           String?
  
  // Address
  address1          String?
  address2          String?
  city              String?
  state             String?
  postalCode        String?
  country           String              @default("US")
  
  // Business info
  taxId             String?             // EIN, VAT number
  industry          String?
  timezone          String              @default("America/Chicago")
  currency          String              @default("USD")
  fiscalYearStart   Int                 @default(1) // Month 1-12
  
  // Branding
  logoUrl           String?
  primaryColor      String?             // Hex color
  
  // Subscription/Limits
  subscriptionTier  SubscriptionTier    @default(BASIC)
  maxUsers          Int                 @default(10)
  maxLocations      Int                 @default(1)
  
  // Status
  status            OrgStatus           @default(ACTIVE)
  activatedAt       DateTime?
  suspendedAt       DateTime?
  suspendReason     String?
  
  // Feature flags
  features          String[]            // Enabled feature codes
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  locations         Location[]          @relation("OrgLocations")
  departments       Department[]        @relation("OrgDepartments")
  teams             Team[]              @relation("OrgTeams")
  settings          OrganizationSetting[] @relation("OrgSettings")
  users             OrganizationUser[]  @relation("OrgUsers")
  
  @@index([code])
  @@index([status])
  @@index([parentId])
}

// Organization types
enum OrganizationType {
  COMPANY           // Main company
  DIVISION          // Business division
  SUBSIDIARY        // Subsidiary company
  FRANCHISE         // Franchise location
  PARTNER           // Partner organization
}

// Organization status
enum OrgStatus {
  PENDING           // Awaiting activation
  ACTIVE            // Active and operational
  SUSPENDED         // Temporarily suspended
  INACTIVE          // Deactivated
  ARCHIVED          // Archived for records
}

// Subscription tiers
enum SubscriptionTier {
  FREE              // Free tier
  BASIC             // Basic paid
  PROFESSIONAL      // Pro tier
  ENTERPRISE        // Enterprise tier
  CUSTOM            // Custom agreement
}

// Physical location for multi-site operations
model Location {
  id                String              @id @default(uuid())
  
  // Organization
  organizationId    String
  organization      Organization        @relation("OrgLocations", fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Basic info
  name              String              // "Main Shop", "Warehouse #2"
  code              String              // Short code "MAIN", "WH2"
  locationType      LocationType        @default(PRODUCTION)
  
  // Address
  address1          String
  address2          String?
  city              String
  state             String
  postalCode        String
  country           String              @default("US")
  latitude          Float?
  longitude         Float?
  
  // Contact
  phone             String?
  email             String?
  managerUserId     String?             // Location manager
  
  // Operations
  timezone          String              @default("America/Chicago")
  operatingHours    Json?               // {mon: {open: "08:00", close: "17:00"}, ...}
  isHeadquarters    Boolean             @default(false)
  
  // Capacity
  squareFootage     Float?
  maxCapacity       Int?                // Max concurrent orders
  
  // Status
  isActive          Boolean             @default(true)
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  departments       Department[]        @relation("LocationDepartments")
  teams             Team[]              @relation("LocationTeams")
  
  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([locationType])
  @@index([isActive])
}

// Location types
enum LocationType {
  PRODUCTION        // Manufacturing facility
  WAREHOUSE         // Storage/distribution
  OFFICE            // Office only
  RETAIL            // Retail storefront
  HYBRID            // Mixed use
}

// Department for cost center tracking
model Department {
  id                String              @id @default(uuid())
  
  // Organization
  organizationId    String
  organization      Organization        @relation("OrgDepartments", fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Optional location
  locationId        String?
  location          Location?           @relation("LocationDepartments", fields: [locationId], references: [id])
  
  // Basic info
  name              String              // "Production", "Sales", "Admin"
  code              String              // "PROD", "SALES", "ADMIN"
  description       String?
  
  // Hierarchy
  parentId          String?
  parent            Department?         @relation("DeptHierarchy", fields: [parentId], references: [id])
  children          Department[]        @relation("DeptHierarchy")
  
  // Financial
  costCenterCode    String?             // GL cost center code
  budgetCode        String?             // Budget code
  annualBudget      Float?              // Annual budget amount
  
  // Management
  managerUserId     String?             // Department head
  
  // Status
  isActive          Boolean             @default(true)
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  teams             Team[]              @relation("DeptTeams")
  members           DepartmentMember[]  @relation("DeptMembers")
  
  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([locationId])
  @@index([parentId])
  @@index([isActive])
}

// Department membership
model DepartmentMember {
  id                String              @id @default(uuid())
  departmentId      String
  department        Department          @relation("DeptMembers", fields: [departmentId], references: [id], onDelete: Cascade)
  userId            String
  user              User                @relation("UserDepartments", fields: [userId], references: [id], onDelete: Cascade)
  role              DeptMemberRole      @default(MEMBER)
  isPrimary         Boolean             @default(false) // Primary department
  joinedAt          DateTime            @default(now())
  
  @@unique([departmentId, userId])
  @@index([userId])
}

// Department member roles
enum DeptMemberRole {
  MEMBER
  LEAD
  MANAGER
  HEAD
}

// Team for work group assignments
model Team {
  id                String              @id @default(uuid())
  
  // Organization
  organizationId    String
  organization      Organization        @relation("OrgTeams", fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Optional location/department
  locationId        String?
  location          Location?           @relation("LocationTeams", fields: [locationId], references: [id])
  departmentId      String?
  department        Department?         @relation("DeptTeams", fields: [departmentId], references: [id])
  
  // Basic info
  name              String              // "Install Crew A", "Print Team"
  code              String
  description       String?
  teamType          TeamType            @default(PRODUCTION)
  
  // Capacity
  maxMembers        Int?
  targetCapacity    Float?              // Target hours/week
  
  // Lead
  leadUserId        String?             // Team lead
  
  // Status
  isActive          Boolean             @default(true)
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  members           TeamMember[]        @relation("TeamMembers")
  
  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([locationId])
  @@index([departmentId])
  @@index([teamType])
  @@index([isActive])
}

// Team types
enum TeamType {
  PRODUCTION        // Production crew
  INSTALLATION      // Install team
  SALES             // Sales team
  SUPPORT           // Customer support
  ADMIN             // Administrative
  CROSS_FUNCTIONAL  // Cross-department
}

// Team membership
model TeamMember {
  id                String              @id @default(uuid())
  teamId            String
  team              Team                @relation("TeamMembers", fields: [teamId], references: [id], onDelete: Cascade)
  userId            String
  user              User                @relation("UserTeams", fields: [userId], references: [id], onDelete: Cascade)
  role              TeamMemberRole      @default(MEMBER)
  allocation        Float               @default(100) // Percentage allocated to this team
  joinedAt          DateTime            @default(now())
  
  @@unique([teamId, userId])
  @@index([userId])
}

// Team member roles
enum TeamMemberRole {
  MEMBER
  SENIOR
  LEAD
}

// Organization-user relationship (for multi-org users)
model OrganizationUser {
  id                String              @id @default(uuid())
  organizationId    String
  organization      Organization        @relation("OrgUsers", fields: [organizationId], references: [id], onDelete: Cascade)
  userId            String
  user              User                @relation("UserOrganizations", fields: [userId], references: [id], onDelete: Cascade)
  role              OrgUserRole         @default(MEMBER)
  isPrimaryOrg      Boolean             @default(false)
  invitedById       String?
  joinedAt          DateTime            @default(now())
  
  @@unique([organizationId, userId])
  @@index([userId])
}

// Org-level user roles
enum OrgUserRole {
  OWNER             // Organization owner
  ADMIN             // Org admin
  MANAGER           // Manager
  MEMBER            // Regular member
  GUEST             // Guest/limited access
}

// Per-organization settings
model OrganizationSetting {
  id                String              @id @default(uuid())
  
  organizationId    String
  organization      Organization        @relation("OrgSettings", fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Setting definition
  category          SettingCategory
  key               String              // "workOrder.autoAssign", "email.fromName"
  value             String              // JSON-encoded value
  valueType         SettingValueType    @default(STRING)
  
  // Metadata
  description       String?
  isSecret          Boolean             @default(false) // Encrypt in storage
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([organizationId, key])
  @@index([organizationId, category])
}

// Setting categories
enum SettingCategory {
  GENERAL           // General settings
  BRANDING          // Brand/appearance
  WORKFLOW          // Workflow rules
  NOTIFICATIONS     // Notification preferences
  INTEGRATIONS      // Integration configs
  BILLING           // Billing settings
  SECURITY          // Security settings
  FEATURES          // Feature toggles
}

// Setting value types
enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  SECRET            // Encrypted value
}

// ============ FINANCIAL TRACKING & COST ACCOUNTING ============

// Cost center for GL mapping and expense tracking
model CostCenter {
  id                String              @id @default(uuid())
  
  // Organization
  organizationId    String?
  
  // Basic info
  code              String              @unique // "10-400", "PROD-01"
  name              String              // "Production Department", "Marketing"
  description       String?
  
  // GL mapping
  glAccountCode     String?             // General ledger account
  glSubAccount      String?             // Sub-account code
  
  // Hierarchy
  parentId          String?
  parent            CostCenter?         @relation("CostCenterHierarchy", fields: [parentId], references: [id])
  children          CostCenter[]        @relation("CostCenterHierarchy")
  
  // Type
  centerType        CostCenterType      @default(EXPENSE)
  
  // Budget
  annualBudget      Float?
  budgetPeriod      BudgetPeriod        @default(ANNUAL)
  
  // Allocation rules
  allocationMethod  AllocationMethod?   // How to allocate overhead
  allocationBasis   String?             // "DirectLabor", "SquareFeet", etc.
  
  // Status
  isActive          Boolean             @default(true)
  effectiveFrom     DateTime?
  effectiveUntil    DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  laborCosts        LaborCostActual[]   @relation("CostCenterLabor")
  materialCosts     MaterialCost[]      @relation("CostCenterMaterials")
  overheadAllocations OverheadAllocation[] @relation("CostCenterOverhead")
  
  @@index([code])
  @@index([glAccountCode])
  @@index([parentId])
  @@index([isActive])
}

// Cost center types
enum CostCenterType {
  REVENUE           // Revenue-generating
  EXPENSE           // Expense only
  PROFIT            // Both revenue and expense
  SERVICE           // Internal service department
  OVERHEAD          // Overhead/indirect
}

// Budget periods
enum BudgetPeriod {
  MONTHLY
  QUARTERLY
  ANNUAL
  PROJECT           // Per-project budget
}

// Overhead allocation methods
enum AllocationMethod {
  DIRECT            // Direct assignment
  LABOR_HOURS       // Based on labor hours
  MACHINE_HOURS     // Based on machine hours
  SQUARE_FOOTAGE    // Based on space used
  HEADCOUNT         // Based on employee count
  REVENUE           // Based on revenue
  EQUAL             // Split equally
}

// Material cost tracking at order level
model MaterialCost {
  id                String              @id @default(uuid())
  
  // Order reference
  workOrderId       String
  workOrder         WorkOrder           @relation("WorkOrderMaterialCosts", fields: [workOrderId], references: [id], onDelete: Cascade)
  lineItemId        String?             // Optional link to specific line item
  
  // Cost center
  costCenterId      String?
  costCenter        CostCenter?         @relation("CostCenterMaterials", fields: [costCenterId], references: [id])
  
  // Material info
  materialType      MaterialType
  description       String
  itemMasterId      String?             // Link to inventory item
  vendorId          String?
  purchaseOrderId   String?
  
  // Quantities
  quantityUsed      Float
  quantityUnit      String              // "sqft", "sheets", "lbs"
  quantityWasted    Float               @default(0)
  wasteReason       String?
  
  // Costs
  unitCost          Float
  totalCost         Float               // quantityUsed * unitCost
  wasteCost         Float               @default(0) // quantityWasted * unitCost
  
  // Pricing (for margin calculation)
  chargedAmount     Float?              // What customer was charged
  
  // Tracking
  usedAt            DateTime            @default(now())
  recordedById      String?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([workOrderId])
  @@index([costCenterId])
  @@index([materialType])
  @@index([usedAt])
}

// Types of materials
enum MaterialType {
  SUBSTRATE         // Print substrates (vinyl, paper, etc.)
  INK               // Inks and toners
  LAMINATE          // Laminates and overlays
  HARDWARE          // Mounting hardware
  PACKAGING         // Packaging materials
  SUPPLIES          // Consumable supplies
  OTHER
}

// Labor cost tracking with time-based calculation
model LaborCostActual {
  id                String              @id @default(uuid())
  
  // Order reference
  workOrderId       String
  workOrder         WorkOrder           @relation("WorkOrderLaborCosts", fields: [workOrderId], references: [id], onDelete: Cascade)
  
  // Cost center
  costCenterId      String?
  costCenter        CostCenter?         @relation("CostCenterLabor", fields: [costCenterId], references: [id])
  
  // Worker
  userId            String
  user              User                @relation("UserLaborCosts", fields: [userId], references: [id])
  
  // Time details
  station           PrintingMethod?
  activity          LaborActivity
  description       String?
  
  // Hours
  startTime         DateTime
  endTime           DateTime?
  regularHours      Float               @default(0)
  overtimeHours     Float               @default(0)
  
  // Rates (at time of work - denormalized)
  regularRate       Float               // $/hour regular
  overtimeRate      Float               // $/hour overtime
  burdenRate        Float               @default(0) // Benefits, taxes, etc.
  
  // Calculated costs
  laborCost         Float               // (regularHours * regularRate) + (overtimeHours * overtimeRate)
  burdenCost        Float               // Total hours * burdenRate
  totalCost         Float               // laborCost + burdenCost
  
  // Billing
  isBillable        Boolean             @default(true)
  billedAmount      Float?              // What customer was charged
  billingRate       Float?              // Rate charged to customer
  
  // Approval
  status            LaborCostStatus     @default(PENDING)
  approvedById      String?
  approvedAt        DateTime?
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([workOrderId])
  @@index([userId])
  @@index([costCenterId])
  @@index([startTime])
  @@index([status])
}

// Types of labor activities
enum LaborActivity {
  SETUP             // Machine setup
  PRODUCTION        // Actual production
  FINISHING         // Post-production finishing
  PACKAGING         // Packaging
  QUALITY_CHECK     // QC inspection
  REWORK            // Fixing issues
  MAINTENANCE       // Equipment maintenance
  ADMIN             // Administrative
}

// Labor cost approval status
enum LaborCostStatus {
  PENDING           // Awaiting approval
  APPROVED          // Approved for payroll/billing
  REJECTED          // Rejected - needs correction
  BILLED            // Included in invoice
}

// Overhead allocation for indirect cost distribution
model OverheadAllocation {
  id                String              @id @default(uuid())
  
  // Source
  fromCostCenterId  String
  fromCostCenter    CostCenter          @relation("CostCenterOverhead", fields: [fromCostCenterId], references: [id])
  
  // Target (where overhead is allocated TO)
  workOrderId       String?
  workOrder         WorkOrder?          @relation("WorkOrderOverhead", fields: [workOrderId], references: [id])
  
  // Period
  periodStart       DateTime
  periodEnd         DateTime
  
  // Allocation
  allocationMethod  AllocationMethod
  allocationBasis   String?             // What measure was used
  basisValue        Float?              // Value of the basis (hours, sqft, etc.)
  totalPoolValue    Float?              // Total pool for the period
  
  // Amount
  amount            Float               // Allocated amount
  
  // Category
  category          OverheadCategory
  
  createdAt         DateTime            @default(now())
  
  @@index([fromCostCenterId])
  @@index([workOrderId])
  @@index([periodStart, periodEnd])
  @@index([category])
}

// Overhead categories
enum OverheadCategory {
  FACILITY          // Rent, utilities, maintenance
  EQUIPMENT         // Equipment depreciation
  INSURANCE         // Insurance costs
  ADMINISTRATIVE    // Admin overhead
  MANAGEMENT        // Management costs
  IT                // IT/technology costs
  OTHER
}

// Profitability snapshot for point-in-time margin tracking
model ProfitabilitySnapshot {
  id                String              @id @default(uuid())
  
  // Reference
  entityType        ProfitEntityType
  entityId          String              // WorkOrder, Quote, Customer ID
  
  // Period
  snapshotDate      DateTime            @default(now())
  periodStart       DateTime?
  periodEnd         DateTime?
  
  // Revenue
  grossRevenue      Float               // Total invoiced/quoted
  discounts         Float               @default(0)
  netRevenue        Float               // After discounts
  
  // Direct costs
  materialCost      Float               @default(0)
  laborCost         Float               @default(0)
  outsourcedCost    Float               @default(0)
  shippingCost      Float               @default(0)
  totalDirectCost   Float               // Sum of direct costs
  
  // Margins
  grossProfit       Float               // netRevenue - totalDirectCost
  grossMarginPct    Float               // grossProfit / netRevenue * 100
  
  // Allocated overhead
  overheadAllocation Float              @default(0)
  
  // Net
  operatingProfit   Float               // grossProfit - overheadAllocation
  operatingMarginPct Float              // operatingProfit / netRevenue * 100
  
  // Comparison
  estimatedProfit   Float?              // Original estimate
  varianceAmount    Float?              // Actual vs estimated
  variancePct       Float?              // Variance percentage
  
  // Analysis
  profitabilityTier ProfitabilityTier?
  notes             String?
  
  createdAt         DateTime            @default(now())
  
  @@index([entityType, entityId])
  @@index([snapshotDate])
  @@index([profitabilityTier])
}

// Entity types for profitability tracking
enum ProfitEntityType {
  WORK_ORDER
  QUOTE
  CUSTOMER
  PRODUCT
  STATION
  PERIOD            // Monthly/quarterly summary
}

// Profitability classification
enum ProfitabilityTier {
  EXCELLENT         // > 40% margin
  GOOD              // 25-40% margin
  ACCEPTABLE        // 15-25% margin
  MARGINAL          // 5-15% margin
  LOSS              // < 5% margin
}

// ============================================================================
// CRITICAL-05: ADVANCED SCHEDULING & CAPACITY PLANNING
// ============================================================================

// Resource type enum
enum ResourceType {
  EQUIPMENT         // Printers, cutters, etc.
  WORKSTATION       // Physical work areas
  VEHICLE           // Installation vehicles
  OPERATOR          // Human resources
  TOOL              // Specialized tools
}

// Calendar event type
enum CalendarEventType {
  AVAILABLE         // Normal working hours
  UNAVAILABLE       // Blocked time
  MAINTENANCE       // Scheduled maintenance
  HOLIDAY           // Company holiday
  VACATION          // Personal time off
  TRAINING          // Training/education
  SETUP             // Equipment setup
  BUFFER            // Buffer time between jobs
}

// Recurrence pattern
enum RecurrencePattern {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
  CUSTOM
}

// Resource calendar for equipment/operator availability
model ResourceCalendar {
  id              String              @id @default(uuid())
  organizationId  String?
  
  // Resource identification
  resourceType    ResourceType
  resourceId      String              // FK to equipment, user, etc.
  resourceName    String              // Denormalized for quick display
  
  // Time slot
  title           String?
  eventType       CalendarEventType
  startTime       DateTime
  endTime         DateTime
  allDay          Boolean             @default(false)
  
  // Recurrence
  isRecurring     Boolean             @default(false)
  recurrencePattern RecurrencePattern?
  recurrenceEndDate DateTime?
  recurrenceExceptions Json?          // Dates to skip
  parentEventId   String?             // For recurring instances
  
  // Capacity
  availableCapacity Float?            // 0-100% availability during slot
  notes           String?
  
  // Metadata
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  parentEvent     ResourceCalendar?   @relation("RecurringEvents", fields: [parentEventId], references: [id])
  childEvents     ResourceCalendar[]  @relation("RecurringEvents")
  
  @@index([resourceType, resourceId])
  @@index([startTime, endTime])
  @@index([eventType])
  @@index([organizationId])
}

// Capacity plan for forward-looking capacity modeling
model CapacityPlan {
  id              String              @id @default(uuid())
  organizationId  String?
  locationId      String?
  
  // Plan identification
  name            String
  description     String?
  
  // Time horizon
  periodStart     DateTime
  periodEnd       DateTime
  granularity     CapacityGranularity
  
  // Status
  status          CapacityPlanStatus  @default(DRAFT)
  approvedById    String?
  approvedAt      DateTime?
  
  // Metadata
  createdById     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  periods         CapacityPeriod[]
  
  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([organizationId])
}

// Capacity plan granularity
enum CapacityGranularity {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

// Capacity plan status
enum CapacityPlanStatus {
  DRAFT
  ACTIVE
  APPROVED
  ARCHIVED
}

// Individual capacity period within a plan
model CapacityPeriod {
  id              String              @id @default(uuid())
  planId          String
  
  // Period timing
  periodStart     DateTime
  periodEnd       DateTime
  
  // Resource
  resourceType    ResourceType
  resourceId      String
  station         PrintingMethod?     // If applicable
  
  // Capacity metrics (in hours)
  totalCapacity   Float               // Total available hours
  allocatedCapacity Float             @default(0) // Already scheduled
  reservedCapacity Float              @default(0) // Tentatively reserved
  availableCapacity Float             // totalCapacity - allocated - reserved
  
  // Demand metrics
  forecastedDemand Float              @default(0)
  actualDemand     Float              @default(0)
  
  // Utilization
  targetUtilization Float             @default(80) // Target %
  projectedUtilization Float?         // Calculated
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  plan            CapacityPlan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  @@index([planId])
  @@index([resourceType, resourceId])
  @@index([periodStart, periodEnd])
}

// Setup time model for accurate changeover tracking
model SetupTime {
  id              String              @id @default(uuid())
  organizationId  String?
  
  // Equipment/Station
  resourceType    ResourceType        @default(EQUIPMENT)
  resourceId      String?             // Specific equipment, null = all
  station         PrintingMethod
  
  // Transition details
  fromProductType String?             // Product category/type
  toProductType   String?
  fromMaterial    String?             // Material type
  toMaterial      String?
  
  // Time values (in minutes)
  setupTimeMinutes Int                // Base setup time
  teardownTimeMinutes Int             @default(0)
  cleanupTimeMinutes Int              @default(0)
  totalMinutes    Int                 // Calculated total
  
  // Variability
  minMinutes      Int?                // Optimistic
  maxMinutes      Int?                // Pessimistic
  
  // Requires
  requiresOperatorSkill String?       // Skill level needed
  requiresTools   Json?               // Tool list
  notes           String?
  
  // Tracking
  lastUsed        DateTime?
  useCount        Int                 @default(0)
  
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([station])
  @@index([resourceType, resourceId])
  @@index([fromProductType, toProductType])
}

// Skill level enum
enum SkillLevel {
  TRAINEE           // Learning
  BASIC             // Can perform under supervision
  PROFICIENT        // Can perform independently
  ADVANCED          // Can handle complex work
  EXPERT            // Can train others
}

// Skill matrix for operator-to-task capability mapping
model SkillMatrix {
  id              String              @id @default(uuid())
  userId          String
  organizationId  String?
  
  // Skill identification
  station         PrintingMethod?     // Station/department
  skillCategory   String              // Category within station
  skillName       String
  
  // Proficiency
  skillLevel      SkillLevel
  certifiedDate   DateTime?
  expirationDate  DateTime?           // If certification expires
  
  // Capacity impact
  efficiencyFactor Float              @default(1.0) // 0.5 = 50% slower, 1.5 = 50% faster
  qualityFactor   Float               @default(1.0) // Quality rating
  
  // Training
  trainingRequired Boolean            @default(false)
  trainingNotes   String?
  mentorId        String?             // User who can train
  
  // Validation
  assessedById    String?
  assessedAt      DateTime?
  assessmentNotes String?
  nextAssessmentDate DateTime?
  
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  // Relations
  user            User                @relation("UserSkillMatrix", fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, station, skillName])
  @@index([userId])
  @@index([station])
  @@index([skillLevel])
  @@index([organizationId])
}

// Schedule conflict type
enum ScheduleConflictType {
  RESOURCE_DOUBLE_BOOKED
  CAPACITY_EXCEEDED
  SKILL_UNAVAILABLE
  MATERIAL_SHORTAGE
  DEPENDENCY_VIOLATION
  DEADLINE_IMPOSSIBLE
  MAINTENANCE_OVERLAP
  PRIORITY_CONFLICT
}

// Conflict resolution status
enum ConflictResolutionStatus {
  DETECTED
  ACKNOWLEDGED
  RESOLVING
  RESOLVED
  IGNORED
  ESCALATED
}

// Schedule conflict detection and resolution tracking
model ScheduleConflict {
  id              String              @id @default(uuid())
  organizationId  String?
  
  // Conflict identification
  conflictType    ScheduleConflictType
  severity        AlertSeverity       @default(MEDIUM)
  
  // Affected entities
  primaryEntityType String            // e.g., 'WorkOrder', 'ScheduleSlot'
  primaryEntityId   String
  secondaryEntityType String?
  secondaryEntityId String?
  
  // Time context
  conflictStart   DateTime
  conflictEnd     DateTime
  
  // Details
  description     String
  impact          String?             // Business impact description
  suggestedResolutions Json?          // Array of possible resolutions
  
  // Resolution
  status          ConflictResolutionStatus @default(DETECTED)
  resolutionMethod String?
  resolutionNotes String?
  resolvedById    String?
  resolvedAt      DateTime?
  
  // Auto-detection
  detectedById    String?             // User or 'SYSTEM'
  detectedAt      DateTime            @default(now())
  
  // Tracking
  acknowledgedById String?
  acknowledgedAt  DateTime?
  escalatedTo     String?
  escalatedAt     DateTime?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@index([conflictType])
  @@index([status])
  @@index([severity])
  @@index([primaryEntityType, primaryEntityId])
  @@index([conflictStart, conflictEnd])
  @@index([organizationId])
}

