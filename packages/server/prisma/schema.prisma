// Prisma Schema for ERP Workflow
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ Users ============

model User {
  id              String           @id @default(uuid())
  username        String           @unique
  passwordHash    String
  displayName     String
  email           String?          @unique
  role            UserRole         @default(OPERATOR)
  isActive        Boolean          @default(true)
  allowedStations PrintingMethod[]
  profilePhoto    String? // URL to profile photo
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  createdOrders           WorkOrder[]           @relation("CreatedBy")
  assignedOrders          WorkOrder[]           @relation("AssignedTo")
  completedStations       StationProgress[]     @relation("CompletedBy")
  events                  WorkEvent[]
  timeEntries             TimeEntry[]
  reprintRequests         ReprintRequest[]      @relation("RequestedBy")
  resolvedReprints        ReprintRequest[]      @relation("ResolvedBy")
  createdTemplates        OrderTemplate[]
  uploadedAttachments     OrderAttachment[]
  createdQuotes           Quote[]               @relation("QuoteCreatedBy")
  assignedQuotes          Quote[]               @relation("QuoteAssignedTo")
  workSchedules           WorkSchedule[]
  timeOffRequests         TimeOffRequest[]
  notifications           Notification[]
  activityLogs            ActivityLog[]
  createdPOs              PurchaseOrder[]       @relation("POCreatedBy")
  receivedPOs             POReceipt[]           @relation("POReceivedBy")
  createdShipments        Shipment[]            @relation("ShipmentCreatedBy")
  materialUsages          MaterialUsage[]       @relation("MaterialRecordedBy")
  qcInspections           QCInspection[]        @relation("QCInspectedBy")
  maintenanceLogs         MaintenanceLog[]      @relation("MaintenancePerformedBy")
  downtimeReported        DowntimeEvent[]       @relation("DowntimeReportedBy")
  downtimeResolved        DowntimeEvent[]       @relation("DowntimeResolvedBy")
  customerInteractions    CustomerInteraction[] @relation("InteractionCreatedBy")
  portalMessages          PortalMessage[]       @relation("PortalMessageFrom")
  productionSlotsAssigned ProductionSlot[]      @relation("ProductionAssignee")
  productionSlotsCreated  ProductionSlot[]      @relation("ProductionCreator")
  creditRequestedBy       CreditApproval[]      @relation("CreditRequestedBy")
  creditApprovedBy        CreditApproval[]      @relation("CreditApprovedBy")
  subcontractJobs         SubcontractJob[]      @relation("SubcontractCreatedBy")
  uploadedDocuments       Document[]

  // Installation/Field Service relations
  installerAssignments InstallerAssignment[]
  installerSchedules   InstallerSchedule[]
  installPhotos        InstallPhoto[]
  installEvents        InstallEvent[]

  // Webhook relations
  webhooks Webhook[]
  
  // Labor rate relations
  laborRatesCreated    LaborRate[]        @relation("LaborRateCreatedBy")
  laborRateChanges     LaborRateHistory[] @relation("LaborRateChangedBy")
  
  // Alert relations
  alertsCreated        Alert[]            @relation("AlertCreatedBy")
  alertsDismissed      AlertDismissal[]   @relation("AlertDismissedBy")
  alertRulesCreated    AlertRule[]        @relation("AlertRuleCreatedBy")
  alertsResolved       AlertHistory[]     @relation("AlertResolvedBy")
  
  // Integration relations
  integrationsCreated  Integration[]      @relation("IntegrationCreatedBy")
  
  // Saved filter relations
  savedFilters         SavedFilter[]      @relation("SavedFilterCreatedBy")
  
  // Price book relations
  priceBookItemsCreated   PriceBookItem[]    @relation("PriceBookItemCreatedBy")
  priceBookChanges        PriceBookHistory[] @relation("PriceBookChangedBy")
  
  // Audit relations
  auditSnapshots          AuditSnapshot[]    @relation("AuditSnapshotCreatedBy")
  
  // Print job relations
  printJobsAssigned       PrintJob[]         @relation("PrintJobAssignedTo")
  printJobsCreated        PrintJob[]         @relation("PrintJobCreatedBy")
  
  // RIP job relations
  ripJobsCreated          RipJob[]           @relation("RipJobCreatedBy")
  ripJobsOperated         RipJob[]           @relation("RipJobOperator")
  
  // User preference relation (one-to-one)
  preferences             UserPreference?    @relation("UserPreferences")
  
  // Favorites relation
  favorites               Favorite[]         @relation("UserFavorites")
  
  // Recent searches relation
  recentSearches          RecentSearch[]     @relation("UserRecentSearches")
  
  // Import relations
  importJobs              ImportJob[]        @relation("UserImportJobs")
  importMappings          ImportMapping[]    @relation("UserImportMappings")
  importHistories         ImportHistory[]    @relation("UserImports")
  
  // Keyboard shortcuts relation
  keyboardShortcuts       KeyboardShortcut[] @relation("UserKeyboardShortcuts")
  
  // Routing intelligence relations
  routingDecisions        RoutingDecision[]  @relation("UserRoutingDecisions")
  
  // NLP & Command Palette relations
  nlpQueries              NLPQuery[]          @relation("UserNLPQueries")
  savedQueries            SavedQuery[]        @relation("UserSavedQueries")
  commandHistory          CommandHistory[]    @relation("UserCommandHistory")
  actionPreferences       UserActionPreference[] @relation("UserActionPreferences")
  searchSuggestions       SearchSuggestion[]  @relation("UserSearchSuggestions")
  
  // Workflow relations
  workflowsCreated        Workflow[]          @relation("WorkflowCreatedBy")
  
  // Validation & Integrity relations
  validationRulesCreated    ValidationRule[]       @relation("ValidationRuleCreatedBy")
  fieldConstraintsCreated   FieldConstraint[]      @relation("FieldConstraintCreatedBy")
  integrityChecksCreated    DataIntegrityCheck[]   @relation("IntegrityCheckCreatedBy")
  
  // Record version relations
  recordVersions          RecordVersion[]     @relation("RecordVersionChangedBy")
  
  // Audit & Compliance relations
  auditEvents             AuditEvent[]        @relation("UserAuditEvents")
  signatures              SignatureLog[]      @relation("UserSignatures")
  complianceRulesCreated  ComplianceRule[]    @relation("ComplianceRuleCreatedBy")
  accessLogs              AccessLog[]         @relation("UserAccessLogs")
  
  // Multi-tenancy relations
  organizations           OrganizationUser[]  @relation("UserOrganizations")
  departmentMemberships   DepartmentMember[]  @relation("UserDepartments")
  teamMemberships         TeamMember[]        @relation("UserTeams")
  
  // Financial relations
  laborCosts              LaborCostActual[]   @relation("UserLaborCosts")
  
  // Scheduling & Capacity relations
  skillMatrix             SkillMatrix[]       @relation("UserSkillMatrix")
  
  // Quality Management relations
  inspections             InspectionCheckpoint[] @relation("InspectionsByUser")
  ncrsReported            NonConformanceReport[] @relation("NCRReportedBy")
  ncrsAssigned            NonConformanceReport[] @relation("NCRAssignedTo")
  correctiveActionsAssigned CorrectiveAction[] @relation("CAAssignedTo")
  correctiveActionsCreated  CorrectiveAction[] @relation("CACreatedBy")
  correctiveActionsVerified CorrectiveAction[] @relation("CAVerifiedBy")
  
  // Document Management relations
  documentVersionsCreated   DocumentVersion[]     @relation("DocumentVersionCreatedBy")
  templatesCreated          DocumentTemplate[]    @relation("TemplateCreatedBy")
  documentApprovalsAssigned DocumentApproval[]    @relation("DocumentApprover")
  documentApprovalsDelegated DocumentApproval[]   @relation("ApprovalDelegatedTo")
  documentAccessGrants      DocumentAccess[]      @relation("DocumentAccessGrantedBy")
  documentAccessUser        DocumentAccess[]      @relation("DocumentAccessUser")
  documentAccessLogs        DocumentAccessLog[]   @relation("DocumentAccessLogUser")
  
  // Performance Analytics relations
  productivityMetrics       UserProductivity[]    @relation("UserProductivityMetrics")
  
  // SSS-019: Advanced QC System relations
  defectsDiscovered         Defect[]              @relation("DefectDiscoveredBy")
  defectsDisposed           Defect[]              @relation("DefectDisposedBy")
  evidenceTaken             QCEvidence[]          @relation("EvidenceTakenBy")
  rootCauseAnalyses         RootCauseAnalysis[]   @relation("RootCauseAnalyst")
  feedbackReceived          CustomerFeedback[]    @relation("FeedbackReceivedBy")
  feedbackResolved          CustomerFeedback[]    @relation("FeedbackResolvedBy")
  
  // NEW-CRITICAL-01: Project Management relations
  projectsManaged           Project[]             @relation("ProjectManager")
  projectsCreated           Project[]             @relation("ProjectCreatedBy")
  milestonesAssigned        ProjectMilestone[]    @relation("MilestoneAssignee")
  projectNotesAuthored      ProjectNote[]         @relation("ProjectNoteAuthor")
  projectAttachmentsUploaded ProjectAttachment[]  @relation("ProjectAttachmentUploader")
  jobTemplatesCreated       JobTemplate[]         @relation("TemplateCreatedBy")
  
  // NEW-CRITICAL-02: Nesting & Waste relations
  nestingJobsCreated        NestingJob[]          @relation("NestingJobCreator")
  nestingJobsApproved       NestingJob[]          @relation("NestingJobApprover")
  wasteRecorded             WasteRecord[]         @relation("WasteRecorder")
  
  // NEW-CRITICAL-03: Notification & Communication relations
  notificationPreferences   NotificationPreference[] @relation("NotificationPreferences")
  notificationsReceived     NotificationQueue[]   @relation("NotificationRecipient")
  threadsCreated            MessageThread[]       @relation("ThreadCreator")
  threadParticipations      ThreadParticipant[]   @relation("ThreadParticipant")
  messagesAuthored          Message[]             @relation("MessageAuthor")
  announcementsCreated      Announcement[]        @relation("AnnouncementAuthor")
  announcementAcks          AnnouncementAck[]     @relation("AnnouncementAcks")
  communicationLogs         CommunicationLog[]    @relation("CommunicationLogger")
  
  // NEW-CRITICAL-04: Equipment Calibration relations
  calibrationsPerformed     Calibration[]         @relation("CalibrationPerformer")
  
  // NEW-CRITICAL-05: Training & Competency relations
  trainingProgramsCreated   TrainingProgram[]     @relation("TrainingProgramCreator")
  trainingSessions          TrainingSession[]     @relation("TrainingInstructor")
  trainingEnrollments       TrainingEnrollment[]  @relation("TrainingEnrollments")
  competencies              UserCompetency[]      @relation("UserCompetencies")
  competenciesVerified      UserCompetency[]      @relation("CompetencyVerifier")
  
  // NEW-CRITICAL-06: Vendor Relationship Management
  vendorContractsCreated    VendorContract[]      @relation("VendorContractsCreated")
  vendorContractsApproved   VendorContract[]      @relation("VendorContractsApproved")
  vendorCertsVerified       VendorCertification[] @relation("VendorCertificationsVerified")
  vendorRatingsGiven        VendorRating[]        @relation("VendorRatingsGiven")
  vendorCommunicationsLogged VendorCommunication[] @relation("VendorCommunicationsLogged")
  vendorQuotesRequested     VendorQuoteRequest[]  @relation("VendorQuotesRequested")
  
  // NEW-CRITICAL-07: Advanced Shipping & Logistics
  freightQuotesRequested    FreightQuote[]        @relation("FreightQuotesRequested")
  deliveryRoutesCreated     DeliveryRoute[]       @relation("DeliveryRoutesCreated")
  deliveryRoutesDriving     DeliveryRoute[]       @relation("DeliveryRouteDriver")
  
  // NEW-CRITICAL-08: Version Control & Revision Management
  revisionsRequested        EntityRevision[]      @relation("RevisionsRequested")
  revisionsApproved         EntityRevision[]      @relation("RevisionsApproved")
  revisionsRejected         EntityRevision[]      @relation("RevisionsRejected")
  revisionsImplemented      EntityRevision[]      @relation("RevisionsImplemented")
  designVersionsCreated     DesignVersion[]       @relation("DesignVersionsCreated")
  designVersionsApproved    DesignVersion[]       @relation("DesignVersionsApproved")
  changeOrdersRequested     ChangeOrder[]         @relation("ChangeOrdersRequested")
  changeOrdersInternalApproved ChangeOrder[]      @relation("ChangeOrdersInternalApproved")
  changeOrdersImplemented   ChangeOrder[]         @relation("ChangeOrdersImplemented")
  versionComparisons        VersionComparison[]   @relation("ComparisonsGenerated")
  
  // NEW-CRITICAL-09: Environmental & Sustainability
  materialProfilesVerified  MaterialEnvironmentalProfile[] @relation("MaterialProfilesVerified")
  wasteLogsCreated          WasteLogEntry[]       @relation("WasteLogsCreated")
  wasteLogsVerified         WasteLogEntry[]       @relation("WasteLogsVerified")
  energyRecordsCreated      EnergyConsumptionRecord[] @relation("EnergyRecordsCreated")
  emissionsCalculated       CarbonEmissionRecord[] @relation("EmissionsCalculated")
  emissionsVerified         CarbonEmissionRecord[] @relation("EmissionsVerified")
  sustainabilityGoalsOwned  SustainabilityGoal[]  @relation("SustainabilityGoalsOwned")
  sustainabilityGoalsCreated SustainabilityGoal[] @relation("SustainabilityGoalsCreated")
  sustainabilitySnapshots   SustainabilitySnapshot[] @relation("SnapshotsRecorded")
  sustainabilityCalculated  WorkOrderSustainability[] @relation("SustainabilityCalculated")
  
  // NEW-CRITICAL-10: Pricing & Quote Intelligence
  pricingRulesCreated       PricingRule[]         @relation("PricingRulesCreated")
  pricingRulesApplied       PricingRuleApplication[] @relation("PricingRulesApplied")
  quoteScorecards           QuoteScorecard[]      @relation("QuoteScorecards")
  competitorPricesRecorded  CompetitorPrice[]     @relation("CompetitorPricesRecorded")
  quotesAnalyzed            QuoteAnalysis[]       @relation("QuotesAnalyzed")
  
  // Equipment Watch Rules
  equipmentWatchRulesCreated EquipmentWatchRule[] @relation("WatchRuleCreatedBy")
  
  // Production List Integration
  productionListSyncs       ProductionListSync[] @relation("ProductionListSyncs")
  
  // Shop Floor / File Chain relations
  printCutLinksLinked        PrintCutLink[]       @relation("PrintCutLinkLinkedBy")
  printCutLinksConfirmed     PrintCutLink[]       @relation("PrintCutLinkConfirmedBy")
  manualJobLinksCreated      ManualJobLink[]      @relation("ManualJobLinkLinkedBy")
  dismissedJobLinks          DismissedJobLink[]   @relation("DismissedJobLinkDismissedBy")
  installSessionsPerformed  InstallSession[]     @relation("InstallSessionInstaller")
  shippingLabelScans        ShippingLabelScan[]  @relation("ShippingLabelScanner")
  
  // ItemMaster audit relations
  itemMastersCreated        ItemMaster[]         @relation("ItemMasterCreatedBy")
  itemMastersUpdated        ItemMaster[]         @relation("ItemMasterUpdatedBy")
  
  // Portal invite relations
  portalInvitesCreated      PortalInvite[]       @relation("PortalInvitesCreated")

  // Design Revision relations
  revisionRequestsCreated   DesignRevisionRequest[] @relation("RevisionRequestsCreated")
  revisionRequestsResolved  DesignRevisionRequest[] @relation("RevisionRequestsResolved")

  // Gamification relations
  achievements              UserAchievement[]    @relation("UserAchievements")
  streak                    UserStreak?          @relation("UserStreak")

  // Line item completion relations
  lineItemCompletions       LineItemCompletion[] @relation("LineItemCompletedBy")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
  VIEWER
}

enum CompanyBrand {
  WILDE_SIGNS
  PORT_CITY_SIGNS
}

// ============ Work Schedules ============

model WorkSchedule {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0 = Sunday, 1 = Monday, ..., 6 = Saturday
  startTime String // HH:mm format (e.g., "09:00")
  endTime   String // HH:mm format (e.g., "17:00")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, dayOfWeek])
}

model TimeOffRequest {
  id         String        @id @default(uuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate  DateTime
  endDate    DateTime
  type       TimeOffType
  status     TimeOffStatus @default(PENDING)
  reason     String?
  approvedBy String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

enum TimeOffType {
  VACATION
  SICK
  PERSONAL
  UNPAID
  HOLIDAY
  OTHER
}

enum TimeOffStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

// ============ Work Orders ============

model WorkOrder {
  id           String           @id @default(uuid())
  orderNumber  String           @unique
  customerName String
  description  String
  status       OrderStatus      @default(PENDING)
  priority     Int              @default(3)
  companyBrand CompanyBrand     @default(WILDE_SIGNS)
  dueDate      DateTime?
  notes        String?
  routing      PrintingMethod[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Nesting - indicates this WO is nested with others on a single print
  nestingEnabled  Boolean       @default(false)
  nestingFileName String?       // Name or ID of the nesting file grouping this WO

  // Network folder override - manually linked folder path (relative to networkDriveBasePath)
  networkFolderPath String?     // e.g. "CUSTOMER NAME/WO12345_Description"

  // Temp WO tracking - orders created in ERP before linked to QuickBooks
  isTempOrder        Boolean   @default(true) // True until linked to QB
  quickbooksOrderNum String? // The real QB order number when linked
  linkedAt           DateTime? // When linked to QB order
  linkedById         String? // Who linked it
  qbTxnId            String?   // QB TxnID for robust deduplication

  // Relations
  createdById  String
  createdBy    User      @relation("CreatedBy", fields: [createdById], references: [id])
  assignedToId String?
  assignedTo   User?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  
  // Company (new) - will replace customerId
  companyId    String?
  company      Company?  @relation("CompanyWorkOrders", fields: [companyId], references: [id])
  
  // Contact (PoC at the company)
  contactId    String?
  contact      Contact?  @relation("ContactWorkOrders", fields: [contactId], references: [id])
  
  // PO Number
  poNumber     String?
  
  // Customer (legacy - being deprecated)
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])

  lineItems        LineItem[]
  stationProgress  StationProgress[]
  events           WorkEvent[]
  timeEntries      TimeEntry[]
  reprintRequests  ReprintRequest[]
  inventoryItems   InventoryItem[]
  attachments      OrderAttachment[]
  shipments        Shipment[]
  fedExShipmentRecords FedExShipmentRecord[]
  materialUsages   MaterialUsage[]
  jobCost          JobCost?
  qcInspections    QCInspection[]
  proofApprovals   ProofApproval[]
  portalMessages   PortalMessage[]
  emailQueue       EmailQueue[]
  productionSlots  ProductionSlot[]
  documents        Document[]        @relation("OrderDocuments")
  creditApprovals  CreditApproval[]
  subcontractJobs  SubcontractJob[]
  recurringOrderId String?
  recurringOrder   RecurringOrder?   @relation("RecurringOrderSource", fields: [recurringOrderId], references: [id])
  installationJobs InstallationJob[]
  printJobs        PrintJob[]
  ripJobs          RipJob[]
  printCutLinks    PrintCutLink[]
  manualJobLinks     ManualJobLink[]
  dismissedJobLinks  DismissedJobLink[]
  installSessions    InstallSession[]
  shippingScans    ShippingLabelScan[]
  
  // Routing intelligence relations
  routingPredictions RoutingPrediction[] @relation("WorkOrderRoutingPredictions")
  routingDecisions   RoutingDecision[]   @relation("WorkOrderRoutingDecisions")
  
  // Financial tracking relations
  materialCosts      MaterialCost[]      @relation("WorkOrderMaterialCosts")
  laborCosts         LaborCostActual[]   @relation("WorkOrderLaborCosts")
  overheadAllocations OverheadAllocation[] @relation("WorkOrderOverhead")
  
  // Quality Management relations
  inspectionCheckpoints InspectionCheckpoint[] @relation("WorkOrderInspections")
  nonConformanceReports NonConformanceReport[] @relation("WorkOrderNCRs")
  
  // Performance Analytics relations
  leadTimeHistory       LeadTimeHistory?       @relation("WorkOrderLeadTime")
  
  // SSS-019: Advanced QC System relations
  defects               Defect[]               @relation("WorkOrderDefects")
  customerFeedback      CustomerFeedback[]     @relation("WorkOrderFeedback")
  
  // NEW-CRITICAL-01: Project Management relations
  projectLinks          ProjectWorkOrder[]
  
  // NEW-CRITICAL-07: Freight quotes
  freightQuotes         FreightQuote[]
  
  // NEW-CRITICAL-08: Change orders
  changeOrders          ChangeOrder[]
  
  // NEW-CRITICAL-09: Environmental & Sustainability
  wasteEntries          WasteLogEntry[]    @relation("WorkOrderWaste")
  carbonEmissions       CarbonEmissionRecord[] @relation("WorkOrderEmissions")
  sustainabilitySummary WorkOrderSustainability?
  
  // Production List Integration
  productionListSnapshots ProductionListSnapshot[] @relation("ProductionListSnapshots")

  // Design Revision Requests
  revisionRequests  DesignRevisionRequest[] @relation("OrderRevisionRequests")
  barcodescans      BarcodeScan[]

  // ============ Performance Indexes ============
  // Single column indexes
  @@index([status])
  @@index([recurringOrderId])
  @@index([createdAt])
  @@index([dueDate])
  @@index([customerId])
  @@index([contactId])
  @@index([companyId, status])                         // Company view: orders by company and status
  @@index([companyBrand])                              // Brand filtering
  
  // Compound indexes for common query patterns
  @@index([status, dueDate])                           // Dashboard: orders by status sorted by due date
  @@index([status, priority])                          // Priority queue: orders by status and priority
  @@index([status, createdAt])                         // Lists: orders by status sorted by creation
  @@index([assignedToId, status])                      // User dashboard: assigned orders by status
  @@index([customerId, status])                        // Customer view: orders by customer and status
  @@index([customerId, createdAt])                     // Customer history: orders sorted by date
  @@index([status, assignedToId, dueDate])             // Workload: assigned orders due soon
  @@index([isTempOrder, status])                       // Temp order management
  @@index([quickbooksOrderNum])                        // QB sync lookups
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  SHIPPED
  CANCELLED
}

enum PrintingMethod {
  // Primary stations
  SALES
  DESIGN_ONLY
  ORDER_ENTRY
  DESIGN
  FLATBED
  ROLL_TO_ROLL
  SCREEN_PRINT
  PRODUCTION
  SHIPPING_RECEIVING
  INSTALLATION
  COMPLETE
  // Design sub-stations
  DESIGN_PROOF
  DESIGN_APPROVAL
  DESIGN_PRINT_READY
  // Flatbed sub-stations
  FLATBED_PRINTING
  // Roll to Roll sub-stations
  ROLL_TO_ROLL_PRINTING
  // Screen Print sub-stations
  SCREEN_PRINT_PRINTING
  SCREEN_PRINT_ASSEMBLY
  // Production sub-stations
  PRODUCTION_ZUND
  PRODUCTION_FINISHING
  // Shipping sub-stations
  SHIPPING_QC
  SHIPPING_PACKAGING
  SHIPPING_SHIPMENT
  SHIPPING_INSTALL_READY
  // Installation sub-stations
  INSTALLATION_REMOTE
  INSTALLATION_INHOUSE
  // Complete sub-stations
  COMPLETE_INSTALLED
  COMPLETE_SHIPPED
  COMPLETE_DESIGN_ONLY
}

// ============ Line Items ============

model LineItem {
  id          String   @id @default(uuid())
  itemNumber  Int
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  orderId      String
  order        WorkOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemMasterId String?
  itemMaster   ItemMaster? @relation(fields: [itemMasterId], references: [id])

  reprintRequests ReprintRequest[]
  inventoryItems  InventoryItem[]
  completions     LineItemCompletion[]

  @@unique([orderId, itemNumber])
}

// ============ Station Progress ============

model StationProgress {
  id          String         @id @default(uuid())
  station     PrintingMethod
  status      StationStatus  @default(NOT_STARTED)
  startedAt   DateTime?
  completedAt DateTime?

  // Relations
  orderId       String
  order         WorkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  completedById String?
  completedBy   User?     @relation("CompletedBy", fields: [completedById], references: [id])

  @@unique([orderId, station])
  // ============ Performance Indexes ============
  @@index([station, status])                           // Station dashboard
  @@index([status, completedAt])                       // Completed work tracking
}

enum StationStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

// ============ Production Scheduling ============

model ProductionSlot {
  id             String         @id @default(uuid())
  station        PrintingMethod
  scheduledDate  DateTime       @db.Date
  scheduledStart DateTime?      @db.Time(0)
  scheduledEnd   DateTime?      @db.Time(0)
  estimatedHours Decimal        @db.Decimal(5, 2)
  actualHours    Decimal?       @db.Decimal(5, 2)
  status         SlotStatus     @default(SCHEDULED)
  priority       Int            @default(1)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  workOrderId  String
  workOrder    WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  assignedToId String?
  assignedTo   User?     @relation("ProductionAssignee", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User      @relation("ProductionCreator", fields: [createdById], references: [id])

  @@index([scheduledDate])
  @@index([station])
  @@index([status])
  @@index([workOrderId])
  @@index([assignedToId])
}

enum SlotStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  RESCHEDULED
  CANCELLED
}

// ============ Events / Audit Log ============

model WorkEvent {
  id          String    @id @default(uuid())
  eventType   EventType
  description String
  details     Json?
  createdAt   DateTime  @default(now())

  // Relations
  orderId String
  order   WorkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId  String
  user    User      @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([createdAt])
  @@index([eventType])
}

enum EventType {
  CREATED
  STATUS_CHANGED
  PRIORITY_CHANGED
  LINE_ADDED
  LINE_UPDATED
  LINE_REMOVED
  ROUTING_SET
  STATION_STARTED
  STATION_COMPLETED
  STATION_UNCOMPLETED
  STATION_STATUS_CHANGED
  STATION_CLAIMED
  STATION_AUTO_ADVANCED
  MATERIAL_DEDUCTED
  TIME_LOGGED
  PRINTED
  REPRINTED
  NOTE_ADDED
  ASSIGNED
  UNASSIGNED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
}

// ============ Time Tracking ============

model TimeEntry {
  id              String         @id @default(uuid())
  station         PrintingMethod
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  notes           String?

  // Relations
  orderId String
  order   WorkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId  String
  user    User      @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([userId])
}

// ============ Reprint Requests ============

model ReprintRequest {
  id          String        @id @default(uuid())
  reason      ReprintReason
  description String
  quantity    Int
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())

  // Relations
  orderId       String
  order         WorkOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
