{
  "name": "@erp/server-manager",
  "version": "1.0.0",
  "description": "ERP Server Manager - Control panel for backend and frontend servers",
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "tsc && electron-builder",
    "build:win": "tsc && electron-builder --win --x64",
    "start": "electron ."
  },
  "author": "Wilde Signs",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@tauri-apps/plugin-shell": "2.3.5",
    "bcrypt": "6.0.0",
    "odbc": "2.3.6",
    "pm2": "^5.3.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.wildesigns.erp-server-manager",
    "productName": "ERP Server Manager",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "dist/**/*",
      "src/index.html",
      "assets/**/*",
      "node_modules/**/*",
      "ecosystem.config.js"
    ],
    "extraResources": [
      {
        "from": "../server",
        "to": "server",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      },
      {
        "from": "../web",
        "to": "web",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      },
      {
        "from": "../shared",
        "to": "shared",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      }
    ]
  }
}
