# Database
DATABASE_URL="postgresql://erp_user:erp_password@localhost:5432/erp_workflow?schema=public"

# JWT Secret (generate a strong random string for production)
JWT_SECRET="change-this-to-a-secure-secret-in-production"
JWT_EXPIRES_IN="7d"

# Server
SERVER_PORT=8001
SERVER_HOST="0.0.0.0"

# Web App
VITE_API_URL="http://localhost:8001"
VITE_WS_URL="ws://localhost:8001"

# Email Configuration (optional - if not set, email notifications are disabled)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="noreply@example.com"
APP_URL="http://localhost:5173"
COMPANY_NAME="Wilde Signs"

# QuickBooks Desktop Integration (READ-ONLY)
# Connects to QuickBooks Desktop via ODBC driver
QB_HOST="CHRISTINA-NEW"
QB_DSN="QuickBooks Data"
QB_COMPANY_FILE=""
QB_CONNECTION_TIMEOUT=30000

# Node Environment
NODE_ENV="development"
